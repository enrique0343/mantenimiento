# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mantenimiento"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="local-dev-secret-cambiar-en-produccion-32chars"
JWT_EXPIRES_IN="8h"

# ── Storage local (sin Supabase) ──────────────────────────────────────────────
# Dejar vacíos para usar almacenamiento en disco local (/uploads)
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_BUCKET=""

# ── Servidor ──────────────────────────────────────────────────────────────────
BASE_URL="http://localhost:3001"
CLIENT_URL="http://localhost:5173"
PORT=3001
NODE_ENV="development"

# ── SMTP (opcional en local — los emails se muestran solo en consola) ─────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
