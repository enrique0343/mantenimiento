---
import "@/styles/globals.css";

interface Props {
  title?: string;
  hideNav?: boolean;
}
const { title = "Mantenimiento", hideNav = false } = Astro.props;
const user = Astro.locals.user;
const path = Astro.url.pathname;

const isAdmin = user?.rol === "admin";
const isAdminOrJefe = user?.rol === "admin" || user?.rol === "jefe";
const isOperativo = user?.rol === "admin" || user?.rol === "jefe" || user?.rol === "tecnico";
const isMotorista = user?.rol === "motorista";
const verFlota = isAdminOrJefe || isMotorista;

interface Link { href: string; label: string; show?: boolean }

const motoLinks: Link[] = [
  { href: "/mi-panel", label: "Mi panel" },
  { href: "/flota", label: "Flota" },
  { href: "/tickets", label: "Reportes" },
];

const homeHref = user?.rol === "tecnico" ? "/mi-panel" : "/";
const homeLabel = user?.rol === "tecnico" ? "Mi panel" : "Dashboard";

const primarios: Link[] = [
  { href: homeHref, label: homeLabel },
  { href: "/ordenes", label: "Órdenes" },
  { href: "/cronograma", label: "Cronograma" },
  { href: "/activos", label: "Equipos" },
  { href: "/tickets", label: "Tickets" },
];

const masGrupos: { titulo: string; items: Link[] }[] = [
  {
    titulo: "Recursos",
    items: [
      { href: "/actividades", label: "Actividades", show: !isMotorista && user?.rol !== "proveedor" },
      { href: "/seguridad", label: "Extintores y seguridad", show: !isMotorista && user?.rol !== "proveedor" },
      { href: "/flota", label: "Flota", show: verFlota },
      { href: "/inventario", label: "Inventario" },
    ],
  },
  {
    titulo: "Análisis",
    items: [
      { href: "/kpis", label: "KPIs", show: isAdminOrJefe },
      { href: "/planificador", label: "Planificador", show: isOperativo },
    ],
  },
  {
    titulo: "Administración",
    items: [
      { href: "/proveedores", label: "Proveedores", show: isAdminOrJefe },
      { href: "/usuarios", label: "Usuarios", show: isAdmin },
      { href: "/configuracion", label: "Configuración", show: isAdmin },
    ],
  },
];

const ROL_LABEL: Record<string, string> = {
  admin: "Admin",
  jefe: "Jefe",
  tecnico: "Técnico",
  proveedor: "Proveedor",
  solicitante: "Solicitante",
  visualizador: "Visualizador",
  motorista: "Motorista",
};

const isActive = (href: string) =>
  path === href || (href !== "/" && href.length > 1 && path.startsWith(href));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    {
      !hideNav && user && (
        <header class="border-b border-slate-200 bg-white">
          <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3">
            <a href="/" class="text-lg font-bold text-brand-600 whitespace-nowrap">Mantenimiento</a>

            <nav class="flex flex-1 items-center gap-1 overflow-x-auto">
              {isMotorista
                ? motoLinks.map((l) => (
                    <a href={l.href} class:list={["rounded-md px-3 py-1.5 text-sm font-medium whitespace-nowrap",
                      isActive(l.href) ? "bg-brand-50 text-brand-700" : "text-slate-700 hover:bg-slate-100"]}>{l.label}</a>
                  ))
                : primarios.map((l) => (
                    <a href={l.href} class:list={["rounded-md px-3 py-1.5 text-sm font-medium whitespace-nowrap",
                      isActive(l.href) ? "bg-brand-50 text-brand-700" : "text-slate-700 hover:bg-slate-100"]}>{l.label}</a>
                  ))
              }
            </nav>

            {!isMotorista && (
              <div id="moreMenu" class="relative">
                <button id="moreBtn" type="button" aria-haspopup="true" aria-expanded="false"
                  class="cursor-pointer rounded-md px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100 whitespace-nowrap">
                  Más ▾
                </button>
                <div id="moreDropdown" class="hidden absolute right-0 top-full z-50 mt-1 w-64 rounded-lg border border-slate-200 bg-white shadow-lg">
                  {masGrupos.map((g) => {
                    const visibles = g.items.filter((it) => it.show === undefined || it.show);
                    if (visibles.length === 0) return null;
                    return (
                      <div class="py-1">
                        <div class="px-3 pt-2 pb-1 text-[10px] font-semibold uppercase tracking-wide text-slate-400">{g.titulo}</div>
                        {visibles.map((it) => (
                          <a href={it.href} class:list={["block px-4 py-1.5 text-sm",
                            isActive(it.href) ? "bg-brand-50 text-brand-700 font-medium" : "text-slate-700 hover:bg-slate-50"]}>{it.label}</a>
                        ))}
                      </div>
                    );
                  })}
                </div>
              </div>
            )}

            <div class="flex items-center gap-3 whitespace-nowrap">
              <span class="text-sm text-slate-600">
                {user.nombre}
                <span class="ml-1 rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-500">
                  {ROL_LABEL[user.rol] ?? user.rol}
                </span>
              </span>
              <button id="logoutBtn" class="btn-secondary">Salir</button>
            </div>
          </div>
        </header>
      )
    }
    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>
    <script is:inline>
      // Logout
      document.getElementById("logoutBtn")?.addEventListener("click", async () => {
        await fetch("/api/auth/logout", { method: "POST" });
        location.href = "/login";
      });

      // Dropdown "Más" (toggle JS plano)
      (function () {
        var btn = document.getElementById("moreBtn");
        var dd = document.getElementById("moreDropdown");
        if (!btn || !dd) return;
        btn.addEventListener("click", function (e) {
          e.stopPropagation();
          var open = !dd.classList.contains("hidden");
          if (open) {
            dd.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
          } else {
            dd.classList.remove("hidden");
            btn.setAttribute("aria-expanded", "true");
          }
        });
        document.addEventListener("click", function (e) {
          if (!btn.contains(e.target) && !dd.contains(e.target)) {
            dd.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
          }
        });
        // Cierra al presionar Escape
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") {
            dd.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
          }
        });
      })();
    </script>
  </body>
</html>
