---
import "@/styles/globals.css";

interface Props {
  title?: string;
  hideNav?: boolean;
}
const { title = "Mantenimiento", hideNav = false } = Astro.props;
const user = Astro.locals.user;
const path = Astro.url.pathname;

const isAdmin = user?.rol === "admin";
const isAdminOrJefe = user?.rol === "admin" || user?.rol === "jefe";
const isOperativo = user?.rol === "admin" || user?.rol === "jefe" || user?.rol === "tecnico";
const isMotorista = user?.rol === "motorista";
const verFlota = isAdminOrJefe || isMotorista;
const esProveedor = user?.rol === "proveedor";

interface Link { href: string; label: string; show?: boolean }

const motoLinks: Link[] = [
  { href: "/mi-panel", label: "Mi panel" },
  { href: "/flota", label: "Flota" },
  { href: "/tickets", label: "Reportes" },
];

const homeHref = user?.rol === "tecnico" ? "/mi-panel" : "/";
const homeLabel = user?.rol === "tecnico" ? "Mi panel" : "Dashboard";

const navLinks: Link[] = [
  { href: homeHref,        label: homeLabel },
  { href: "/ordenes",      label: "Órdenes",            show: !isMotorista && !esProveedor },
  { href: "/cronograma",   label: "Cronograma",          show: !isMotorista && !esProveedor },
  { href: "/activos",      label: "Equipos",             show: !isMotorista },
  { href: "/tickets",      label: "Tickets",             show: !isMotorista },
  { href: "/actividades",  label: "Actividades",         show: isOperativo },
  { href: "/seguridad",    label: "Extintores",          show: isOperativo },
  { href: "/flota",        label: "Flota",               show: verFlota },
  { href: "/inventario",   label: "Inventario",          show: !isMotorista },
  { href: "/kpis",         label: "KPIs",                show: isAdminOrJefe },
  { href: "/planificador", label: "Planificador",        show: isAdminOrJefe },
  { href: "/proveedores",  label: "Proveedores",         show: isAdminOrJefe },
  { href: "/usuarios",     label: "Usuarios",            show: isAdmin },
  { href: "/configuracion",label: "Configuración",       show: isAdmin },
];

const linksVisibles = isMotorista
  ? motoLinks
  : navLinks.filter((l) => l.show === undefined || l.show);

const ROL_LABEL: Record<string, string> = {
  admin: "Admin",
  jefe: "Jefe",
  tecnico: "Técnico",
  proveedor: "Proveedor",
  solicitante: "Solicitante",
  visualizador: "Visualizador",
  motorista: "Motorista",
};

const isActive = (href: string) =>
  path === href || (href !== "/" && href.length > 1 && path.startsWith(href));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    {
      !hideNav && user && (
        <header class="border-b border-slate-200 bg-white">
          <!-- Fila 1: Logo + usuario + salir -->
          <div class="mx-auto flex max-w-7xl items-center justify-between px-4 pt-3 pb-1">
            <a href="/" class="text-lg font-bold text-brand-600">Mantenimiento</a>
            <div class="flex items-center gap-3">
              <span class="text-sm text-slate-600">
                {user.nombre}
                <span class="ml-1 rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-500">
                  {ROL_LABEL[user.rol] ?? user.rol}
                </span>
              </span>
              <button id="logoutBtn" class="btn-secondary text-sm">Salir</button>
            </div>
          </div>

          <!-- Fila 2: Navegación horizontal deslizable -->
          <nav class="mx-auto max-w-7xl overflow-x-auto px-4 pb-2">
            <div class="flex items-center gap-0.5 w-max">
              {linksVisibles.map((l) => (
                <a href={l.href} class:list={["rounded-md px-3 py-1.5 text-sm font-medium whitespace-nowrap",
                  isActive(l.href) ? "bg-brand-50 text-brand-700" : "text-slate-600 hover:bg-slate-100 hover:text-slate-800"]}>
                  {l.label}
                </a>
              ))}
            </div>
          </nav>
        </header>
      )
    }
    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>
    <script is:inline>
      document.getElementById("logoutBtn")?.addEventListener("click", async () => {
        await fetch("/api/auth/logout", { method: "POST" });
        location.href = "/login";
      });
    </script>
  </body>
</html>
