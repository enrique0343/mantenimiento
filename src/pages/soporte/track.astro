---
import "@/styles/globals.css";
export const prerender = false;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Consultar estado</title>
  </head>
  <body class="min-h-screen bg-slate-50">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-3xl px-4 py-3">
        <a href="/soporte" class="text-lg font-bold text-brand-600">← Soporte</a>
      </div>
    </header>
    <main class="mx-auto max-w-md px-4 py-10">
      <h1 class="text-2xl font-bold">Consultar mi ticket</h1>
      <p class="mt-1 text-sm text-slate-600">Ingresa el código de seguimiento que recibiste al crear tu ticket.</p>
      <form id="form" class="card mt-4 space-y-3 p-5">
        <input id="token" class="input text-center font-mono text-lg uppercase" placeholder="Código (12 caracteres)" maxlength="12" required />
        <button class="btn-primary w-full justify-center" type="submit">Consultar</button>
      </form>
    </main>
    <script>
      document.getElementById("form")?.addEventListener("submit", (e) => {
        e.preventDefault();
        const t = (document.getElementById("token")).value.trim().toUpperCase();
        if (t.length === 12) location.href = `/soporte/track/${t}`;
      });
    </script>
  </body>
</html>
