---
import "@/styles/globals.css";
import { getDb } from "@/lib/db";
import { tickets, ticketComentarios, usuarios, ordenes } from "@/lib/schema";
import { eq, asc } from "drizzle-orm";
import { ESTADO_TICKET_LABEL, ESTADO_TICKET_COLOR, type EstadoTicket } from "@/lib/tickets";
export const prerender = false;

const token = String(Astro.params.token ?? "").toUpperCase();
const db = getDb(Astro);
const [t] = await db.select().from(tickets).where(eq(tickets.trackingToken, token)).limit(1);

const coms = t
  ? await db
      .select({ c: ticketComentarios, u: usuarios })
      .from(ticketComentarios)
      .leftJoin(usuarios, eq(usuarios.id, ticketComentarios.usuarioId))
      .where(eq(ticketComentarios.ticketId, t.id))
      .orderBy(asc(ticketComentarios.id))
  : [];

// Cargar la OT vinculada para saber si está completada/verificada y dentro
// de la ventana de 48h para reportar inconformidad
let ot: any = null;
let mostrarInconformidad = false;
let horasRestantes = 0;
const VENTANA_HORAS = 48;
if (t?.otId) {
  const [otRow] = await db.select().from(ordenes).where(eq(ordenes.id, t.otId)).limit(1);
  ot = otRow ?? null;
  if (ot && (ot.estado === "completada" || ot.estado === "verificada") && ot.completadaEn) {
    const horas = (Date.now() - new Date(ot.completadaEn).getTime()) / 3_600_000;
    if (horas < VENTANA_HORAS) {
      mostrarInconformidad = true;
      horasRestantes = Math.max(0, Math.round(VENTANA_HORAS - horas));
    }
  }
}

const abrirInconformidad = Astro.url.searchParams.get("inconformidad") === "1";
const fmt = (s: string | null) => (s ? new Date(s).toLocaleString("es") : "-");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ticket {token}</title>
  </head>
  <body class="min-h-screen bg-slate-50">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-3xl px-4 py-3"><a href="/soporte" class="text-lg font-bold text-brand-600">← Soporte</a></div>
    </header>
    <main class="mx-auto max-w-3xl px-4 py-8">
      {!t && <div class="card p-6 text-center text-slate-500">Ticket no encontrado. Verifica el código.</div>}
      {t && (
        <>
          <div class="flex items-start justify-between gap-3">
            <div>
              <h1 class="text-2xl font-bold">{t.asunto}</h1>
              <p class="mt-1 font-mono text-xs text-slate-500">#{t.id} · {token}</p>
            </div>
            <span class={`badge ${ESTADO_TICKET_COLOR[t.estado as EstadoTicket]}`}>{ESTADO_TICKET_LABEL[t.estado as EstadoTicket]}</span>
          </div>

          <div class="card mt-4 p-5">
            <h2 class="text-sm font-semibold text-slate-700">Tu solicitud</h2>
            <p class="mt-2 whitespace-pre-wrap text-sm text-slate-600">{t.descripcion}</p>
            <div class="mt-3 grid grid-cols-2 gap-3 text-xs text-slate-500">
              <div><strong>Creado:</strong> {fmt(t.createdAt)}</div>
              <div><strong>SLA:</strong> {fmt(t.vencimientoSla)}</div>
              {t.resueltoEn && <div class="col-span-2"><strong>Resuelto:</strong> {fmt(t.resueltoEn)}</div>}
            </div>
            {t.resolucionNotas && (
              <div class="mt-3 rounded bg-emerald-50 p-3 text-sm text-slate-700"><strong>Resolución:</strong> {t.resolucionNotas}</div>
            )}
          </div>

          {mostrarInconformidad && (
            <div id="inconformidadBox" class="card mt-4 p-5 border-l-4 border-red-400">
              <h2 class="text-sm font-semibold text-red-700">¿El problema persiste?</h2>
              <p class="mt-1 text-sm text-slate-600">
                Tu orden fue marcada como <strong>resuelta</strong>. Tienes <strong>{horasRestantes} horas</strong> para reportar inconformidad y reabrirla automáticamente. Después, deberás crear un nuevo ticket.
              </p>
              <button id="btnAbrirIncon" class:list={["mt-3 px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700", abrirInconformidad ? "hidden" : ""]}>
                Reportar inconformidad
              </button>
              <form id="formIncon" class:list={["mt-3 space-y-2", abrirInconformidad ? "" : "hidden"]}>
                <label class="block text-sm font-medium text-slate-700">Cuéntanos qué notaste</label>
                <textarea id="motivoIncon" class="input" rows="4" minlength="10" placeholder="Ej: el aire sigue sin enfriar, el filtro quedó mal puesto, etc." required></textarea>
                <p class="text-xs text-slate-500">Sé específico: nos ayuda a resolver más rápido. Mínimo 10 caracteres.</p>
                <p id="errIncon" class="hidden text-sm text-red-600"></p>
                <div class="flex gap-2">
                  <button type="submit" class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700">
                    Enviar y reabrir orden
                  </button>
                  <button type="button" id="btnCancelIncon" class="px-4 py-2 rounded-lg border border-slate-300 text-slate-600 text-sm hover:bg-slate-50">
                    Cancelar
                  </button>
                </div>
              </form>
              <div id="okIncon" class="hidden mt-3 rounded bg-emerald-50 border border-emerald-200 p-3 text-sm text-emerald-800">
                ✓ Reportamos tu inconformidad y la orden fue reabierta. El técnico ya recibió la notificación.
              </div>
            </div>
          )}

          <div class="card mt-4 p-5">
            <h2 class="text-sm font-semibold text-slate-700">Conversación</h2>
            <ul class="mt-3 space-y-3 text-sm">
              {coms.filter((c) => c.c.publico).length === 0 && <li class="text-slate-500">Sin comentarios aún.</li>}
              {coms.filter((c) => c.c.publico).map((r) => (
                <li class="rounded-md bg-slate-50 p-3">
                  <div class="text-xs text-slate-500">{r.u?.nombre ?? r.c.autorExterno ?? "Solicitante"} · {fmt(r.c.createdAt)}</div>
                  <div class="mt-1 whitespace-pre-wrap">{r.c.texto}</div>
                </li>
              ))}
            </ul>
            {(t.estado !== "cerrado" && t.estado !== "descartado") && (
              <form id="comForm" class="mt-3 space-y-2">
                <textarea id="comTexto" class="input" rows="3" placeholder="Agregar mensaje..."></textarea>
                <button type="submit" class="btn-primary">Enviar</button>
              </form>
            )}
          </div>
        </>
      )}
    </main>
    <script define:vars={{ token, abrirInconformidad }}>
      document.getElementById("comForm")?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const texto = document.getElementById("comTexto").value.trim();
        if (!texto) return;
        const res = await fetch(`/api/tickets/track/${token}`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ texto }),
        });
        if (res.ok) location.reload();
      });

      const btnAbrir = document.getElementById("btnAbrirIncon");
      const formIncon = document.getElementById("formIncon");
      const btnCancel = document.getElementById("btnCancelIncon");
      btnAbrir?.addEventListener("click", () => {
        btnAbrir.classList.add("hidden");
        formIncon.classList.remove("hidden");
        document.getElementById("motivoIncon")?.focus();
      });
      btnCancel?.addEventListener("click", () => {
        formIncon.classList.add("hidden");
        btnAbrir.classList.remove("hidden");
      });

      formIncon?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const motivo = document.getElementById("motivoIncon").value.trim();
        const err = document.getElementById("errIncon");
        err.classList.add("hidden");
        if (motivo.length < 10) {
          err.textContent = "Por favor describe qué notaste con al menos 10 caracteres.";
          err.classList.remove("hidden");
          return;
        }
        const submitBtn = formIncon.querySelector("button[type='submit']");
        submitBtn.disabled = true;
        submitBtn.textContent = "Enviando...";
        const res = await fetch(`/api/tickets/track/${token}/reabrir`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ motivo }),
        });
        const j = await res.json().catch(() => ({}));
        if (res.ok) {
          formIncon.classList.add("hidden");
          document.getElementById("okIncon").classList.remove("hidden");
          setTimeout(() => location.reload(), 2500);
        } else {
          err.textContent = j.error ?? "Error al enviar. Intenta de nuevo.";
          err.classList.remove("hidden");
          submitBtn.disabled = false;
          submitBtn.textContent = "Enviar y reabrir orden";
        }
      });

      // Si llega con ?inconformidad=1, hacer scroll al bloque
      if (abrirInconformidad) {
        document.getElementById("inconformidadBox")?.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    </script>
  </body>
</html>

