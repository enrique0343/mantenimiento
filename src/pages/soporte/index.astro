---
import "@/styles/globals.css";
import { getDb } from "@/lib/db";
import { sucursales, empresa } from "@/lib/schema";
import { eq } from "drizzle-orm";
export const prerender = false;

const db = getDb(Astro);
const [emp] = await db.select().from(empresa).limit(1);
const sucRows = await db.select({ id: sucursales.id, nombre: sucursales.nombre })
  .from(sucursales).where(eq(sucursales.activa, true)).orderBy(sucursales.nombre);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Soporte — {emp?.nombre ?? "Mantenimiento"}</title>
  </head>
  <body class="min-h-screen bg-slate-50">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3">
        <h1 class="text-lg font-bold text-brand-600">{emp?.nombre ?? "Soporte"}</h1>
        <a href="/soporte/track" class="text-sm text-brand-700 hover:underline">¿Ya enviaste un ticket? Consultar estado →</a>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10">
      <div id="successBox" class="hidden card border-l-4 border-emerald-500 p-5">
        <h2 class="text-xl font-semibold text-emerald-700">✓ Ticket creado</h2>
        <p class="mt-2 text-sm text-slate-700">Tu solicitud fue recibida. Guarda este código de seguimiento:</p>
        <div class="mt-3 rounded-lg bg-slate-900 p-4 text-center font-mono text-2xl text-emerald-300" id="trackToken"></div>
        <p class="mt-3 text-sm text-slate-600">Puedes consultar el estado en cualquier momento en <a href="/soporte/track" class="text-brand-700 hover:underline">/soporte/track</a></p>
        <p class="mt-1 text-xs text-slate-500">Tiempo de respuesta estimado: <span id="slaInfo"></span></p>
      </div>

      <div id="formBox">
        <h2 class="text-2xl font-bold">Solicitar soporte / mantenimiento</h2>
        <p class="mt-1 text-sm text-slate-600">Completa el formulario y nuestro equipo te atenderá lo antes posible.</p>

        <form id="form" class="card mt-5 space-y-4 p-5">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label class="label">Tu nombre *</label>
              <input class="input" id="solicitanteNombre" required minlength="2" />
            </div>
            <div>
              <label class="label">Email *</label>
              <input class="input" id="solicitanteEmail" type="email" required />
            </div>
            <div>
              <label class="label">Teléfono</label>
              <input class="input" id="solicitanteTelefono" type="tel" />
            </div>
            <div>
              <label class="label">Prioridad</label>
              <select class="input" id="prioridad">
                <option value="baja">Baja (asunto rutinario)</option>
                <option value="media" selected>Media</option>
                <option value="alta">Alta (afecta operaciones)</option>
                <option value="urgente">Urgente (paro / riesgo)</option>
              </select>
            </div>
          </div>
          <div>
            <label class="label">Asunto *</label>
            <input class="input" id="asunto" required minlength="3" placeholder="Breve descripción del problema" />
          </div>
          <div>
            <label class="label">Descripción detallada *</label>
            <textarea class="input" id="descripcion" rows="5" required minlength="10" placeholder="¿Qué está fallando? ¿Cuándo empezó? ¿Qué equipo o área se ve afectado?"></textarea>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {sucRows.length > 0 && (
              <div>
                <label class="label">Sucursal</label>
                <select class="input" id="sucursalId">
                  <option value="">— Seleccionar —</option>
                  {sucRows.map((s) => <option value={s.id}>{s.nombre}</option>)}
                </select>
              </div>
            )}
            <div>
              <label class="label">Ubicación específica</label>
              <input class="input" id="ubicacion" placeholder="Ej: Sala 3, Piso 2 - Quirófano A" />
            </div>
          </div>
          <p id="err" class="hidden text-sm text-red-600"></p>
          <button class="btn-primary w-full justify-center" type="submit">Enviar solicitud</button>
        </form>
      </div>
    </main>

    <script>
      const form = document.getElementById("form");
      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const err = document.getElementById("err");
        err.classList.add("hidden");
        const v = (id) => document.getElementById(id)?.value?.trim() ?? "";
        const sucEl = document.getElementById("sucursalId");
        const payload = {
          solicitanteNombre: v("solicitanteNombre"),
          solicitanteEmail: v("solicitanteEmail"),
          solicitanteTelefono: v("solicitanteTelefono") || null,
          asunto: v("asunto"),
          descripcion: v("descripcion"),
          prioridad: v("prioridad"),
          ubicacion: v("ubicacion") || null,
          sucursalId: sucEl?.value ? Number(sucEl.value) : null,
        };
        const res = await fetch("/api/tickets/publico", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          err.textContent = "No pudimos enviar tu solicitud. Verifica los campos e intenta de nuevo.";
          err.classList.remove("hidden");
          return;
        }
        const j = await res.json();
        const slaH = { urgente: 2, alta: 8, media: 24, baja: 72 }[payload.prioridad] || 24;
        document.getElementById("formBox").classList.add("hidden");
        document.getElementById("trackToken").textContent = j.ticket.trackingToken;
        document.getElementById("slaInfo").textContent = `${slaH} horas`;
        document.getElementById("successBox").classList.remove("hidden");
      });
    </script>
  </body>
</html>
