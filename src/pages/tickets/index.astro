---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { tickets, usuarios, sucursales, activos } from "@/lib/schema";
import { desc, eq } from "drizzle-orm";
import { ESTADO_TICKET_LABEL, ESTADO_TICKET_COLOR, slaStatus, type EstadoTicket } from "@/lib/tickets";
import { PRIO_COLOR } from "@/lib/ordenes";
import { tipoActivoFiltro } from "@/lib/especialidad";
export const prerender = false;

const user = Astro.locals.user!;
const db = getDb(Astro);

const url = new URL(Astro.request.url);
const filtroEstado = url.searchParams.get("estado");
const filtroVista = url.searchParams.get("vista"); // "mios" | null
const verCerrados = url.searchParams.get("verCerrados") === "1";

// Filtro por especialidad (jefe/tecnico)
const aplicaFiltroEsp = (user.rol === "jefe" || user.rol === "tecnico");
const filtroEspecialidad = aplicaFiltroEsp ? tipoActivoFiltro(user.especialidad ?? null) : null;
const esTecnico = user.rol === "tecnico";

const rowsRaw = await db
  .select({ t: tickets, a: usuarios, s: sucursales, act: activos })
  .from(tickets)
  .leftJoin(usuarios, eq(usuarios.id, tickets.asignadoA))
  .leftJoin(sucursales, eq(sucursales.id, tickets.sucursalId))
  .leftJoin(activos, eq(activos.id, tickets.activoId))
  .orderBy(desc(tickets.id));

// Estados activos: los que se muestran por defecto (vista limpia).
// Resueltos, cerrados y descartados se ocultan salvo toggle "Ver cerrados".
const ESTADOS_ACTIVOS = new Set<EstadoTicket>(["nuevo", "asignado", "en_proceso"]);

// Filtro por especialidad: usa tipoMantenimiento del ticket directamente.
// Si el ticket no tiene tipoMantenimiento (legacy), cae al tipo del activo.
// Si tampoco hay activo, se asume "general" → visible para techs general.
// Tickets asignados al usuario actual SIEMPRE se muestran.
const rows = rowsRaw.filter((r) => {
  const asignadoAMi = r.t.asignadoA === user.id;
  if (filtroVista === "mios" && !asignadoAMi) return false;
  if (filtroEstado && r.t.estado !== filtroEstado) return false;
  // Por defecto solo mostrar activos
  if (!filtroEstado && !verCerrados && !ESTADOS_ACTIVOS.has(r.t.estado as EstadoTicket)) return false;
  if (filtroEspecialidad && !asignadoAMi) {
    const tipoTicket = (r.t as any).tipoMantenimiento ?? r.act?.tipo ?? "general";
    if (tipoTicket !== filtroEspecialidad) return false;
  }
  return true;
});

const conteoMios = rowsRaw.filter((r) => r.t.asignadoA === user.id).length;
const conteoActivos = rowsRaw.filter((r) => ESTADOS_ACTIVOS.has(r.t.estado as EstadoTicket)).length;
const conteoNuevoSinAsignar = rowsRaw.filter((r) => r.t.estado === "nuevo" && !r.t.asignadoA).length;
const conteoAsignados = rowsRaw.filter((r) => r.t.estado === "asignado").length;
const conteoEnProcesoTk = rowsRaw.filter((r) => r.t.estado === "en_proceso").length;
const conteoCerrados = rowsRaw.length - conteoActivos;

const conteo = rowsRaw.reduce<Record<string, number>>((acc, r) => {
  acc[r.t.estado] = (acc[r.t.estado] ?? 0) + 1;
  return acc;
}, {});

const fmt = (s: string | null) => (s ? new Date(s).toLocaleString("es", { timeZone: "America/El_Salvador" }) : "-");
const ESTADOS: EstadoTicket[] = ["nuevo", "asignado", "en_proceso", "resuelto", "cerrado", "descartado"];
const esAdmin = user.rol === "admin";
---

<Layout title="Tickets de soporte">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold">Tickets de soporte</h1>
      <p class="text-sm text-slate-500">{rowsRaw.length} totales · mostrando {rows.length}</p>
    </div>
    <div class="flex gap-2">
      {esAdmin && (
        <button id="bulkDelBtn" class="hidden text-sm px-3 py-1.5 rounded-lg bg-red-600 text-white hover:bg-red-700">
          🗑 Eliminar seleccionados (<span id="selCount">0</span>)
        </button>
      )}
      <a href="/soporte" target="_blank" class="btn-secondary">Ver formulario público ↗</a>
    </div>
  </div>

  <!-- Toggle vista mios / todos -->
  <div class="mt-4 flex gap-1 text-xs">
    <a href={`/tickets${filtroEstado ? `?estado=${filtroEstado}` : ""}${verCerrados ? (filtroEstado ? "&" : "?") + "verCerrados=1" : ""}`}
       class:list={["rounded-md px-3 py-1.5 font-medium", filtroVista !== "mios" ? "bg-brand-600 text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200"]}>
      Todos
    </a>
    {esTecnico && (
      <a href={`/tickets?vista=mios${filtroEstado ? `&estado=${filtroEstado}` : ""}${verCerrados ? "&verCerrados=1" : ""}`}
         class:list={["rounded-md px-3 py-1.5 font-medium", filtroVista === "mios" ? "bg-emerald-600 text-white" : "bg-emerald-100 text-emerald-700 hover:bg-emerald-200"]}>
        👤 Asignados a mí ({conteoMios})
      </a>
    )}
  </div>

  <!-- Filtros rapidos por estado -->
  <div class="mt-3 flex flex-wrap gap-1.5 text-xs">
    <a href={`/tickets${filtroVista ? `?vista=${filtroVista}` : ""}`}
       class:list={["rounded-md px-2 py-1 font-medium", !filtroEstado && !verCerrados ? "bg-slate-700 text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200"]}>
      ⚡ Activos ({conteoActivos})
    </a>
    <span class="text-slate-300">·</span>
    <a href={`/tickets?estado=nuevo${filtroVista ? `&vista=${filtroVista}` : ""}`}
       class:list={["rounded-md px-2 py-1 font-medium", filtroEstado === "nuevo" ? "bg-blue-600 text-white" : "bg-blue-50 text-blue-700 hover:bg-blue-100 border border-blue-200"]}>
      🔵 Nuevos ({conteo.nuevo ?? 0})
    </a>
    <a href={`/tickets?estado=asignado${filtroVista ? `&vista=${filtroVista}` : ""}`}
       class:list={["rounded-md px-2 py-1 font-medium", filtroEstado === "asignado" ? "bg-indigo-600 text-white" : "bg-indigo-50 text-indigo-700 hover:bg-indigo-100 border border-indigo-200"]}>
      🟦 Asignados ({conteoAsignados})
    </a>
    <a href={`/tickets?estado=en_proceso${filtroVista ? `&vista=${filtroVista}` : ""}`}
       class:list={["rounded-md px-2 py-1 font-medium", filtroEstado === "en_proceso" ? "bg-emerald-600 text-white" : "bg-emerald-50 text-emerald-700 hover:bg-emerald-100 border border-emerald-200"]}>
      🟢 En progreso ({conteoEnProcesoTk})
    </a>
    {conteoNuevoSinAsignar > 0 && (
      <a href={`/tickets?estado=nuevo${filtroVista ? `&vista=${filtroVista}` : ""}`}
         class:list={["rounded-md px-2 py-1 font-medium bg-red-50 text-red-700 hover:bg-red-100 border border-red-200"]}
         title="Tickets nuevos sin técnico asignado">
        🔴 Sin asignar ({conteoNuevoSinAsignar})
      </a>
    )}
    <span class="text-slate-300">·</span>
    {(["resuelto", "cerrado", "descartado"] as EstadoTicket[]).map((s) => (
      <a href={`/tickets?estado=${s}${filtroVista ? `&vista=${filtroVista}` : ""}`}
         class:list={["rounded-md px-2 py-1 font-medium", filtroEstado === s ? `${ESTADO_TICKET_COLOR[s]} ring-2 ring-offset-1` : "bg-slate-100 text-slate-500 hover:bg-slate-200"]}>
        {ESTADO_TICKET_LABEL[s]} ({conteo[s] ?? 0})
      </a>
    ))}
    {!filtroEstado && (
      <a href={`/tickets?verCerrados=1${filtroVista ? `&vista=${filtroVista}` : ""}`}
         class:list={["rounded-md px-2 py-1 font-medium ml-auto", verCerrados ? "bg-slate-200 text-slate-700" : "bg-slate-100 text-slate-500 hover:bg-slate-200"]}>
        {verCerrados ? "🗂 Mostrando todos" : "🗂 Ver cerrados (" + conteoCerrados + ")"}
      </a>
    )}
  </div>

  <!-- Vista de tarjetas (móvil) -->
  <div class="mt-4 grid grid-cols-1 gap-3 sm:hidden">
    {rows.length === 0 && <div class="card p-6 text-center text-slate-400">Sin tickets.</div>}
    {rows.map((r) => {
      const sla = slaStatus(r.t.vencimientoSla, r.t.estado as EstadoTicket);
      const asignadoAMi = r.t.asignadoA === user.id;
      const e = r.t.estado as EstadoTicket;
      const cardColor =
        e === "nuevo" && !r.t.asignadoA ? "border-l-4 border-red-500" :
        e === "nuevo" ? "border-l-4 border-blue-500" :
        e === "asignado" ? "border-l-4 border-indigo-500" :
        e === "en_proceso" ? "border-l-4 border-emerald-500" :
        "border-l-4 border-transparent";
      return (
        <a href={`/tickets/${r.t.id}`} class:list={["card block p-4 hover:bg-slate-50 active:bg-slate-100 no-underline", cardColor]}>
          <div class="flex items-start justify-between gap-2">
            <div class="font-mono text-xs text-slate-400">
              {asignadoAMi && <span title="Asignado a ti" class="mr-1">👤</span>}
              #{r.t.id}
            </div>
            <span class={`badge ${PRIO_COLOR[r.t.prioridad]} capitalize text-[10px]`}>{r.t.prioridad}</span>
          </div>
          <div class="mt-1 text-base font-semibold text-slate-900">{r.t.asunto}</div>
          <div class="mt-2 grid grid-cols-2 gap-x-3 gap-y-1 text-xs">
            <div>
              <span class="text-slate-400 block">📍 Sucursal</span>
              <span class="text-slate-700 font-medium">{r.s?.nombre ?? "—"}</span>
            </div>
            <div>
              <span class="text-slate-400 block">👤 Asignado</span>
              <span class="text-slate-700 font-medium">{r.a?.nombre ?? <span class="text-red-600">Sin asignar</span>}</span>
            </div>
            <div>
              <span class="text-slate-400 block">Solicitante</span>
              <span class="text-slate-600 truncate block">{r.t.solicitanteNombre}</span>
            </div>
            <div>
              <span class="text-slate-400 block">SLA</span>
              {sla === "vencido" && <span class="text-red-600 font-medium">⚠ Vencido</span>}
              {sla === "warning" && <span class="text-amber-600 font-medium">Por vencer</span>}
              {sla === "ok" && <span class="text-slate-600">{fmt(r.t.vencimientoSla)}</span>}
              {sla === "n/a" && <span class="text-slate-400">—</span>}
            </div>
          </div>
          <div class="mt-2 flex items-center gap-1.5">
            <span class={`badge ${ESTADO_TICKET_COLOR[r.t.estado as EstadoTicket]} text-[10px]`}>{ESTADO_TICKET_LABEL[r.t.estado as EstadoTicket]}</span>
            {e === "nuevo" && !r.t.asignadoA && (
              <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-red-100 text-red-700 font-medium">Sin asignar</span>
            )}
          </div>
        </a>
      );
    })}
  </div>

  <!-- Vista de tabla (desktop) -->
  <div class="card mt-4 hidden sm:block overflow-hidden">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          {esAdmin && <th class="px-3 py-2 w-8"><input type="checkbox" id="selAll" class="cursor-pointer" /></th>}
          <th class="px-4 py-2">#</th>
          <th class="px-4 py-2">Asunto</th>
          <th class="px-4 py-2">Solicitante</th>
          <th class="px-4 py-2">Sucursal</th>
          <th class="px-4 py-2">Prioridad</th>
          <th class="px-4 py-2">Estado</th>
          <th class="px-4 py-2">SLA</th>
          <th class="px-4 py-2">Asignado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && <tr><td colspan={esAdmin ? 9 : 8} class="px-4 py-6 text-center text-slate-400">Sin tickets.</td></tr>}
        {rows.map((r) => {
          const sla = slaStatus(r.t.vencimientoSla, r.t.estado as EstadoTicket);
          const asignadoAMi = r.t.asignadoA === user.id;
          const e = r.t.estado as EstadoTicket;
          const filaColor =
            e === "nuevo" && !r.t.asignadoA ? "border-l-4 border-red-500 bg-red-50" :
            e === "nuevo" ? "border-l-4 border-blue-500 bg-blue-50" :
            e === "asignado" ? "border-l-4 border-indigo-500 bg-indigo-50" :
            e === "en_proceso" ? "border-l-4 border-emerald-500 bg-emerald-50" :
            "border-l-4 border-transparent";
          const subestadoBadge =
            e === "nuevo" && !r.t.asignadoA
              ? <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-red-100 text-red-700 font-medium">Sin asignar</span>
              : null;
          return (
            <tr class:list={["hover:brightness-95", filaColor]}>
              {esAdmin && <td class="px-3 py-2"><input type="checkbox" class="tk-cb cursor-pointer" data-id={r.t.id} /></td>}
              <td class="px-4 py-2 font-mono text-xs">
                {asignadoAMi && <span title="Asignado a ti" class="mr-1">👤</span>}
                #{r.t.id}
              </td>
              <td class="px-4 py-2">
                <a class="font-medium text-slate-900 hover:underline" href={`/tickets/${r.t.id}`}>{r.t.asunto}</a>
                {subestadoBadge && <span class="ml-2">{subestadoBadge}</span>}
                <div class="text-xs text-slate-500 truncate max-w-md">{r.t.descripcion}</div>
              </td>
              <td class="px-4 py-2 text-xs">
                <div>{r.t.solicitanteNombre}</div>
                <div class="text-slate-500">{r.t.solicitanteEmail}</div>
              </td>
              <td class="px-4 py-2 text-slate-600">{r.s?.nombre ?? "—"}</td>
              <td class="px-4 py-2"><span class={`badge ${PRIO_COLOR[r.t.prioridad]} capitalize`}>{r.t.prioridad}</span></td>
              <td class="px-4 py-2"><span class={`badge ${ESTADO_TICKET_COLOR[r.t.estado as EstadoTicket]}`}>{ESTADO_TICKET_LABEL[r.t.estado as EstadoTicket]}</span></td>
              <td class="px-4 py-2 text-xs">
                {sla === "vencido" && <span class="font-medium text-red-600">⚠ Vencido</span>}
                {sla === "warning" && <span class="font-medium text-amber-600">Por vencer</span>}
                {sla === "ok" && <span class="text-slate-500">{fmt(r.t.vencimientoSla)}</span>}
                {sla === "n/a" && <span class="text-slate-400">—</span>}
              </td>
              <td class="px-4 py-2 text-slate-600">{r.a?.nombre ?? "—"}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  {esAdmin && (
    <script>
      const cbs = document.querySelectorAll<HTMLInputElement>(".tk-cb");
      const selAll = document.getElementById("selAll") as HTMLInputElement | null;
      const bulkBtn = document.getElementById("bulkDelBtn");
      const countEl = document.getElementById("selCount");

      function refresh() {
        const sel = Array.from(cbs).filter((cb) => cb.checked);
        if (countEl) countEl.textContent = String(sel.length);
        if (bulkBtn) bulkBtn.classList.toggle("hidden", sel.length === 0);
      }
      selAll?.addEventListener("change", () => { cbs.forEach((cb) => (cb.checked = selAll.checked)); refresh(); });
      cbs.forEach((cb) => cb.addEventListener("change", refresh));

      bulkBtn?.addEventListener("click", async () => {
        const ids = Array.from(cbs).filter((cb) => cb.checked).map((cb) => Number(cb.dataset.id));
        if (!ids.length) return;
        const txt = ids.length === 1 ? "este ticket" : `estos ${ids.length} tickets`;
        if (!confirm(`¿Eliminar ${txt}? Esta acción NO se puede deshacer.`)) return;
        if (ids.length > 5 && !confirm(`Vas a borrar ${ids.length} tickets. ¿Confirmas?`)) return;
        bulkBtn.setAttribute("disabled", "true");
        bulkBtn.textContent = "Borrando...";
        const res = await fetch("/api/tickets/bulk-delete", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ ids }),
        });
        const j = await res.json().catch(() => ({}));
        if (res.ok) {
          alert(`✓ ${j.borrados} ticket(s) eliminados`);
          location.reload();
        } else {
          alert("✗ Error: " + (j.error ?? "desconocido"));
          bulkBtn.removeAttribute("disabled");
        }
      });
    </script>
  )}
</Layout>
