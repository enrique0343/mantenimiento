---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { ordenes, activos, usuarios } from "@/lib/schema";
import { desc, eq } from "drizzle-orm";
export const prerender = false;

const db = getDb(Astro);
const rows = await db
  .select({ orden: ordenes, activo: activos, asignado: usuarios })
  .from(ordenes)
  .leftJoin(activos, eq(activos.id, ordenes.activoId))
  .leftJoin(usuarios, eq(usuarios.id, ordenes.asignadoA))
  .orderBy(desc(ordenes.id));

const estadoColor: Record<string, string> = {
  abierta: "bg-blue-100 text-blue-700",
  en_proceso: "bg-amber-100 text-amber-700",
  completada: "bg-emerald-100 text-emerald-700",
  cancelada: "bg-slate-200 text-slate-600",
};
const prioColor: Record<string, string> = {
  baja: "bg-slate-100 text-slate-600",
  media: "bg-blue-100 text-blue-700",
  alta: "bg-orange-100 text-orange-700",
  urgente: "bg-red-100 text-red-700",
};
---

<Layout title="Ordenes de trabajo">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">Ordenes de trabajo</h1>
      <p class="text-sm text-slate-500">{rows.length} en total</p>
    </div>
    <a href="/ordenes/nueva" class="btn-primary">+ Nueva orden</a>
  </div>

  <div class="card mt-4 overflow-hidden">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          <th class="px-4 py-2">#</th>
          <th class="px-4 py-2">Titulo</th>
          <th class="px-4 py-2">Activo</th>
          <th class="px-4 py-2">Tipo</th>
          <th class="px-4 py-2">Prioridad</th>
          <th class="px-4 py-2">Estado</th>
          <th class="px-4 py-2">Asignado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && (
          <tr><td colspan="7" class="px-4 py-6 text-center text-slate-500">Aun no hay ordenes.</td></tr>
        )}
        {rows.map((r) => (
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2 font-mono text-xs">#{r.orden.id}</td>
            <td class="px-4 py-2">
              <a class="font-medium text-brand-700 hover:underline" href={`/ordenes/${r.orden.id}`}>{r.orden.titulo}</a>
            </td>
            <td class="px-4 py-2 text-slate-600">{r.activo?.codigo ?? "-"}</td>
            <td class="px-4 py-2 capitalize">{r.orden.tipo}</td>
            <td class="px-4 py-2"><span class={`badge ${prioColor[r.orden.prioridad]}`}>{r.orden.prioridad}</span></td>
            <td class="px-4 py-2"><span class={`badge ${estadoColor[r.orden.estado]}`}>{r.orden.estado.replace("_"," ")}</span></td>
            <td class="px-4 py-2 text-slate-600">{r.asignado?.nombre ?? "-"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>
