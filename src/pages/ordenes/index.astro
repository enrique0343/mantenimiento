---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { ordenes, activos, usuarios, vehiculos, actividades } from "@/lib/schema";
import { desc, inArray } from "drizzle-orm";
import { ESTADO_LABEL, ESTADO_COLOR, TIPO_COLOR, PRIO_COLOR, type EstadoOT } from "@/lib/ordenes";
import { tipoActivoFiltro } from "@/lib/especialidad";
export const prerender = false;

const usrLogged = Astro.locals.user!;
const db = getDb(Astro);
const url = new URL(Astro.request.url);
const filtroEstado = url.searchParams.get("estado");
const filtroTipo = url.searchParams.get("tipo");
const filtroVista = url.searchParams.get("vista"); // "mias" | null

// Filtro por especialidad (jefe/tecnico): solo OTs cuyo activo coincide
const aplicaFiltroEsp = (usrLogged.rol === "jefe" || usrLogged.rol === "tecnico");
const filtroEspecialidad = aplicaFiltroEsp ? tipoActivoFiltro(usrLogged.especialidad ?? null) : null;
const esTecnico = usrLogged.rol === "tecnico";

let errorMsg: string | null = null;
let rowsRaw: any[] = [];

try {
  // Query simple sin joins para evitar problemas de schema
  const ots = await db.select().from(ordenes).orderBy(desc(ordenes.id)).limit(500);

  // Cargo entidades relacionadas en queries separados (en lote)
  const activoIds = Array.from(new Set(ots.map((o) => o.activoId).filter((x): x is number => !!x)));
  const vehiculoIds = Array.from(new Set(ots.map((o: any) => o.vehiculoId).filter((x: any): x is number => !!x)));
  const actividadIds = Array.from(new Set(ots.map((o: any) => o.actividadId).filter((x: any): x is number => !!x)));
  const userIds = Array.from(new Set(ots.map((o) => o.asignadoA).filter((x): x is number => !!x)));

  const actMap = new Map<number, any>();
  if (activoIds.length > 0) {
    const ws = await db.select().from(activos).where(inArray(activos.id, activoIds));
    for (const a of ws) actMap.set(a.id, a);
  }
  const vehMap = new Map<number, any>();
  if (vehiculoIds.length > 0) {
    const ws = await db.select().from(vehiculos).where(inArray(vehiculos.id, vehiculoIds));
    for (const v of ws) vehMap.set(v.id, v);
  }
  const actiMap = new Map<number, any>();
  if (actividadIds.length > 0) {
    const ws = await db.select().from(actividades).where(inArray(actividades.id, actividadIds));
    for (const a of ws) actiMap.set(a.id, a);
  }
  const userMap = new Map<number, any>();
  if (userIds.length > 0) {
    const ws = await db.select().from(usuarios).where(inArray(usuarios.id, userIds));
    for (const u of ws) userMap.set(u.id, u);
  }

  rowsRaw = ots.map((o: any) => ({
    orden: o,
    activo: o.activoId ? actMap.get(o.activoId) ?? null : null,
    vehiculo: o.vehiculoId ? vehMap.get(o.vehiculoId) ?? null : null,
    actividad: o.actividadId ? actiMap.get(o.actividadId) ?? null : null,
    asignado: o.asignadoA ? userMap.get(o.asignadoA) ?? null : null,
  }));
} catch (e: any) {
  errorMsg = String(e?.message ?? e);
}

// Filtro por especialidad: OTs cuyo activo coincide, OR OTs sin activo
// (no excluimos las "sin equipo" — son trabajos generales que también aplican).
// OTs asignadas al usuario actual SIEMPRE se muestran (override del filtro).
const rows = rowsRaw.filter((r) => {
  const asignadaAMi = r.orden.asignadoA === usrLogged.id;
  if (filtroVista === "mias" && !asignadaAMi) return false;
  if (filtroEstado && r.orden.estado !== filtroEstado) return false;
  if (filtroTipo && r.orden.tipo !== filtroTipo) return false;
  if (filtroEspecialidad && !asignadaAMi) {
    // Sin activo: visible para todos (trabajos generales)
    if (r.activo && r.activo.tipo !== filtroEspecialidad) return false;
  }
  return true;
});

const conteoMias = rowsRaw.filter((r) => r.orden.asignadoA === usrLogged.id).length;

const conteoEstados = rowsRaw.reduce<Record<string, number>>((acc, r) => {
  acc[r.orden.estado] = (acc[r.orden.estado] ?? 0) + 1;
  return acc;
}, {});

const esAdmin = usrLogged.rol === "admin";
---

<Layout title="Órdenes de trabajo">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold">Órdenes de trabajo</h1>
      <p class="text-sm text-slate-500">{rowsRaw.length} en total · mostrando {rows.length}</p>
    </div>
    <div class="flex gap-2">
      {esAdmin && (
        <button id="bulkDelBtn" class="hidden text-sm px-3 py-1.5 rounded-lg bg-red-600 text-white hover:bg-red-700">
          🗑 Eliminar seleccionadas (<span id="selCount">0</span>)
        </button>
      )}
      <a href="/ordenes/nueva" class="btn-primary">+ Nueva orden</a>
    </div>
  </div>

  {errorMsg && (
    <div class="card mt-4 border-l-4 border-red-500 p-4">
      <h2 class="font-semibold text-red-700">Error al cargar órdenes</h2>
      <pre class="mt-2 whitespace-pre-wrap text-xs text-red-600">{errorMsg}</pre>
    </div>
  )}

  <!-- Toggle vista -->
  <div class="mt-4 flex gap-1 text-xs">
    <a href={`/ordenes${filtroEstado ? `?estado=${filtroEstado}` : ""}`}
       class:list={["rounded-md px-3 py-1.5 font-medium", filtroVista !== "mias" ? "bg-brand-600 text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200"]}>
      Todas ({rowsRaw.length})
    </a>
    {esTecnico && (
      <a href={`/ordenes?vista=mias${filtroEstado ? `&estado=${filtroEstado}` : ""}`}
         class:list={["rounded-md px-3 py-1.5 font-medium", filtroVista === "mias" ? "bg-emerald-600 text-white" : "bg-emerald-100 text-emerald-700 hover:bg-emerald-200"]}>
        👤 Asignadas a mí ({conteoMias})
      </a>
    )}
  </div>

  <!-- Filtros rapidos por estado -->
  <div class="mt-3 flex flex-wrap gap-1 text-xs">
    <a href={`/ordenes${filtroVista ? `?vista=${filtroVista}` : ""}`}
       class:list={["rounded-md px-2 py-1 font-medium", !filtroEstado ? "bg-brand-50 text-brand-700 border border-brand-200" : "bg-slate-100 text-slate-700 hover:bg-slate-200"]}>
      Todos los estados
    </a>
    {(["abierta", "en_proceso", "en_espera", "completada", "verificada", "cerrada", "cancelada"] as EstadoOT[]).map((s) => (
      <a href={`/ordenes?estado=${s}${filtroVista ? `&vista=${filtroVista}` : ""}`}
         class:list={["rounded-md px-2 py-1 font-medium", filtroEstado === s ? `${ESTADO_COLOR[s]} ring-2 ring-offset-1` : "bg-slate-100 text-slate-700 hover:bg-slate-200"]}>
        {ESTADO_LABEL[s]} ({conteoEstados[s] ?? 0})
      </a>
    ))}
  </div>

  <div class="card mt-4 overflow-hidden">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          {esAdmin && <th class="px-3 py-2 w-8"><input type="checkbox" id="selAll" class="cursor-pointer" /></th>}
          <th class="px-4 py-2">#</th>
          <th class="px-4 py-2">Título</th>
          <th class="px-4 py-2">Equipo / Vehículo / Actividad</th>
          <th class="px-4 py-2">Tipo</th>
          <th class="px-4 py-2">Prioridad</th>
          <th class="px-4 py-2">Estado</th>
          <th class="px-4 py-2">Asignado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && !errorMsg && (
          <tr><td colspan={esAdmin ? 8 : 7} class="px-4 py-6 text-center text-slate-500">Sin órdenes con esos filtros.</td></tr>
        )}
        {rows.map((r) => {
          const e = (r.orden.estado ?? "abierta") as EstadoOT;
          const tipo = (r.orden.tipo ?? "correctivo") as keyof typeof TIPO_COLOR;
          const prio = (r.orden.prioridad ?? "media") as keyof typeof PRIO_COLOR;
          const asignadaAMi = r.orden.asignadoA === usrLogged.id;
          return (
            <tr class:list={["hover:bg-slate-50", asignadaAMi && "bg-emerald-50/50"]}>
              {esAdmin && <td class="px-3 py-2"><input type="checkbox" class="ot-cb cursor-pointer" data-id={r.orden.id} /></td>}
              <td class="px-4 py-2 font-mono text-xs">
                {asignadaAMi && <span title="Asignada a ti" class="mr-1">👤</span>}
                #{r.orden.id}
              </td>
              <td class="px-4 py-2">
                <a class="font-medium text-brand-700 hover:underline" href={`/ordenes/${r.orden.id}`}>{r.orden.titulo}</a>
              </td>
              <td class="px-4 py-2 text-slate-600 text-xs">
                {r.activo && <span>🛠 {r.activo.codigo}</span>}
                {r.vehiculo && <span>🚗 {r.vehiculo.placa}</span>}
                {r.actividad && <span>📋 {r.actividad.codigo}</span>}
                {!r.activo && !r.vehiculo && !r.actividad && <span class="text-slate-400">— sin asociar —</span>}
              </td>
              <td class="px-4 py-2">
                <span class={`badge ${TIPO_COLOR[tipo] ?? "bg-slate-100 text-slate-600"} capitalize`}>{r.orden.tipo}</span>
              </td>
              <td class="px-4 py-2"><span class={`badge ${PRIO_COLOR[prio] ?? "bg-slate-100 text-slate-600"} capitalize`}>{r.orden.prioridad}</span></td>
              <td class="px-4 py-2"><span class={`badge ${ESTADO_COLOR[e] ?? "bg-slate-100 text-slate-600"}`}>{ESTADO_LABEL[e] ?? r.orden.estado}</span></td>
              <td class="px-4 py-2 text-slate-600">{r.asignado?.nombre ?? "—"}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  {esAdmin && (
    <script>
      const cbs = document.querySelectorAll<HTMLInputElement>(".ot-cb");
      const selAll = document.getElementById("selAll") as HTMLInputElement | null;
      const bulkBtn = document.getElementById("bulkDelBtn");
      const countEl = document.getElementById("selCount");

      function refresh() {
        const sel = Array.from(cbs).filter((cb) => cb.checked);
        if (countEl) countEl.textContent = String(sel.length);
        if (bulkBtn) bulkBtn.classList.toggle("hidden", sel.length === 0);
      }

      selAll?.addEventListener("change", () => {
        cbs.forEach((cb) => (cb.checked = selAll.checked));
        refresh();
      });
      cbs.forEach((cb) => cb.addEventListener("change", refresh));

      bulkBtn?.addEventListener("click", async () => {
        const ids = Array.from(cbs).filter((cb) => cb.checked).map((cb) => Number(cb.dataset.id));
        if (!ids.length) return;
        const txt = ids.length === 1 ? "esta OT" : `estas ${ids.length} OTs`;
        if (!confirm(`¿Eliminar ${txt}? Esta acción NO se puede deshacer. Se borrarán todos sus comentarios, adjuntos y firmas.`)) return;
        if (ids.length > 5 && !confirm(`Vas a borrar ${ids.length} OTs. ¿Confirmas?`)) return;

        bulkBtn.setAttribute("disabled", "true");
        bulkBtn.textContent = "Borrando...";
        const res = await fetch("/api/ordenes/bulk-delete", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ ids }),
        });
        const j = await res.json().catch(() => ({}));
        if (res.ok) {
          alert(`✓ ${j.borradas} OT(s) eliminadas correctamente`);
          location.reload();
        } else {
          alert("✗ Error: " + (j.error ?? "desconocido"));
          bulkBtn.removeAttribute("disabled");
        }
      });
    </script>
  )}
</Layout>
