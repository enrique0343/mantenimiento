---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { activos, usuarios } from "@/lib/schema";
import { asc, eq, and, inArray } from "drizzle-orm";
export const prerender = false;

const db = getDb(Astro);
const activosList = await db.select().from(activos).orderBy(asc(activos.codigo));
const tecnicos = await db
  .select({ id: usuarios.id, nombre: usuarios.nombre, rol: usuarios.rol })
  .from(usuarios)
  .where(and(eq(usuarios.activo, true), inArray(usuarios.rol, ["tecnico", "jefe", "proveedor"])))
  .orderBy(asc(usuarios.nombre));
---

<Layout title="Nueva orden">
  <a href="/ordenes" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>
  <h1 class="mt-2 text-2xl font-bold">Nueva orden de trabajo</h1>

  <form id="form" class="card mt-4 space-y-4 p-5">
    <div>
      <label class="label">Título *</label>
      <input class="input" id="titulo" required placeholder="Ej: Cambio de filtro AC sala 3" />
    </div>
    <div>
      <label class="label">Descripción</label>
      <textarea class="input" id="descripcion" rows="3" placeholder="Detalles del trabajo..."></textarea>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div>
        <label class="label">Tipo</label>
        <select class="input" id="tipo">
          <option value="correctivo">🔧 Correctivo</option>
          <option value="preventivo">🛡️ Preventivo</option>
          <option value="predictivo">📊 Predictivo</option>
        </select>
      </div>
      <div>
        <label class="label">Prioridad</label>
        <select class="input" id="prioridad">
          <option value="baja">Baja</option>
          <option value="media" selected>Media</option>
          <option value="alta">Alta</option>
          <option value="urgente">Urgente</option>
        </select>
      </div>
      <div>
        <label class="label">Vencimiento</label>
        <input class="input" id="vencimiento" type="datetime-local" />
      </div>
    </div>

    <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
      <div class="flex items-center gap-3">
        <input type="checkbox" id="conEquipo" checked />
        <label for="conEquipo" class="text-sm font-medium text-slate-700">Asociar a un equipo</label>
        <span class="text-xs text-slate-500">(desmarca para trabajos generales: limpieza, instalación, etc.)</span>
      </div>
      <div id="equipoBox" class="mt-3">
        <label class="label">Equipo</label>
        <select class="input" id="activoId">
          <option value="">— Selecciona un equipo —</option>
          {activosList.map((a) => <option value={a.id}>{a.codigo} - {a.nombre}</option>)}
        </select>
      </div>
    </div>

    <div>
      <label class="label">Asignar a</label>
      <select class="input" id="asignadoA">
        <option value="">— Sin asignar —</option>
        {tecnicos.map((t) => <option value={t.id}>{t.nombre} ({t.rol})</option>)}
      </select>
    </div>

    <!-- Checklist inicial opcional -->
    <details class="rounded-lg border border-slate-200 bg-white p-3">
      <summary class="cursor-pointer text-sm font-medium text-slate-700">+ Agregar checklist inicial (opcional)</summary>
      <p class="mt-2 text-xs text-slate-500">Una línea por item. El técnico podrá marcarlas durante la ejecución.</p>
      <textarea id="checklistRaw" class="input mt-2" rows="4" placeholder="Limpiar filtros&#10;Verificar tensión de bandas&#10;Revisar nivel de aceite"></textarea>
    </details>

    <p id="err" class="hidden text-sm text-red-600"></p>
    <div class="flex gap-2">
      <button class="btn-primary" type="submit">Crear orden</button>
      <a class="btn-secondary" href="/ordenes">Cancelar</a>
    </div>
  </form>

  <script>
    const conEquipoCk = document.getElementById("conEquipo") as HTMLInputElement;
    const equipoBox = document.getElementById("equipoBox") as HTMLElement;
    const activoSel = document.getElementById("activoId") as HTMLSelectElement;
    conEquipoCk.addEventListener("change", () => {
      equipoBox.classList.toggle("hidden", !conEquipoCk.checked);
      if (!conEquipoCk.checked) activoSel.value = "";
    });

    const form = document.getElementById("form") as HTMLFormElement;
    const err = document.getElementById("err") as HTMLElement;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      err.classList.add("hidden");
      const v = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement).value;
      const venc = v("vencimiento");
      const activoId = v("activoId");
      const asignadoA = v("asignadoA");
      const checklistRaw = v("checklistRaw").trim();

      let checklistEjecucion: string | null = null;
      if (checklistRaw) {
        const items = checklistRaw.split("\n").map((l) => l.trim()).filter(Boolean).map((texto) => ({ texto, hecho: false }));
        if (items.length > 0) checklistEjecucion = JSON.stringify(items);
      }

      const payload: any = {
        titulo: v("titulo"),
        descripcion: v("descripcion") || null,
        tipo: v("tipo"),
        prioridad: v("prioridad"),
        activoId: activoId ? Number(activoId) : null,
        asignadoA: asignadoA ? Number(asignadoA) : null,
        vencimiento: venc ? new Date(venc).toISOString() : null,
        checklistEjecucion,
      };
      const res = await fetch("/api/ordenes", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        err.textContent = typeof j.error === "string" ? j.error : "Error al crear";
        err.classList.remove("hidden");
        return;
      }
      const j = await res.json();
      location.href = `/ordenes/${j.orden.id}`;
    });
  </script>
</Layout>
