---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { ordenes, activos, usuarios, comentarios, adjuntos } from "@/lib/schema";
import { eq } from "drizzle-orm";
export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect("/ordenes");

const db = getDb(Astro);
const [row] = await db
  .select({ orden: ordenes, activo: activos, asignado: usuarios })
  .from(ordenes)
  .leftJoin(activos, eq(activos.id, ordenes.activoId))
  .leftJoin(usuarios, eq(usuarios.id, ordenes.asignadoA))
  .where(eq(ordenes.id, id))
  .limit(1);

if (!row) return Astro.redirect("/ordenes");

const coms = await db
  .select({ c: comentarios, u: usuarios })
  .from(comentarios)
  .leftJoin(usuarios, eq(usuarios.id, comentarios.usuarioId))
  .where(eq(comentarios.ordenId, id))
  .orderBy(comentarios.id);

const adjs = await db.select().from(adjuntos).where(eq(adjuntos.ordenId, id));
const tecnicos = await db
  .select({ id: usuarios.id, nombre: usuarios.nombre })
  .from(usuarios)
  .where(eq(usuarios.activo, true));

const o = row.orden;
const fmt = (s: string | null) => (s ? new Date(s).toLocaleString("es") : "-");
---

<Layout title={`Orden #${o.id}`}>
  <a href="/ordenes" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>

  <div class="mt-2 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold">{o.titulo}</h1>
      <p class="text-sm text-slate-500">Orden #{o.id} - creada {fmt(o.createdAt)}</p>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
    <div class="card lg:col-span-2 p-5">
      <h2 class="font-semibold text-slate-900">Detalles</h2>
      <p class="mt-2 whitespace-pre-wrap text-sm text-slate-700">{o.descripcion || "Sin descripcion."}</p>

      <div class="mt-5 grid grid-cols-2 gap-3 text-sm">
        <div><div class="text-xs uppercase text-slate-500">Tipo</div><div class="capitalize">{o.tipo}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Prioridad</div><div class="capitalize">{o.prioridad}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Activo</div><div>{row.activo ? `${row.activo.codigo} - ${row.activo.nombre}` : "-"}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Vencimiento</div><div>{fmt(o.vencimiento)}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Completada en</div><div>{fmt(o.completadaEn)}</div></div>
      </div>
    </div>

    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Estado</h2>
      <div class="mt-3 space-y-3 text-sm">
        <div>
          <label class="label">Estado</label>
          <select class="input" id="estado">
            <option value="abierta" selected={o.estado === "abierta"}>Abierta</option>
            <option value="en_proceso" selected={o.estado === "en_proceso"}>En proceso</option>
            <option value="completada" selected={o.estado === "completada"}>Completada</option>
            <option value="cancelada" selected={o.estado === "cancelada"}>Cancelada</option>
          </select>
        </div>
        <div>
          <label class="label">Asignar a</label>
          <select class="input" id="asignadoA">
            <option value="">- Sin asignar -</option>
            {tecnicos.map((t) => <option value={t.id} selected={o.asignadoA === t.id}>{t.nombre}</option>)}
          </select>
        </div>
        <button id="saveBtn" class="btn-primary w-full justify-center">Guardar cambios</button>
        <p id="saveMsg" class="hidden text-sm"></p>
      </div>
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Comentarios</h2>
      <ul class="mt-3 space-y-3 text-sm">
        {coms.length === 0 && <li class="text-slate-500">Sin comentarios.</li>}
        {coms.map((r) => (
          <li class="rounded-md bg-slate-50 p-3">
            <div class="text-xs text-slate-500">{r.u?.nombre} - {fmt(r.c.createdAt)}</div>
            <div class="mt-1 whitespace-pre-wrap">{r.c.texto}</div>
          </li>
        ))}
      </ul>
      <form id="comForm" class="mt-3 space-y-2">
        <textarea id="comTexto" class="input" rows="2" placeholder="Agregar comentario..." required></textarea>
        <button class="btn-primary" type="submit">Comentar</button>
      </form>
    </div>

    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Adjuntos</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {adjs.length === 0 && <li class="text-slate-500">Sin adjuntos.</li>}
        {adjs.map((a) => (
          <li class="flex items-center justify-between rounded-md bg-slate-50 p-2">
            <a href={`/api/adjuntos/${a.id}`} target="_blank" class="text-brand-700 hover:underline">{a.nombre}</a>
            <span class="text-xs text-slate-500">{(a.tamano / 1024).toFixed(1)} KB</span>
          </li>
        ))}
      </ul>
      <form id="upForm" class="mt-3 space-y-2">
        <input id="upFile" type="file" class="block text-sm" required />
        <button class="btn-primary" type="submit">Subir archivo</button>
        <p id="upErr" class="hidden text-sm text-red-600"></p>
      </form>
    </div>
  </div>

  <script define:vars={{ id }}>
    const $ = (id) => document.getElementById(id);

    $("saveBtn").addEventListener("click", async () => {
      const msg = $("saveMsg");
      msg.classList.add("hidden");
      const payload = {
        estado: $("estado").value,
        asignadoA: $("asignadoA").value ? Number($("asignadoA").value) : null,
      };
      const res = await fetch(`/api/ordenes/${id}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        msg.textContent = "Error al guardar";
        msg.className = "text-sm text-red-600";
      } else {
        msg.textContent = "Guardado.";
        msg.className = "text-sm text-emerald-600";
        setTimeout(() => location.reload(), 600);
      }
      msg.classList.remove("hidden");
    });

    $("comForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const texto = $("comTexto").value.trim();
      if (!texto) return;
      const res = await fetch(`/api/ordenes/${id}/comentarios`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ texto }),
      });
      if (res.ok) location.reload();
    });

    $("upForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const err = $("upErr");
      err.classList.add("hidden");
      const file = $("upFile").files[0];
      if (!file) return;
      const fd = new FormData();
      fd.append("file", file);
      const res = await fetch(`/api/ordenes/${id}/adjuntos`, { method: "POST", body: fd });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        err.textContent = j.error || "Error al subir";
        err.classList.remove("hidden");
        return;
      }
      location.reload();
    });
  </script>
</Layout>
