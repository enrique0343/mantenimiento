---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { ordenes, activos, usuarios, comentarios, adjuntos, items as itemsTable, sucursales, ubicaciones, ordenRepuestos, stock, empresa, solicitudesCompra } from "@/lib/schema";
import { eq, desc, and, inArray, asc } from "drizzle-orm";
import {
  ESTADO_LABEL, ESTADO_COLOR, TIPO_COLOR, PRIO_COLOR,
  transicionesPermitidas, puedeAsignarse, puedeEditarEjecucion,
  parseChecklist, progresoChecklist,
  type EstadoOT,
} from "@/lib/ordenes";
import { fmtCantidad } from "@/lib/inventario";
export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect("/ordenes");

const user = Astro.locals.user!;
const db = getDb(Astro);

const [row] = await db
  .select({ orden: ordenes, activo: activos, asignado: usuarios, ubicacion: ubicaciones, sucursal: sucursales })
  .from(ordenes)
  .leftJoin(activos, eq(activos.id, ordenes.activoId))
  .leftJoin(usuarios, eq(usuarios.id, ordenes.asignadoA))
  .leftJoin(ubicaciones, eq(ubicaciones.id, activos.ubicacionId))
  .leftJoin(sucursales, eq(sucursales.id, ubicaciones.sucursalId))
  .where(eq(ordenes.id, id))
  .limit(1);

if (!row) return Astro.redirect("/ordenes");

const o = row.orden;
const estadoActual = o.estado as EstadoOT;
const esAsignado = o.asignadoA === user.id;

const [verifUsr] = o.verificadoPor
  ? await db.select({ id: usuarios.id, nombre: usuarios.nombre }).from(usuarios).where(eq(usuarios.id, o.verificadoPor)).limit(1)
  : [null];
const [cierraUsr] = o.cerradoPor
  ? await db.select({ id: usuarios.id, nombre: usuarios.nombre }).from(usuarios).where(eq(usuarios.id, o.cerradoPor)).limit(1)
  : [null];

const coms = await db
  .select({ c: comentarios, u: usuarios })
  .from(comentarios)
  .leftJoin(usuarios, eq(usuarios.id, comentarios.usuarioId))
  .where(eq(comentarios.ordenId, id))
  .orderBy(comentarios.id);

const adjs = await db.select().from(adjuntos).where(eq(adjuntos.ordenId, id));
const tecnicos = await db
  .select({ id: usuarios.id, nombre: usuarios.nombre, rol: usuarios.rol })
  .from(usuarios)
  .where(and(eq(usuarios.activo, true), inArray(usuarios.rol, ["tecnico", "jefe", "proveedor"])))
  .orderBy(asc(usuarios.nombre));

// Repuestos consumidos en esta OT (bodega única)
const repuestosRows = await db
  .select({ rep: ordenRepuestos, it: itemsTable })
  .from(ordenRepuestos)
  .leftJoin(itemsTable, eq(itemsTable.id, ordenRepuestos.itemId))
  .where(eq(ordenRepuestos.ordenId, id))
  .orderBy(desc(ordenRepuestos.id));

const totalRepuestos = repuestosRows.reduce(
  (s, r) => s + (r.rep.precioUnitario ?? 0) * r.rep.cantidad,
  0
);

// Costo: mano de obra (horas × tarifa del técnico asignado) + repuestos
const tarifaTecnico = Number((row.asignado as any)?.tarifaHora ?? 0);
const horasTrab = Number(o.horasTrabajadas ?? 0);
const costoManoObra = horasTrab * tarifaTecnico;
const costoTotal = costoManoObra + totalRepuestos;

// Para el formulario de agregar repuesto
const itemsActivos = await db
  .select({ id: itemsTable.id, codigo: itemsTable.codigo, nombre: itemsTable.nombre, unidad: itemsTable.unidad, precio: itemsTable.precioReferencia })
  .from(itemsTable)
  .where(eq(itemsTable.activo, true))
  .orderBy(itemsTable.nombre);

const itemsRepJson = JSON.stringify(itemsActivos);

// Selectores en cascada: sucursal → ubicación → equipo
const puedeAsignarActivo = ["admin", "jefe", "tecnico"].includes(user.rol);
const activosLista = puedeAsignarActivo
  ? await db
      .select({ id: activos.id, codigo: activos.codigo, nombre: activos.nombre, ubicacionId: activos.ubicacionId })
      .from(activos)
      .orderBy(asc(activos.codigo))
  : [];
const ubicacionesLista = puedeAsignarActivo
  ? await db
      .select({ id: ubicaciones.id, nombre: ubicaciones.nombre, tipo: ubicaciones.tipo, sucursalId: ubicaciones.sucursalId })
      .from(ubicaciones)
      .where(eq(ubicaciones.activa, true))
      .orderBy(asc(ubicaciones.nombre))
  : [];
const sucursalesLista = puedeAsignarActivo
  ? await db
      .select({ id: sucursales.id, nombre: sucursales.nombre })
      .from(sucursales)
      .where(eq(sucursales.activa, true))
      .orderBy(asc(sucursales.nombre))
  : [];

const checklistItems = parseChecklist(o.checklistEjecucion);
const progreso = progresoChecklist(checklistItems);

// Solicitudes de compra vinculadas a esta OT
const solicitudesVinculadas = await db
  .select({ id: solicitudesCompra.id, codigo: solicitudesCompra.codigo, titulo: solicitudesCompra.titulo, estado: solicitudesCompra.estado })
  .from(solicitudesCompra)
  .where(eq(solicitudesCompra.ordenId, id));
const puedeSolicitarCompra = (estadoActual === "en_proceso" || estadoActual === "en_espera") &&
  ["admin", "jefe", "tecnico"].includes(user.rol);
const verComprasSection = ["admin", "jefe", "tecnico"].includes(user.rol);

const proximas = transicionesPermitidas(estadoActual, user.rol, esAsignado);
const puedeEditar = puedeEditarEjecucion(user.rol, esAsignado, estadoActual);

// Las fotos "antes" SÍ se pueden subir desde el estado "abierta" (no requiere
// haber pulsado Iniciar). El flujo correcto es: verificar lugar → foto antes
// → Iniciar → trabajar → foto después. Bloqueadas solo en cerrada/cancelada.
const puedeSubirAntes =
  estadoActual !== "cerrada" && estadoActual !== "cancelada" &&
  (user.rol === "admin" || user.rol === "jefe" || (user.rol === "tecnico" && esAsignado));
const puedeAsignar = puedeAsignarse(user.rol);

const ESTADO_PROGRESO: Record<EstadoOT, number> = {
  abierta: 1, en_proceso: 2, en_espera: 2, completada: 3, verificada: 4, cerrada: 5, cancelada: 0,
};
const stepActual = ESTADO_PROGRESO[estadoActual];

const fmt = (s: string | null) => (s ? new Date(s).toLocaleString("es") : "-");
const fmtDate = (s: string | null) => (s ? new Date(s).toLocaleDateString("es") : "-");

const adjsAntes = adjs.filter((a) => a.categoria === "antes");
const adjsDespues = adjs.filter((a) => a.categoria === "despues");
const adjsDocumento = adjs.filter((a) => a.categoria === "documento");
const adjsGeneral = adjs.filter((a) => a.categoria === "general");
---

<Layout title={`Orden #${o.id}`}>
  <a href="/ordenes" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>

  <div class="mt-2 flex flex-wrap items-start justify-between gap-4">
    <div>
      <div class="flex flex-wrap items-center gap-2">
        <h1 class="text-2xl font-bold">{o.titulo}</h1>
        <span class={`badge ${TIPO_COLOR[o.tipo]} capitalize`}>{o.tipo}</span>
        <span class={`badge ${PRIO_COLOR[o.prioridad]} capitalize`}>{o.prioridad}</span>
        <span class={`badge ${ESTADO_COLOR[estadoActual]}`}>{ESTADO_LABEL[estadoActual]}</span>
      </div>
      <p class="mt-1 text-sm text-slate-500">Orden #{o.id} - creada {fmt(o.createdAt)}</p>
    </div>
    <div class="flex gap-2">
      {user.rol === "admin" && (
        <button id="historialBtn" type="button" class="btn-secondary text-sm">📜 Historial</button>
      )}
      {user.rol === "admin" && (
        <button id="deleteOtBtn" type="button" class="btn-secondary text-sm text-red-600 hover:bg-red-50">🗑 Eliminar OT</button>
      )}
    </div>
  </div>

  {user.rol === "admin" && (
    <div id="historialModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-3xl max-h-[90vh] overflow-y-auto">
        <div class="sticky top-0 bg-white border-b border-slate-200 px-5 py-3 flex items-center justify-between">
          <h2 class="font-bold text-lg">📜 Historial de la OT #{o.id}</h2>
          <button id="closeHistorial" class="text-slate-400 hover:text-slate-600 text-xl">×</button>
        </div>
        <div id="historialContent" class="p-5">
          <div class="text-center text-slate-400 py-6">Cargando...</div>
        </div>
      </div>
    </div>

    <script define:vars={{ otId: o.id }}>
      const ACCION_ICON = {
        create: "➕", update: "✏️", estado: "🔄", asignacion: "👤", delete: "🗑",
      };
      const ACCION_LABEL = {
        create: "Creación", update: "Edición", estado: "Cambio de estado",
        asignacion: "Asignación", delete: "Eliminación",
      };

      const historialBtn = document.getElementById("historialBtn");
      const modal = document.getElementById("historialModal");
      const content = document.getElementById("historialContent");
      const closeBtn = document.getElementById("closeHistorial");

      function fmtDate(s) {
        if (!s) return "—";
        return new Date(s).toLocaleString("es", { dateStyle: "medium", timeStyle: "short" });
      }
      function escHtml(s) {
        if (s == null) return "";
        return String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
      }

      historialBtn?.addEventListener("click", async () => {
        modal.classList.remove("hidden");
        content.innerHTML = '<div class="text-center text-slate-400 py-6">Cargando...</div>';
        try {
          const res = await fetch(`/api/ordenes/${otId}/historial`);
          if (!res.ok) {
            content.innerHTML = '<div class="text-red-600 py-4">Error al cargar el historial</div>';
            return;
          }
          const j = await res.json();

          let html = '';

          // Origen
          if (j.ticketOrigen) {
            html += `<div class="mb-5 rounded-lg border-l-4 border-blue-400 bg-blue-50 p-4 text-sm">
              <p class="text-xs font-semibold text-blue-700 uppercase mb-1">📨 Origen: Ticket público</p>
              <p><strong>Solicitante:</strong> ${escHtml(j.ticketOrigen.solicitanteNombre)}</p>
              <p><strong>Email:</strong> <a href="mailto:${escHtml(j.ticketOrigen.solicitanteEmail)}" class="text-blue-600 hover:underline">${escHtml(j.ticketOrigen.solicitanteEmail)}</a></p>
              ${j.ticketOrigen.solicitanteTelefono ? `<p><strong>Teléfono:</strong> ${escHtml(j.ticketOrigen.solicitanteTelefono)}</p>` : ""}
              <p><strong>Ticket #${j.ticketOrigen.id}:</strong> <a href="/tickets/${j.ticketOrigen.id}" class="text-blue-600 hover:underline">${escHtml(j.ticketOrigen.asunto)}</a></p>
              <p class="text-xs text-slate-500 mt-1">Recibido: ${fmtDate(j.ticketOrigen.createdAt)}</p>
            </div>`;
          } else if (j.creador) {
            html += `<div class="mb-5 rounded-lg border-l-4 border-slate-300 bg-slate-50 p-4 text-sm">
              <p class="text-xs font-semibold text-slate-600 uppercase mb-1">📝 OT creada manualmente</p>
              <p><strong>Por:</strong> ${escHtml(j.creador.nombre)} <span class="text-slate-500">&lt;${escHtml(j.creador.email)}&gt;</span></p>
              <p class="text-xs text-slate-500 mt-1">Fecha: ${fmtDate(j.orden.createdAt)}</p>
            </div>`;
          }

          // Hitos clave
          html += '<div class="mb-5 grid grid-cols-2 gap-2 text-sm sm:grid-cols-4">';
          [
            ["Creada", j.orden.createdAt, "bg-slate-100"],
            ["Iniciada", j.orden.iniciadaEn, "bg-amber-50"],
            ["Completada", j.orden.completadaEn, "bg-emerald-50"],
            ["Cerrada", j.orden.cerradoEn, "bg-slate-200"],
          ].forEach(([lbl, t, cls]) => {
            html += `<div class="${cls} rounded p-2">
              <div class="text-xs uppercase text-slate-500">${lbl}</div>
              <div class="text-xs">${fmtDate(t)}</div>
            </div>`;
          });
          html += '</div>';

          // Timeline de eventos
          html += '<h3 class="font-semibold text-sm mb-2">Eventos registrados (' + j.eventos.length + ')</h3>';
          if (j.eventos.length === 0) {
            html += '<p class="text-sm text-slate-400">Sin eventos en el audit log.</p>';
          } else {
            html += '<ol class="space-y-2 border-l-2 border-slate-200 pl-4">';
            j.eventos.forEach((ev) => {
              const icon = ACCION_ICON[ev.accion] || "•";
              const label = ACCION_LABEL[ev.accion] || ev.accion;
              const color = ev.accion === "delete" ? "border-red-400" :
                            ev.accion === "estado" ? "border-amber-400" :
                            ev.accion === "asignacion" ? "border-purple-400" :
                            ev.accion === "create" ? "border-emerald-400" : "border-slate-300";
              html += `<li class="relative -ml-6 pl-6 border-l-2 ${color} pb-2">
                <div class="absolute -left-[7px] top-1 w-3 h-3 rounded-full bg-white border-2 ${color}"></div>
                <div class="flex items-baseline justify-between gap-2 flex-wrap">
                  <span class="text-sm font-medium">${icon} ${escHtml(ev.resumen ?? label)}</span>
                  <span class="text-xs text-slate-400 whitespace-nowrap">${fmtDate(ev.createdAt)}</span>
                </div>
                <div class="text-xs text-slate-500 mt-0.5">
                  ${ev.usuario ? escHtml(ev.usuario.nombre) + ' <span class="text-slate-400">&lt;' + escHtml(ev.usuario.email) + '&gt;</span>' : '<em class="text-slate-400">sistema</em>'}
                </div>
                ${ev.cambios ? '<details class="mt-1"><summary class="cursor-pointer text-xs text-slate-400 hover:text-slate-600">Ver detalle de cambios</summary><pre class="mt-1 text-xs bg-slate-50 p-2 rounded overflow-x-auto">' + escHtml(JSON.stringify(ev.cambios, null, 2)) + '</pre></details>' : ''}
              </li>`;
            });
            html += '</ol>';
          }

          content.innerHTML = html;
        } catch (e) {
          content.innerHTML = '<div class="text-red-600 py-4">Error: ' + escHtml(String(e)) + '</div>';
        }
      });

      closeBtn?.addEventListener("click", () => modal.classList.add("hidden"));
      modal?.addEventListener("click", (e) => { if (e.target === modal) modal.classList.add("hidden"); });
    </script>
  )}

  {estadoActual === "abierta" && (
    <div class="card mt-4 border-l-4 border-amber-500 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>⚠ OT no iniciada.</strong> Verifica el lugar y los datos del equipo. Cuando estés en sitio listo para trabajar, pulsa <strong>"Iniciar"</strong> para activar el cronómetro y desbloquear los campos de ejecución.
    </div>
  )}
  {estadoActual === "en_espera" && (
    <div class="card mt-4 border-l-4 border-purple-500 bg-purple-50 p-4 text-sm text-purple-800">
      <strong>⏸ OT en espera.</strong> La OT está pausada pendiente de compra u otro insumo.
      {solicitudesVinculadas.length > 0 && (
        <span> Solicitudes vinculadas: {solicitudesVinculadas.map((s) => (
          <a href={`/solicitudes-compra/${s.id}`} class="ml-1 font-medium underline">{s.codigo} ({s.estado})</a>
        ))}</span>
      )}
      {" "}Cuando tengas los materiales, pulsa <strong>"Reanudar"</strong> para continuar.
    </div>
  )}

  <!-- Wizard de estados -->
  {estadoActual !== "cancelada" && (
    <div class="card mt-4 p-4">
      <div class="flex items-center justify-between gap-2">
        {(["abierta", "en_proceso", "completada", "verificada", "cerrada"] as EstadoOT[]).map((s, idx) => (
          <div class="flex flex-1 items-center gap-2">
            <div class:list={[
              "flex h-7 w-7 items-center justify-center rounded-full text-xs font-bold",
              ESTADO_PROGRESO[s] <= stepActual ? "bg-brand-600 text-white" : "bg-slate-200 text-slate-500",
            ]}>{idx + 1}</div>
            <span class:list={["text-xs font-medium", ESTADO_PROGRESO[s] <= stepActual ? "text-slate-900" : "text-slate-400"]}>
              {ESTADO_LABEL[s]}
            </span>
            {idx < 4 && <div class:list={["h-0.5 flex-1", ESTADO_PROGRESO[s] < stepActual ? "bg-brand-600" : "bg-slate-200"]} />}
          </div>
        ))}
      </div>
      {proximas.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {proximas.map((s) => (
            <button
              data-transition={s}
              class:list={[
                "rounded-md px-3 py-1.5 text-sm font-medium",
                s === "cancelada" ? "bg-red-50 text-red-700 hover:bg-red-100" :
                s === "cerrada" ? "bg-slate-700 text-white hover:bg-slate-800" :
                s === "verificada" ? "bg-teal-600 text-white hover:bg-teal-700" :
                s === "en_espera" ? "bg-purple-600 text-white hover:bg-purple-700" :
                "bg-brand-600 text-white hover:bg-brand-700",
              ]}
            >
              {s === "abierta" ? "↺ Reabrir" :
               s === "en_proceso" ? (estadoActual === "en_espera" ? "▶ Reanudar" : "▶ Iniciar") :
               s === "en_espera" ? "⏸ Poner en espera" :
               s === "completada" ? "✓ Completar y cerrar" :
               s === "verificada" ? "✓✓ Verificar y cerrar" :
               s === "cerrada" ? "🔒 Cerrar definitivamente" :
               s === "cancelada" ? "✕ Cancelar" : s}
            </button>
          ))}
        </div>
      )}
    </div>
  )}

  <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
    <!-- Detalles + ejecucion -->
    <div class="lg:col-span-2 space-y-4">
      <div class="card p-5">
        <h2 class="font-semibold text-slate-900">Descripción</h2>
        <p class="mt-2 whitespace-pre-wrap text-sm text-slate-700">{o.descripcion || "Sin descripción."}</p>
      </div>

      <!-- Tarjeta de identificación del equipo (verifica el lugar de intervención) -->
      {row.activo && (
        <div class="card p-5 border-l-4 border-blue-400">
          <div class="flex items-center justify-between">
            <h2 class="font-semibold text-slate-900">📍 Lugar a intervenir</h2>
            {puedeAsignarActivo && (
              <button id="editActivoBtn" type="button" class="text-xs text-brand-600 hover:underline">Cambiar equipo</button>
            )}
          </div>
          <div class="mt-3 grid grid-cols-2 gap-3 text-sm">
            <div class="col-span-2">
              <div class="text-xs uppercase text-slate-500">Equipo</div>
              <div id="activoLabel" class="mt-0.5">
                <a class="font-medium text-brand-700 hover:underline" href={`/activos/${row.activo.id}`}>
                  {row.activo.codigo} · {row.activo.nombre}
                </a>
                <span class="ml-2 text-xs text-slate-500">
                  {row.activo.tipo === "biomedico" ? "🩺 Biomédico" : "🔧 General"}
                </span>
              </div>
            </div>
            <div>
              <div class="text-xs uppercase text-slate-500">🏢 Sucursal</div>
              <div class="mt-0.5">{row.sucursal?.nombre ?? <span class="text-slate-400">—</span>}</div>
            </div>
            <div>
              <div class="text-xs uppercase text-slate-500">📍 Ubicación</div>
              <div class="mt-0.5">
                {row.ubicacion?.nombre ?? row.activo.ubicacion ?? <span class="text-slate-400">—</span>}
                {row.ubicacion?.tipo && <span class="ml-1 text-xs text-slate-400 capitalize">({row.ubicacion.tipo})</span>}
              </div>
            </div>
            <div>
              <div class="text-xs uppercase text-slate-500">N° de serie</div>
              <div class="mt-0.5 font-mono text-xs">{row.activo.serial ?? <span class="text-slate-400 font-sans">—</span>}</div>
            </div>
            <div>
              <div class="text-xs uppercase text-slate-500">Marca / Modelo</div>
              <div class="mt-0.5">{[row.activo.marca, row.activo.modelo].filter(Boolean).join(" / ") || <span class="text-slate-400">—</span>}</div>
            </div>
          </div>
          {puedeAsignarActivo && (
            <div id="activoEditor" class="hidden mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
              <div>
                <label class="label text-xs">1️⃣ Sucursal</label>
                <select id="sucSel" class="input text-sm">
                  <option value="">— Selecciona —</option>
                  {sucursalesLista.map((s) => <option value={s.id}>{s.nombre}</option>)}
                </select>
              </div>
              <div>
                <label class="label text-xs">2️⃣ Ubicación</label>
                <select id="ubSel" class="input text-sm" disabled>
                  <option value="">Selecciona la sucursal</option>
                </select>
              </div>
              <div>
                <label class="label text-xs">3️⃣ Equipo</label>
                <select id="activoSelect" class="input text-sm" disabled>
                  <option value="">Selecciona la ubicación</option>
                </select>
              </div>
              <div class="sm:col-span-3 flex items-center justify-end gap-2">
                <p id="activoMsg" class="hidden mr-auto text-xs"></p>
                <button id="activoCancel" type="button" class="btn-secondary text-sm">Cancelar</button>
                <button id="activoSave" type="button" class="btn-primary text-sm">Guardar</button>
              </div>
            </div>
          )}
        </div>
      )}

      {!row.activo && puedeAsignarActivo && (
        <div class="card p-5 border-l-4 border-slate-300">
          <div class="flex items-center justify-between">
            <div>
              <div class="text-xs uppercase text-slate-500">Equipo</div>
              <div class="text-slate-400 italic">Trabajo sin equipo asignado</div>
            </div>
            <button id="editActivoBtn" type="button" class="btn-secondary text-sm">Asignar equipo</button>
          </div>
          <div id="activoEditor" class="hidden mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
            <div>
              <label class="label text-xs">1️⃣ Sucursal</label>
              <select id="sucSel" class="input text-sm">
                <option value="">— Selecciona —</option>
                {sucursalesLista.map((s) => <option value={s.id}>{s.nombre}</option>)}
              </select>
            </div>
            <div>
              <label class="label text-xs">2️⃣ Ubicación</label>
              <select id="ubSel" class="input text-sm" disabled>
                <option value="">Selecciona la sucursal</option>
              </select>
            </div>
            <div>
              <label class="label text-xs">3️⃣ Equipo</label>
              <select id="activoSelect" class="input text-sm" disabled>
                <option value="">Selecciona la ubicación</option>
              </select>
            </div>
            <div class="sm:col-span-3 flex items-center justify-end gap-2">
              <p id="activoMsg" class="hidden mr-auto text-xs"></p>
              <button id="activoCancel" type="button" class="btn-secondary text-sm">Cancelar</button>
              <button id="activoSave" type="button" class="btn-primary text-sm">Guardar</button>
            </div>
          </div>
        </div>
      )}

      <!-- Foto ANTES de la OT (verificación del estado inicial) -->
      <div class="card p-5 border-l-4 border-blue-300">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-semibold text-slate-900">📷 Foto del estado inicial (antes)</h2>
            <p class="mt-1 text-xs text-slate-500">Toma esta foto al llegar al sitio, antes de pulsar "Iniciar". Sirve como evidencia del estado en que se recibió el equipo.</p>
          </div>
          <span class="text-xs text-slate-500">{adjsAntes.length} foto(s)</span>
        </div>

        {adjsAntes.length > 0 && (
          <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
            {adjsAntes.map((a) => (
              <div class="relative group rounded bg-slate-50 p-2 text-xs">
                {puedeSubirAntes && (
                  <button class="adj-del-btn absolute top-1 right-1 z-10 rounded-full bg-red-500 text-white w-6 h-6 flex items-center justify-center shadow sm:opacity-0 sm:group-hover:opacity-100 transition" data-id={a.id} title="Eliminar">×</button>
                )}
                {a.contentType.startsWith("image/") && (
                  <a href={`/api/adjuntos/${a.id}`} target="_blank">
                    <img src={`/api/adjuntos/${a.id}`} alt={a.nombre} class="mb-1 h-24 w-full rounded object-cover" loading="lazy" />
                  </a>
                )}
                <a href={`/api/adjuntos/${a.id}`} target="_blank" class="block truncate font-medium text-brand-700 hover:underline">{a.nombre}</a>
                <span class="text-slate-500">{(a.tamano / 1024).toFixed(1)} KB</span>
              </div>
            ))}
          </div>
        )}

        {puedeSubirAntes && (
          <form class="upForm mt-3" data-categoria="antes">
            <label class="block">
              <input type="file" accept="image/*,application/pdf" capture="environment" class="hidden upFile" />
              <span class="btn-primary w-full justify-center py-3 cursor-pointer block text-center">📷 {adjsAntes.length === 0 ? "Tomar foto del estado inicial" : "Agregar otra foto"}</span>
            </label>
            <button type="submit" class="hidden">Subir</button>
          </form>
        )}
      </div>

      <!-- Línea de tiempo de la OT -->
      <div class="card p-5">
        <h2 class="font-semibold text-slate-900">⏱ Tiempos</h2>
        <div class="mt-3 grid grid-cols-2 gap-3 text-sm sm:grid-cols-4">
          <div>
            <div class="text-xs uppercase text-slate-500">Asignado</div>
            <div class="mt-0.5">{row.asignado?.nombre ?? <span class="text-slate-400">Sin asignar</span>}</div>
          </div>
          <div>
            <div class="text-xs uppercase text-slate-500">Vencimiento</div>
            <div class="mt-0.5">{fmtDate(o.vencimiento)}</div>
          </div>
          <div>
            <div class="text-xs uppercase text-slate-500">Iniciada</div>
            <div class="mt-0.5">{fmt(o.iniciadaEn)}</div>
          </div>
          <div>
            <div class="text-xs uppercase text-slate-500">Completada</div>
            <div class="mt-0.5">{fmt(o.completadaEn)}</div>
          </div>
        </div>
        {o.iniciadaEn && (
          <div class:list={["mt-3 rounded px-3 py-2 text-xs", estadoActual === "en_espera" ? "bg-purple-50 text-purple-700" : "bg-emerald-50 text-emerald-700"]}>
            {o.completadaEn ? (
              <>
                ⏱ Duración real: <strong>{((new Date(o.completadaEn).getTime() - new Date(o.iniciadaEn).getTime()) / 3600_000).toFixed(2)} h</strong>
                {(o.tiempoPausadoMin ?? 0) > 0 && <> · Pausado: <strong>{((o.tiempoPausadoMin ?? 0) / 60).toFixed(1)} h</strong></>}
                {o.horasTrabajadas != null && <> · Registradas: <strong>{Number(o.horasTrabajadas).toFixed(2)} h</strong></>}
              </>
            ) : estadoActual === "en_espera" ? (
              <>⏸ OT pausada{o.pausadaEn ? ` desde ${fmt(o.pausadaEn)}` : ""}. Tiempo pausado acumulado: <strong>{((o.tiempoPausadoMin ?? 0) / 60).toFixed(1)} h</strong></>
            ) : (
              <>⏱ En proceso desde {fmt(o.iniciadaEn)} — el cronómetro corre.</>
            )}
          </div>
        )}
      </div>

      <!-- Checklist -->
      {checklistItems.length > 0 && (
        <div class="card p-5">
          <div class="flex items-center justify-between">
            <h2 class="font-semibold text-slate-900">Checklist de ejecución</h2>
            <span class="text-xs text-slate-500">{progreso.hechos} / {progreso.total} ({progreso.pct}%)</span>
          </div>
          <div class="mt-2 h-2 overflow-hidden rounded bg-slate-100">
            <div class="h-full bg-emerald-500" style={`width: ${progreso.pct}%`}></div>
          </div>
          <ul id="checklistList" class="mt-4 space-y-2">
            {checklistItems.map((it, idx) => (
              <li class:list={["ck-row flex items-start gap-3 rounded-lg p-3 transition", it.hecho ? "bg-emerald-50" : "bg-slate-50", puedeEditar && "cursor-pointer active:bg-slate-200"]} data-idx={idx}>
                <input type="checkbox" class="ck-item mt-0.5 h-5 w-5 cursor-pointer" data-idx={idx} checked={it.hecho} disabled={!puedeEditar} />
                <div class="flex-1">
                  <div class:list={["text-sm", it.hecho && "text-slate-500 line-through"]}>{it.texto}</div>
                  {it.notas && <div class="text-xs text-slate-500">{it.notas}</div>}
                </div>
              </li>
            ))}
          </ul>
          {puedeEditar && (
            <button id="ckSave" class="btn-secondary mt-3 text-sm">Guardar checklist</button>
          )}
        </div>
      )}

      <!-- Trabajos realizados / causa raiz / solucion -->
      <div class="card p-5">
        <div class="flex items-center justify-between gap-2">
          <h2 class="font-semibold text-slate-900">Ejecución del trabajo</h2>
          <span id="autosaveIndicador" class="text-xs text-slate-400" data-status="idle"></span>
        </div>
        <div class="mt-3 space-y-3 text-sm">
          <div>
            <label class="label">Trabajos realizados</label>
            <textarea id="trabajosRealizados" class="input" rows="3" placeholder="Describe qué se hizo..." disabled={!puedeEditar}>{o.trabajosRealizados ?? ""}</textarea>
          </div>
          {o.tipo === "correctivo" && (
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
              <div>
                <label class="label">Causa raíz</label>
                <textarea id="causaRaiz" class="input" rows="2" disabled={!puedeEditar}>{o.causaRaiz ?? ""}</textarea>
              </div>
              <div>
                <label class="label">Solución aplicada</label>
                <textarea id="solucionAplicada" class="input" rows="2" disabled={!puedeEditar}>{o.solucionAplicada ?? ""}</textarea>
              </div>
            </div>
          )}
          <div>
            <label class="label">Horas trabajadas</label>
            <input id="horasTrabajadas" type="number" min="0" step="0.25" class="input w-32 bg-slate-100 cursor-not-allowed" value={o.horasTrabajadas ?? ""} readonly disabled />
            <p class="mt-1 text-xs text-slate-500">🔒 Se calcula automáticamente del cronómetro: <strong>inicio → cierre</strong>, descontando el tiempo en estado "en espera". No es editable para garantizar trazabilidad real del tiempo.</p>
          </div>
          {puedeEditar && (
            <div class="flex items-center gap-2 flex-wrap">
              <p class="text-xs text-emerald-700 mr-auto">✓ Tus cambios se guardan automáticamente al escribir.</p>
              <button id="ejecSave" class="btn-secondary text-xs">Guardar ahora</button>
            </div>
          )}
          <p id="ejecMsg" class="hidden text-xs"></p>
        </div>
      </div>

      <!-- Repuestos consumidos -->
      {(itemsActivos.length > 0 || repuestosRows.length > 0) && (
        <div class="card p-5">
          <div class="flex items-center justify-between">
            <h2 class="font-semibold text-slate-900">Repuestos consumidos</h2>
            <span class="text-xs text-slate-500">
              {repuestosRows.length} líneas
              {totalRepuestos > 0 && <span> · ${totalRepuestos.toFixed(2)}</span>}
            </span>
          </div>
          {repuestosRows.length === 0 && <p class="mt-2 text-sm text-slate-500">Sin repuestos registrados.</p>}
          {repuestosRows.length > 0 && (
            <div class="mt-3 overflow-x-auto">
              <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                  <tr>
                    <th class="px-3 py-1.5">Item</th>
                    <th class="px-3 py-1.5 text-right">Cant.</th>
                    <th class="px-3 py-1.5 text-right">P. unit.</th>
                    <th class="px-3 py-1.5 text-right">Subtotal</th>
                    {puedeEditar && <th class="px-3 py-1.5"></th>}
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {repuestosRows.map((r) => {
                    const sub = (r.rep.precioUnitario ?? 0) * r.rep.cantidad;
                    return (
                      <tr id={`rep-${r.rep.id}`}>
                        <td class="px-3 py-1.5">
                          <a class="text-brand-700 hover:underline" href={`/inventario/${r.it?.id}`}>{r.it?.codigo} · {r.it?.nombre}</a>
                        </td>
                        <td class="px-3 py-1.5 text-right font-mono">{fmtCantidad(r.rep.cantidad, r.it?.unidad)}</td>
                        <td class="px-3 py-1.5 text-right font-mono">{r.rep.precioUnitario != null ? `$${r.rep.precioUnitario.toFixed(2)}` : "—"}</td>
                        <td class="px-3 py-1.5 text-right font-mono">{sub > 0 ? `$${sub.toFixed(2)}` : "—"}</td>
                        {puedeEditar && (
                          <td class="px-3 py-1.5 text-right">
                            <button class="rep-del-btn text-xs text-red-500 hover:underline" data-id={r.rep.id}>Revertir</button>
                          </td>
                        )}
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}

          {puedeEditar && itemsActivos.length > 0 && (
            <div class="mt-4 rounded border border-dashed border-slate-300 p-3">
              <h3 class="mb-2 text-sm font-semibold text-slate-700">+ Registrar consumo</h3>
              <div class="grid grid-cols-1 gap-2 sm:grid-cols-4">
                <select id="rep_item" class="input text-sm sm:col-span-2">
                  <option value="">— Item —</option>
                  {itemsActivos.map((it) => <option value={it.id} data-precio={it.precio ?? ""} data-unidad={it.unidad}>{it.codigo} · {it.nombre}</option>)}
                </select>
                <input id="rep_cant" type="number" min="0" step="0.01" placeholder="Cantidad" class="input text-sm" />
                <input id="rep_precio" type="number" min="0" step="0.01" placeholder="Precio unit. (opcional)" class="input text-sm" />
              </div>
              <div class="mt-2 flex items-center justify-between gap-2">
                <input id="rep_notas" placeholder="Notas (opcional)" class="input flex-1 text-sm" />
                <button id="rep_save" class="btn-primary text-sm">Registrar</button>
              </div>
              <p id="rep_msg" class="mt-2 hidden text-xs"></p>
            </div>
          )}
        </div>
      )}

      <!-- Costo total estimado de la OT -->
      {/* Costo solo visible para admin/jefe (técnicos no lo ven) */}
      {(user.rol === "admin" || user.rol === "jefe") && (costoManoObra > 0 || totalRepuestos > 0) && (
        <div class="card p-5 border-l-4 border-emerald-500">
          <div class="flex items-center justify-between">
            <h2 class="font-semibold text-slate-900">💰 Costo de la OT</h2>
            <span class="text-xs text-slate-500">Estimado</span>
          </div>
          <dl class="mt-3 space-y-1.5 text-sm">
            <div class="flex justify-between">
              <dt class="text-slate-600">Mano de obra</dt>
              <dd class="font-mono">
                {horasTrab.toFixed(1)}h × ${tarifaTecnico.toFixed(2)}/h
                <span class="ml-2 font-bold text-slate-700">${costoManoObra.toFixed(2)}</span>
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-slate-600">Repuestos consumidos</dt>
              <dd class="font-mono font-bold text-slate-700">${totalRepuestos.toFixed(2)}</dd>
            </div>
            <div class="flex justify-between border-t border-slate-200 pt-2">
              <dt class="font-semibold text-slate-900">Total</dt>
              <dd class="font-mono text-lg font-bold text-emerald-700">${costoTotal.toFixed(2)}</dd>
            </div>
          </dl>
          {tarifaTecnico === 0 && row.asignado && (
            <p class="mt-3 rounded bg-amber-50 p-2 text-xs text-amber-700">
              ⚠ El técnico asignado no tiene tarifa horaria configurada. Configúrala en <a href="/usuarios" class="font-medium underline">Usuarios</a> para calcular el costo de mano de obra.
            </p>
          )}
        </div>
      )}

      <!-- Foto DESPUÉS (estado final) — visible cuando OT está en proceso o más allá -->
      {estadoActual !== "abierta" && estadoActual !== "cancelada" && (
        <div class="card p-5 border-l-4 border-emerald-300">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="font-semibold text-slate-900">📸 Foto del estado final (después)</h2>
              <p class="mt-1 text-xs text-slate-500">Toma foto antes de pulsar "Completar". Es obligatoria para cerrar el trabajo.</p>
            </div>
            <span class="text-xs text-slate-500">{adjsDespues.length} foto(s)</span>
          </div>

          {adjsDespues.length > 0 && (
            <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
              {adjsDespues.map((a) => (
                <div class="relative group rounded bg-slate-50 p-2 text-xs">
                  {puedeEditar && (
                    <button class="adj-del-btn absolute top-1 right-1 z-10 rounded-full bg-red-500 text-white w-6 h-6 flex items-center justify-center shadow sm:opacity-0 sm:group-hover:opacity-100 transition" data-id={a.id} title="Eliminar">×</button>
                  )}
                  {a.contentType.startsWith("image/") && (
                    <a href={`/api/adjuntos/${a.id}`} target="_blank">
                      <img src={`/api/adjuntos/${a.id}`} alt={a.nombre} class="mb-1 h-24 w-full rounded object-cover" loading="lazy" />
                    </a>
                  )}
                  <a href={`/api/adjuntos/${a.id}`} target="_blank" class="block truncate font-medium text-brand-700 hover:underline">{a.nombre}</a>
                  <span class="text-slate-500">{(a.tamano / 1024).toFixed(1)} KB</span>
                </div>
              ))}
            </div>
          )}

          {puedeEditar && (
            <form class="upForm mt-3" data-categoria="despues">
              <label class="block">
                <input type="file" accept="image/*,application/pdf" capture="environment" class="hidden upFile" />
                <span class="btn-primary w-full justify-center py-3 cursor-pointer block text-center bg-emerald-600 hover:bg-emerald-700">📸 {adjsDespues.length === 0 ? "Tomar foto del estado final" : "Agregar otra foto"}</span>
              </label>
              <button type="submit" class="hidden">Subir</button>
            </form>
          )}
        </div>
      )}

      <!-- Verificacion (cuando ya esta verificada o cerrada) -->
      {(o.verificadoEn || o.verificacionNotas) && (
        <div class="card p-5 border-l-4 border-teal-500">
          <h2 class="font-semibold text-teal-700">Verificación</h2>
          <div class="mt-2 text-sm">
            {o.verificadoEn && (
              <p class="text-slate-600">
                Verificada por <strong>{verifUsr?.nombre ?? "—"}</strong> el {fmt(o.verificadoEn)}
              </p>
            )}
            {o.verificacionNotas && (
              <p class="mt-2 whitespace-pre-wrap rounded bg-teal-50 p-3 text-slate-700">{o.verificacionNotas}</p>
            )}
          </div>
        </div>
      )}

      {o.cerradoEn && (
        <div class="card p-5 border-l-4 border-slate-700">
          <h2 class="font-semibold text-slate-700">Cerrada</h2>
          <p class="mt-2 text-sm text-slate-600">
            Cerrada por <strong>{cierraUsr?.nombre ?? "—"}</strong> el {fmt(o.cerradoEn)}
          </p>
        </div>
      )}
    </div>

    <!-- Sidebar: Asignacion + Comentarios -->
    <div class="space-y-4">
      {puedeAsignar && estadoActual !== "cerrada" && estadoActual !== "cancelada" && (
        <div class="card p-5">
          <h2 class="font-semibold text-slate-900">Asignación</h2>
          <div class="mt-3 space-y-2 text-sm">
            <select class="input" id="asignadoA">
              <option value="">— Sin asignar —</option>
              {tecnicos.map((t) => (
                <option value={t.id} selected={o.asignadoA === t.id}>{t.nombre} ({t.rol})</option>
              ))}
            </select>
            {o.asignadoA && (
              <div>
                <label class="text-xs text-slate-500 block mb-1">Motivo de reasignación <span class="text-slate-400">(opcional)</span></label>
                <input class="input text-sm" id="motivoReasignacion" placeholder="Ej: Cobertura por ausencia, mejor especialidad…" />
                <p class="mt-0.5 text-[11px] text-slate-400">Se incluye en el correo al técnico nuevo. Déjalo vacío si no aplica.</p>
              </div>
            )}
            <button id="asignarBtn" class="btn-secondary w-full justify-center">Guardar asignación</button>
          </div>
        </div>
      )}

      <!-- Solicitudes de compra vinculadas -->
      {verComprasSection && (
        <div class="card p-5">
          <div class="flex items-center justify-between mb-2">
            <h2 class="font-semibold text-slate-900">🛒 Compras</h2>
            {puedeSolicitarCompra && (
              <a href={`/solicitudes-compra/nueva?ordenId=${o.id}`} class="text-xs text-brand-600 hover:underline font-medium">
                + Nueva solicitud
              </a>
            )}
          </div>

          {!puedeSolicitarCompra && solicitudesVinculadas.length === 0 && (
            <div class="rounded-lg bg-amber-50 border border-amber-200 p-3 text-xs text-amber-800">
              {estadoActual === "abierta"
                ? <>⚠ Pulsa <strong>"Iniciar"</strong> para activar la OT y poder solicitar compras de contingencia.</>
                : <>Esta OT está en estado <strong>{ESTADO_LABEL[estadoActual]}</strong>. Solo se pueden generar solicitudes mientras la OT está en proceso o en espera.</>
              }
            </div>
          )}

          {solicitudesVinculadas.map((s) => {
            const sc = {
              borrador: "bg-slate-100 text-slate-600", enviada: "bg-blue-100 text-blue-700",
              comprada: "bg-emerald-100 text-emerald-700", rechazada: "bg-red-100 text-red-700",
              cancelada: "bg-slate-200 text-slate-500",
            } as const;
            const sl = {
              borrador: "Borrador", enviada: "Enviada", comprada: "Comprada", rechazada: "Rechazada", cancelada: "Cancelada",
            } as const;
            return (
              <a href={`/solicitudes-compra/${s.id}`} class="mt-2 flex items-center justify-between rounded-lg bg-slate-50 p-2 text-sm hover:bg-slate-100 no-underline block">
                <div>
                  <span class="font-mono text-xs text-slate-400">{s.codigo}</span>
                  <p class="text-sm font-medium text-slate-800 truncate">{s.titulo}</p>
                </div>
                <span class:list={["ml-2 shrink-0 text-xs px-2 py-0.5 rounded-full font-medium", sc[s.estado]]}>{sl[s.estado]}</span>
              </a>
            );
          })}
          {puedeSolicitarCompra && solicitudesVinculadas.length === 0 && (
            <a href={`/solicitudes-compra/nueva?ordenId=${o.id}`}
               class="mt-2 flex items-center justify-center gap-2 rounded-lg border border-dashed border-purple-300 p-3 text-sm text-purple-600 hover:bg-purple-50 no-underline">
              🛒 Solicitar compra de contingencia
            </a>
          )}
        </div>
      )}

      <div class="card p-5">
        <h2 class="font-semibold text-slate-900">Comentarios ({coms.length})</h2>
        <ul class="mt-3 space-y-3 text-sm">
          {coms.length === 0 && <li class="text-slate-500">Sin comentarios.</li>}
          {coms.map((r) => (
            <li class="rounded-md bg-slate-50 p-3">
              <div class="text-xs text-slate-500">{r.u?.nombre} - {fmt(r.c.createdAt)}</div>
              <div class="mt-1 whitespace-pre-wrap">{r.c.texto}</div>
            </li>
          ))}
        </ul>
        {puedeEditar ? (
          <form id="comForm" class="mt-3 space-y-2">
            <textarea id="comTexto" class="input" rows="2" placeholder="Agregar comentario..." required></textarea>
            <button class="btn-primary w-full justify-center" type="submit">Comentar</button>
          </form>
        ) : (
          <p class="mt-3 text-xs text-slate-400">
            {estadoActual === "abierta" ? "⚠ Inicia la OT para agregar comentarios" : "Comentarios bloqueados en este estado"}
          </p>
        )}
      </div>
    </div>
  </div>

  <!-- Documentos y archivos generales (las fotos antes/después están en sus tarjetas) -->
  <div class="mt-6 card p-5">
    <h2 class="font-semibold text-slate-900">Documentos y archivos ({adjsDocumento.length + adjsGeneral.length})</h2>
    <p class="text-xs text-slate-500">Para subir manuales, facturas u otros archivos. Las fotos antes/después están en sus secciones correspondientes.</p>
    <div class="mt-3 grid grid-cols-1 gap-4 md:grid-cols-2">
      {([
        { key: "documento", label: "📄 Documentos", color: "bg-amber-50", items: adjsDocumento },
        { key: "general", label: "📎 General", color: "bg-slate-50", items: adjsGeneral },
      ] as const).map((cat) => (
        <div class={`${cat.color} rounded-lg p-3`}>
          <div class="mb-2 flex items-center justify-between">
            <h3 class="text-sm font-semibold text-slate-700">{cat.label}</h3>
            <span class="text-xs text-slate-500">{cat.items.length}</span>
          </div>
          <ul class="space-y-1">
            {cat.items.length === 0 && <li class="text-xs text-slate-400">Vacío.</li>}
            {cat.items.map((a) => (
              <li class="relative group rounded bg-white p-2 text-xs">
                {puedeEditar && (
                  <button class="adj-del-btn absolute top-1 right-1 z-10 rounded-full bg-red-500 text-white w-6 h-6 flex items-center justify-center shadow sm:opacity-0 sm:group-hover:opacity-100 transition" data-id={a.id} title="Eliminar">×</button>
                )}
                {a.contentType.startsWith("image/") && (
                  <a href={`/api/adjuntos/${a.id}`} target="_blank">
                    <img src={`/api/adjuntos/${a.id}`} alt={a.nombre} class="mb-1 h-24 w-full rounded object-cover" loading="lazy" />
                  </a>
                )}
                <a href={`/api/adjuntos/${a.id}`} target="_blank" class="block truncate font-medium text-brand-700 hover:underline">
                  {a.nombre}
                </a>
                <span class="text-slate-500">{(a.tamano / 1024).toFixed(1)} KB</span>
              </li>
            ))}
          </ul>
          {puedeEditar && (
            <form class="upForm mt-2 space-y-1" data-categoria={cat.key}>
              <label class="block">
                <input type="file" accept="image/*,application/pdf" capture="environment" class="hidden upFile" />
                <span class="btn-secondary w-full justify-center py-2 text-xs cursor-pointer block text-center">📷 Tomar foto / subir archivo</span>
              </label>
              <button type="submit" class="hidden">Subir</button>
            </form>
          )}
        </div>
      ))}
    </div>
    <p id="upErr" class="mt-2 hidden text-sm text-red-600"></p>
  </div>

  <!-- Firmas digitales + PDF -->
  <div class="card mt-6 p-5">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold text-slate-900">Firmas digitales</h2>
      <button id="pdfBtn" class="btn-primary text-sm">📄 Descargar PDF</button>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-3">
      {(["tecnico", "jefe", "solicitante"] as const).map((rol) => {
        const r2 = rol === "tecnico" ? o.firmaTecnicoR2 : rol === "jefe" ? o.firmaJefeR2 : o.firmaSolicitanteR2;
        const nombre = rol === "tecnico" ? o.firmaTecnicoNombre : rol === "jefe" ? o.firmaJefeNombre : o.firmaSolicitanteNombre;
        const fecha = rol === "tecnico" ? o.firmaTecnicoFecha : rol === "jefe" ? o.firmaJefeFecha : o.firmaSolicitanteFecha;
        const labels = { tecnico: "Técnico", jefe: "Jefe / Supervisor", solicitante: "Solicitante / Usuario" };
        return (
          <div class="rounded-lg border border-slate-200 p-3">
            <div class="text-xs font-medium uppercase text-slate-500">{labels[rol]}</div>
            {r2 ? (
              <div class="mt-2">
                <img src={`/api/firmas/${o.id}/${rol}`} alt={`Firma ${rol}`} class="h-20 w-full rounded bg-white object-contain" />
                <div class="mt-1 text-xs text-slate-600"><strong>{nombre}</strong></div>
                <div class="text-[10px] text-slate-400">{fecha ? new Date(fecha).toLocaleString("es") : ""}</div>
                <button class="firma-clear-btn mt-1 text-[10px] text-red-500 hover:underline" data-rol={rol}>Volver a firmar</button>
              </div>
            ) : (
              <button class="firma-add-btn mt-2 w-full rounded border border-dashed border-slate-300 py-3 text-xs text-slate-500 hover:border-brand-500 hover:text-brand-700" data-rol={rol}>
                + Agregar firma
              </button>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Modal de firma -->
  <div id="firmaModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-lg rounded-lg bg-white p-5 shadow-xl">
      <h3 id="firmaTitulo" class="font-semibold">Firmar como técnico</h3>
      <p class="mt-1 text-xs text-slate-500">Dibuja con el mouse o el dedo (touch).</p>
      <input id="firmaNombre" class="input mt-3" placeholder="Nombre completo del firmante" />
      <canvas id="firmaCanvas" width="500" height="180" class="mt-3 w-full rounded border-2 border-dashed border-slate-300 bg-white" style="touch-action:none"></canvas>
      <div class="mt-3 flex justify-end gap-2">
        <button id="firmaClear" class="btn-secondary">Limpiar</button>
        <button id="firmaCancel" class="btn-secondary">Cancelar</button>
        <button id="firmaSave" class="btn-primary">Guardar firma</button>
      </div>
      <p id="firmaErr" class="mt-2 hidden text-xs text-red-600"></p>
    </div>
  </div>

  <!-- Modal verificacion (capturar notas) -->
  <div id="verifModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" role="dialog">
    <div class="w-full max-w-md rounded-lg bg-white p-5 shadow-xl">
      <h3 class="font-semibold text-slate-900">Verificar y cerrar orden</h3>
      <p class="mt-1 text-xs text-slate-500">Confirmas que el trabajo está conforme. La OT pasará a <strong>cerrada</strong> y se enviará la encuesta de satisfacción al solicitante. Puedes agregar observaciones.</p>
      <textarea id="verifNotas" class="input mt-3" rows="3" placeholder="Notas de verificación (opcional)"></textarea>
      <div class="mt-3 flex justify-end gap-2">
        <button id="verifCancel" class="btn-secondary">Cancelar</button>
        <button id="verifConfirm" class="btn-primary bg-teal-600 hover:bg-teal-700">Verificar y cerrar</button>
      </div>
    </div>
  </div>

  <script define:vars={{
    id,
    checklistJson: o.checklistEjecucion ?? null,
    itemsRepJson,
    ubicacionesData: ubicacionesLista,
    activosData: activosLista,
    sucursalActualId: row.sucursal?.id ?? null,
    ubicacionActualId: row.ubicacion?.id ?? null,
    activoActualId: row.activo?.id ?? null,
  }}>
    const $ = (id) => document.getElementById(id);
    let checklist = checklistJson ? JSON.parse(checklistJson) : [];

    async function patchOrden(payload) {
      const res = await fetch(`/api/ordenes/${id}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        alert(typeof j.error === "string" ? j.error : "Error");
        return null;
      }
      return await res.json();
    }

    // ── Asignar / cambiar equipo (en cascada: sucursal → ubicación → equipo)
    (function () {
      const sucSel = $("sucSel");
      const ubSel = $("ubSel");
      const acSel = $("activoSelect");
      if (!sucSel || !ubSel || !acSel) return;

      function poblarUbicaciones(sucId, preselectUbId) {
        ubSel.innerHTML = "";
        if (!sucId) {
          ubSel.disabled = true;
          ubSel.appendChild(new Option("Selecciona la sucursal", ""));
          poblarActivos(null, null);
          return;
        }
        const ubs = (ubicacionesData || []).filter((u) => u.sucursalId === sucId);
        ubSel.disabled = ubs.length === 0;
        ubSel.appendChild(new Option(ubs.length === 0 ? "Sin ubicaciones" : "— Selecciona —", ""));
        ubs.forEach((u) => {
          const opt = new Option(`${u.nombre} (${u.tipo})`, String(u.id));
          if (u.id === preselectUbId) opt.selected = true;
          ubSel.appendChild(opt);
        });
        poblarActivos(preselectUbId ?? null, activoActualId);
      }

      function poblarActivos(ubId, preselectActivoId) {
        acSel.innerHTML = "";
        if (!ubId) {
          acSel.disabled = true;
          acSel.appendChild(new Option("Selecciona la ubicación", ""));
          return;
        }
        const eqs = (activosData || []).filter((a) => a.ubicacionId === ubId);
        acSel.disabled = eqs.length === 0;
        acSel.appendChild(new Option(eqs.length === 0 ? "Sin equipos en esta ubicación" : "— Sin equipo —", ""));
        eqs.forEach((a) => {
          const opt = new Option(`${a.codigo} · ${a.nombre}`, String(a.id));
          if (a.id === preselectActivoId) opt.selected = true;
          acSel.appendChild(opt);
        });
      }

      sucSel.addEventListener("change", () => {
        const sid = Number(sucSel.value) || null;
        poblarUbicaciones(sid, null);
      });
      ubSel.addEventListener("change", () => {
        const uid = Number(ubSel.value) || null;
        poblarActivos(uid, null);
      });

      $("editActivoBtn")?.addEventListener("click", () => {
        $("activoEditor")?.classList.remove("hidden");
        $("editActivoBtn").classList.add("hidden");
        // Pre-seleccionar el actual si lo hay
        if (sucursalActualId) {
          sucSel.value = String(sucursalActualId);
          poblarUbicaciones(sucursalActualId, ubicacionActualId);
        }
      });
      $("activoCancel")?.addEventListener("click", () => {
        $("activoEditor")?.classList.add("hidden");
        $("editActivoBtn").classList.remove("hidden");
      });
      $("activoSave")?.addEventListener("click", async () => {
        const newId = acSel.value ? Number(acSel.value) : null;
        const msg = $("activoMsg");
        msg.classList.add("hidden");
        const r = await patchOrden({ activoId: newId });
        if (r) location.reload();
      });
    })();

    // Eliminar OT (solo admin)
    $("deleteOtBtn")?.addEventListener("click", async () => {
      if (!confirm("¿Eliminar esta OT permanentemente?\n\nEsta acción borra la OT, sus comentarios y adjuntos. Si vino de un plan o actividad recurrente, el cron podrá generar otra en el siguiente ciclo. No se puede deshacer.")) return;
      const r = await fetch(`/api/ordenes/${id}`, { method: "DELETE" });
      if (r.ok) {
        location.href = "/ordenes";
      } else {
        alert("Error al eliminar la OT");
      }
    });

    // Transiciones
    document.querySelectorAll("[data-transition]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const estado = btn.dataset.transition;
        if (estado === "verificada") {
          $("verifModal").classList.remove("hidden");
          $("verifModal").classList.add("flex");
          return;
        }
        if (estado === "cancelada" && !confirm("¿Cancelar esta orden?")) return;
        if (estado === "cerrada" && !confirm("¿Cerrar definitivamente la orden? Ya no se podrá modificar.")) return;
        const r = await patchOrden({ estado });
        if (r) location.reload();
      });
    });

    // Verificacion modal
    $("verifCancel")?.addEventListener("click", () => {
      $("verifModal").classList.add("hidden");
      $("verifModal").classList.remove("flex");
    });
    $("verifConfirm")?.addEventListener("click", async () => {
      const notas = $("verifNotas").value.trim();
      const r = await patchOrden({ estado: "verificada", verificacionNotas: notas || null });
      if (r) location.reload();
    });

    // Asignacion
    $("asignarBtn")?.addEventListener("click", async () => {
      const v = $("asignadoA").value;
      const motivoEl = $("motivoReasignacion");
      const motivo = motivoEl ? motivoEl.value.trim() : "";
      const payload = { asignadoA: v ? Number(v) : null };
      if (motivo) payload.motivoReasignacion = motivo;
      const r = await patchOrden(payload);
      if (r) location.reload();
    });

    // Checklist: el checkbox y la fila completa son tap-targets
    function actualizarFila(idx, hecho) {
      const row = document.querySelector(`.ck-row[data-idx="${idx}"]`);
      if (!row) return;
      const txt = row.querySelector(".text-sm");
      if (hecho) {
        row.classList.remove("bg-slate-50");
        row.classList.add("bg-emerald-50");
        txt?.classList.add("text-slate-500", "line-through");
      } else {
        row.classList.add("bg-slate-50");
        row.classList.remove("bg-emerald-50");
        txt?.classList.remove("text-slate-500", "line-through");
      }
    }
    document.querySelectorAll(".ck-item").forEach((el) => {
      el.addEventListener("change", () => {
        const idx = Number(el.dataset.idx);
        if (checklist[idx]) checklist[idx].hecho = el.checked;
        actualizarFila(idx, el.checked);
      });
    });
    document.querySelectorAll(".ck-row").forEach((row) => {
      row.addEventListener("click", (e) => {
        if (e.target.tagName === "INPUT") return;
        const cb = row.querySelector(".ck-item");
        if (cb && !cb.disabled) {
          cb.checked = !cb.checked;
          cb.dispatchEvent(new Event("change"));
        }
      });
    });
    $("ckSave")?.addEventListener("click", async () => {
      const r = await patchOrden({ checklistEjecucion: JSON.stringify(checklist) });
      if (r) {
        const btn = $("ckSave");
        btn.textContent = "✓ Guardado";
        setTimeout(() => (btn.textContent = "Guardar checklist"), 1500);
      }
    });

    // ── Ejecución: auto-guardado con debounce + backup en localStorage ────
    const STORAGE_KEY = `ot-${id}-draft`;
    const ejecFields = ["trabajosRealizados", "causaRaiz", "solucionAplicada"];
    const ejecIndicador = $("autosaveIndicador");

    function setIndicador(estado, texto) {
      if (!ejecIndicador) return;
      ejecIndicador.dataset.status = estado;
      ejecIndicador.textContent = texto;
      const colores = {
        idle: "text-slate-400",
        guardando: "text-amber-600",
        guardado: "text-emerald-600",
        error: "text-red-600",
        offline: "text-amber-700",
      };
      ejecIndicador.className = "text-xs " + (colores[estado] || colores.idle);
    }

    function leerEjecPayload() {
      // horasTrabajadas se calcula en el servidor automaticamente al cerrar.
      // No se envia desde el cliente.
      return {
        trabajosRealizados: $("trabajosRealizados")?.value.trim() || null,
        causaRaiz: $("causaRaiz")?.value?.trim() || null,
        solucionAplicada: $("solucionAplicada")?.value?.trim() || null,
      };
    }

    function guardarLocal(payload) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ payload, savedAt: Date.now() }));
      } catch {}
    }
    function limpiarLocal() {
      try { localStorage.removeItem(STORAGE_KEY); } catch {}
    }

    let debounceTimer = null;
    let inFlight = false;
    let pending = false;

    async function ejecutarGuardado() {
      if (inFlight) { pending = true; return; }
      inFlight = true;
      setIndicador("guardando", "⏳ Guardando…");
      const payload = leerEjecPayload();
      // Backup local antes de mandar al servidor
      guardarLocal(payload);
      try {
        const r = await patchOrden(payload);
        if (r) {
          limpiarLocal();
          setIndicador("guardado", "✓ Guardado");
          setTimeout(() => { if (ejecIndicador?.dataset.status === "guardado") setIndicador("idle", ""); }, 2000);
        } else {
          setIndicador("offline", "⚠ Sin conexión — guardado localmente");
        }
      } catch {
        setIndicador("offline", "⚠ Sin conexión — guardado localmente");
      } finally {
        inFlight = false;
        if (pending) { pending = false; ejecutarGuardado(); }
      }
    }

    function programarGuardado() {
      // Mostrar inmediatamente que hay cambios pendientes
      setIndicador("guardando", "✏️ Editando…");
      // Backup local instantáneo
      guardarLocal(leerEjecPayload());
      // Debounce 1.5s
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(ejecutarGuardado, 1500);
    }

    // Conectar listeners a cada campo de ejecución
    ejecFields.forEach((fieldId) => {
      const el = $(fieldId);
      if (!el || el.disabled) return;
      el.addEventListener("input", programarGuardado);
      el.addEventListener("change", programarGuardado);
    });

    // Botón "Guardar ahora" (forzar sin esperar el debounce)
    $("ejecSave")?.addEventListener("click", async () => {
      if (debounceTimer) { clearTimeout(debounceTimer); debounceTimer = null; }
      await ejecutarGuardado();
    });

    // Al cargar la página: si hay un draft local más reciente que el servidor,
    // ofrecer restaurarlo
    (function checkDraftLocal() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const { payload, savedAt } = JSON.parse(raw);
        if (!payload) return;
        // Comparar con valores actuales del DOM (que vienen del servidor)
        const actualTrab = ($("trabajosRealizados")?.value || "").trim();
        const actualCausa = ($("causaRaiz")?.value || "").trim();
        const actualSol = ($("solucionAplicada")?.value || "").trim();
        const cambios = (
          (payload.trabajosRealizados ?? "") !== actualTrab ||
          (payload.causaRaiz ?? "") !== actualCausa ||
          (payload.solucionAplicada ?? "") !== actualSol
        );
        if (!cambios) { limpiarLocal(); return; }
        const fechaSave = new Date(savedAt).toLocaleString("es");
        const mensaje = `Tienes cambios sin guardar de ${fechaSave} en esta OT. ¿Restaurarlos? (Cancelar = descartar)`;
        if (confirm(mensaje)) {
          if ($("trabajosRealizados") && payload.trabajosRealizados != null) $("trabajosRealizados").value = payload.trabajosRealizados;
          if ($("causaRaiz") && payload.causaRaiz != null) $("causaRaiz").value = payload.causaRaiz;
          if ($("solucionAplicada") && payload.solucionAplicada != null) $("solucionAplicada").value = payload.solucionAplicada;
          // Disparar guardado inmediato al servidor
          ejecutarGuardado();
        } else {
          limpiarLocal();
        }
      } catch {}
    })();

    // Avisar al usuario si intenta cerrar la pestaña con cambios pendientes
    window.addEventListener("beforeunload", (e) => {
      if (debounceTimer || inFlight) {
        e.preventDefault();
        e.returnValue = "";
      }
    });

    // Comentarios
    $("comForm")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const texto = $("comTexto").value.trim();
      if (!texto) return;
      const res = await fetch(`/api/ordenes/${id}/comentarios`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ texto }),
      });
      if (res.ok) location.reload();
    });

    // Repuestos: auto-rellenar precio cuando elige item
    const repItem = $("rep_item");
    const repPrecio = $("rep_precio");
    repItem?.addEventListener("change", () => {
      const opt = repItem.options[repItem.selectedIndex];
      const p = opt?.dataset?.precio;
      if (p && !repPrecio.value) repPrecio.value = p;
    });

    $("rep_save")?.addEventListener("click", async () => {
      const msg = $("rep_msg");
      msg.classList.add("hidden");
      const itemId = Number($("rep_item").value);
      const cantidad = Number($("rep_cant").value);
      const precio = $("rep_precio").value;
      if (!itemId || !cantidad || cantidad <= 0) {
        msg.textContent = "Completa item y cantidad.";
        msg.className = "text-xs text-red-600"; msg.classList.remove("hidden"); return;
      }
      const res = await fetch(`/api/ordenes/${id}/repuestos`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          itemId, cantidad,
          precioUnitario: precio ? Number(precio) : null,
          notas: $("rep_notas").value.trim() || null,
        }),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        msg.textContent = typeof j.error === "string" ? j.error : "Error al registrar";
        msg.className = "text-xs text-red-600"; msg.classList.remove("hidden"); return;
      }
      location.reload();
    });

    document.querySelectorAll(".rep-del-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        if (!confirm("¿Revertir este consumo y devolver al stock?")) return;
        const res = await fetch(`/api/ordenes/${id}/repuestos?repuesto_id=${btn.dataset.id}`, { method: "DELETE" });
        if (res.ok) location.reload();
      });
    });

    // Subida de adjuntos por categoría — auto-upload al seleccionar archivo
    async function subirAdjunto(form, file) {
      const err = $("upErr");
      err.classList.add("hidden");
      const btn = form.querySelector("button[type=submit]");
      if (btn) { btn.disabled = true; btn.textContent = "⏳ Subiendo…"; }
      try {
        const fd = new FormData();
        fd.append("file", file);
        fd.append("categoria", form.dataset.categoria);
        const res = await fetch(`/api/ordenes/${id}/adjuntos`, { method: "POST", body: fd });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          err.textContent = j.error || "Error al subir";
          err.classList.remove("hidden");
          if (btn) { btn.disabled = false; btn.textContent = "📷 Subir / Tomar foto"; }
          return;
        }
        location.reload();
      } catch (e) {
        err.textContent = "Error de red al subir";
        err.classList.remove("hidden");
        if (btn) { btn.disabled = false; btn.textContent = "📷 Subir / Tomar foto"; }
      }
    }

    document.querySelectorAll(".upForm").forEach((form) => {
      const fileInput = form.querySelector(".upFile");
      // Submit manual (botón) — opcional
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const file = fileInput.files[0];
        if (file) subirAdjunto(form, file);
      });
      // Auto-upload al seleccionar archivo (cámara o explorador)
      fileInput?.addEventListener("change", () => {
        const file = fileInput.files[0];
        if (file) subirAdjunto(form, file);
      });
    });

    // Eliminar adjuntos individuales
    document.querySelectorAll(".adj-del-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (!confirm("¿Eliminar esta foto/archivo? Esta acción no se puede deshacer.")) return;
        const adjId = btn.dataset.id;
        const r = await fetch(`/api/adjuntos/${adjId}`, { method: "DELETE" });
        if (r.ok) location.reload();
        else alert("Error al eliminar el archivo");
      });
    });
  </script>

  <!-- Firmas + PDF -->
  <script define:vars={{ id, ordenData: { id: o.id, titulo: o.titulo, descripcion: o.descripcion, tipo: o.tipo, prioridad: o.prioridad, estado: o.estado, createdAt: o.createdAt, completadaEn: o.completadaEn, vencimiento: o.vencimiento, trabajosRealizados: o.trabajosRealizados, causaRaiz: o.causaRaiz, solucionAplicada: o.solucionAplicada, horasTrabajadas: o.horasTrabajadas, verificacionNotas: o.verificacionNotas, firmaTecnicoNombre: o.firmaTecnicoNombre, firmaJefeNombre: o.firmaJefeNombre, firmaSolicitanteNombre: o.firmaSolicitanteNombre, firmaTecnicoR2: o.firmaTecnicoR2, firmaJefeR2: o.firmaJefeR2, firmaSolicitanteR2: o.firmaSolicitanteR2 }, activoData: row.activo, asignadoData: row.asignado, repuestos: repuestosRows.map(r => ({ codigo: r.it?.codigo, nombre: r.it?.nombre, unidad: r.it?.unidad, cantidad: r.rep.cantidad, precio: r.rep.precioUnitario })), totalRepuestos, checklistItems, adjs: adjs.map(a => ({ id: a.id, nombre: a.nombre, categoria: a.categoria, contentType: a.contentType })) }}>
    const $ = (s) => document.getElementById(s);
    const modal = $("firmaModal");
    const canvas = $("firmaCanvas");
    const ctx = canvas.getContext("2d");
    let drawing = false, currentRol = null;

    function clearCanvas() {
      ctx.fillStyle = "#fff";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.strokeStyle = "#0f172a";
      ctx.lineWidth = 2;
      ctx.lineCap = "round";
    }

    function getPos(e) {
      const r = canvas.getBoundingClientRect();
      const sx = canvas.width / r.width;
      const sy = canvas.height / r.height;
      const t = e.touches ? e.touches[0] : e;
      return { x: (t.clientX - r.left) * sx, y: (t.clientY - r.top) * sy };
    }

    canvas.addEventListener("pointerdown", (e) => { drawing = true; const p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
    canvas.addEventListener("pointermove", (e) => { if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
    canvas.addEventListener("pointerup", () => { drawing = false; });
    canvas.addEventListener("pointerleave", () => { drawing = false; });

    document.querySelectorAll(".firma-add-btn, .firma-clear-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        currentRol = btn.dataset.rol;
        const labels = { tecnico: "técnico", jefe: "jefe / supervisor", solicitante: "solicitante / usuario" };
        $("firmaTitulo").textContent = `Firmar como ${labels[currentRol]}`;
        $("firmaNombre").value = "";
        clearCanvas();
        modal.classList.remove("hidden");
        modal.classList.add("flex");
      });
    });

    $("firmaCancel").addEventListener("click", () => { modal.classList.add("hidden"); modal.classList.remove("flex"); });
    $("firmaClear").addEventListener("click", clearCanvas);

    $("firmaSave").addEventListener("click", async () => {
      const err = $("firmaErr");
      err.classList.add("hidden");
      const nombre = $("firmaNombre").value.trim();
      if (!nombre) { err.textContent = "Nombre requerido"; err.classList.remove("hidden"); return; }
      const dataUrl = canvas.toDataURL("image/png");
      const res = await fetch(`/api/ordenes/${id}/firma`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ rol: currentRol, nombre, imagenDataUrl: dataUrl }),
      });
      if (!res.ok) { err.textContent = "Error al guardar firma"; err.classList.remove("hidden"); return; }
      location.reload();
    });
    clearCanvas();

    // ── PDF ───────────────────────────────────────────────────────────────────
    async function loadJsPdf() {
      if (window.jspdf) return window.jspdf;
      await new Promise((resolve, reject) => {
        const s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js";
        s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });
      return window.jspdf;
    }

    async function fetchEmpresa() {
      try { const r = await fetch("/api/empresa"); if (r.ok) { const j = await r.json(); return j.empresa; } } catch {}
      return null;
    }

    async function fetchImageAsDataURL(url) {
      try {
        const r = await fetch(url);
        if (!r.ok) return null;
        const blob = await r.blob();
        return await new Promise((resolve) => {
          const fr = new FileReader();
          fr.onload = () => resolve(fr.result);
          fr.readAsDataURL(blob);
        });
      } catch { return null; }
    }

    function fmt(s) { return s ? new Date(s).toLocaleString("es") : "—"; }

    $("pdfBtn").addEventListener("click", async () => {
      $("pdfBtn").disabled = true;
      $("pdfBtn").textContent = "Generando...";
      try {
        const { jsPDF } = await loadJsPdf();
        const empresa = await fetchEmpresa();
        const doc = new jsPDF({ unit: "mm", format: "a4" });
        const W = 210, M = 14;
        let y = M;

        // Header
        doc.setFillColor(10, 64, 130);
        doc.rect(0, 0, W, 22, "F");
        doc.setTextColor(255);
        doc.setFontSize(16); doc.setFont("helvetica", "bold");
        doc.text(empresa?.nombre ?? "Mantenimiento", M, 12);
        doc.setFontSize(10); doc.setFont("helvetica", "normal");
        doc.text(`Orden de Trabajo #${ordenData.id}`, M, 18);
        doc.setTextColor(0);
        y = 30;

        // Info empresa
        if (empresa) {
          doc.setFontSize(8); doc.setTextColor(100);
          if (empresa.nit) doc.text(`NIT: ${empresa.nit}`, W - M, 8, { align: "right" });
          if (empresa.direccion) doc.text(empresa.direccion, W - M, 12, { align: "right" });
          if (empresa.telefono) doc.text(`Tel: ${empresa.telefono}`, W - M, 16, { align: "right" });
          doc.setTextColor(0);
        }

        // Titulo OT
        doc.setFontSize(14); doc.setFont("helvetica", "bold");
        doc.text(ordenData.titulo, M, y); y += 8;

        // Tabla datos
        doc.setFontSize(9); doc.setFont("helvetica", "normal");
        const rows = [
          ["Tipo", ordenData.tipo, "Prioridad", ordenData.prioridad],
          ["Estado", ordenData.estado, "Creada", fmt(ordenData.createdAt)],
          ["Equipo", activoData ? `${activoData.codigo} - ${activoData.nombre}` : "Sin equipo", "Vencimiento", fmt(ordenData.vencimiento)],
          ["Asignado", asignadoData?.nombre ?? "—", "Completada", fmt(ordenData.completadaEn)],
        ];
        rows.forEach((r) => {
          doc.setFont("helvetica", "bold"); doc.text(r[0] + ":", M, y);
          doc.setFont("helvetica", "normal"); doc.text(String(r[1] ?? "—"), M + 28, y);
          doc.setFont("helvetica", "bold"); doc.text(r[2] + ":", W / 2, y);
          doc.setFont("helvetica", "normal"); doc.text(String(r[3] ?? "—"), W / 2 + 28, y);
          y += 5;
        });
        y += 3;

        // Descripcion
        if (ordenData.descripcion) {
          doc.setFont("helvetica", "bold"); doc.text("Descripción", M, y); y += 5;
          doc.setFont("helvetica", "normal");
          const lines = doc.splitTextToSize(ordenData.descripcion, W - M * 2);
          doc.text(lines, M, y); y += lines.length * 4 + 3;
        }

        // Trabajos realizados
        if (ordenData.trabajosRealizados) {
          if (y > 250) { doc.addPage(); y = M; }
          doc.setFont("helvetica", "bold"); doc.text("Trabajos realizados", M, y); y += 5;
          doc.setFont("helvetica", "normal");
          const lines = doc.splitTextToSize(ordenData.trabajosRealizados, W - M * 2);
          doc.text(lines, M, y); y += lines.length * 4 + 3;
        }

        if (ordenData.causaRaiz) {
          doc.setFont("helvetica", "bold"); doc.text("Causa raíz: ", M, y);
          doc.setFont("helvetica", "normal");
          const lines = doc.splitTextToSize(ordenData.causaRaiz, W - M * 2 - 20);
          doc.text(lines, M + 20, y); y += Math.max(lines.length * 4, 5) + 1;
        }
        if (ordenData.solucionAplicada) {
          doc.setFont("helvetica", "bold"); doc.text("Solución: ", M, y);
          doc.setFont("helvetica", "normal");
          const lines = doc.splitTextToSize(ordenData.solucionAplicada, W - M * 2 - 20);
          doc.text(lines, M + 20, y); y += Math.max(lines.length * 4, 5) + 1;
        }
        if (ordenData.horasTrabajadas != null) {
          doc.setFont("helvetica", "bold"); doc.text(`Horas trabajadas: `, M, y);
          doc.setFont("helvetica", "normal"); doc.text(`${ordenData.horasTrabajadas}`, M + 35, y); y += 6;
        }

        // Checklist
        if (checklistItems && checklistItems.length > 0) {
          if (y > 240) { doc.addPage(); y = M; }
          doc.setFont("helvetica", "bold"); doc.text("Checklist", M, y); y += 5;
          doc.setFont("helvetica", "normal");
          checklistItems.forEach((it) => {
            doc.text(`${it.hecho ? "[X]" : "[ ]"} ${it.texto}`, M, y); y += 4.5;
            if (y > 280) { doc.addPage(); y = M; }
          });
          y += 2;
        }

        // Repuestos
        if (repuestos && repuestos.length > 0) {
          if (y > 240) { doc.addPage(); y = M; }
          doc.setFont("helvetica", "bold"); doc.text("Repuestos consumidos", M, y); y += 5;
          doc.setFontSize(8);
          doc.text("Item", M, y); doc.text("Cant.", 140, y); doc.text("Precio", 160, y); doc.text("Subt.", 185, y); y += 4;
          doc.setLineWidth(0.2); doc.line(M, y - 2, W - M, y - 2);
          doc.setFont("helvetica", "normal");
          repuestos.forEach((r) => {
            doc.text(`${r.codigo ?? ""} ${r.nombre ?? ""}`.slice(0, 60), M, y);
            doc.text(String(r.cantidad), 140, y);
            doc.text(r.precio != null ? `$${r.precio.toFixed(2)}` : "—", 160, y);
            doc.text(r.precio != null ? `$${(r.precio * r.cantidad).toFixed(2)}` : "—", 185, y);
            y += 4.5;
            if (y > 280) { doc.addPage(); y = M; }
          });
          if (totalRepuestos > 0) {
            doc.setFont("helvetica", "bold");
            doc.text(`Total: $${totalRepuestos.toFixed(2)}`, W - M, y, { align: "right" }); y += 6;
          }
          doc.setFontSize(9);
        }

        // Verificacion
        if (ordenData.verificacionNotas) {
          if (y > 250) { doc.addPage(); y = M; }
          doc.setFont("helvetica", "bold"); doc.text("Verificación", M, y); y += 5;
          doc.setFont("helvetica", "normal");
          const lines = doc.splitTextToSize(ordenData.verificacionNotas, W - M * 2);
          doc.text(lines, M, y); y += lines.length * 4 + 3;
        }

        // Imagenes (antes/despues) - max 4
        const imgs = adjs.filter(a => (a.categoria === "antes" || a.categoria === "despues") && a.contentType.startsWith("image/")).slice(0, 4);
        if (imgs.length > 0) {
          if (y > 200) { doc.addPage(); y = M; }
          doc.setFont("helvetica", "bold"); doc.text("Evidencia fotográfica", M, y); y += 5;
          for (let i = 0; i < imgs.length; i++) {
            const a = imgs[i];
            const dataUrl = await fetchImageAsDataURL(`/api/adjuntos/${a.id}`);
            if (!dataUrl) continue;
            try {
              const x = M + (i % 2) * 90;
              const yy = y + Math.floor(i / 2) * 65;
              if (yy + 60 > 280) { doc.addPage(); y = M; continue; }
              doc.addImage(dataUrl, "JPEG", x, yy, 80, 55);
              doc.setFont("helvetica", "normal"); doc.setFontSize(8);
              doc.text(`${a.categoria}: ${a.nombre.slice(0, 30)}`, x, yy + 60);
              doc.setFontSize(9);
            } catch {}
          }
          y += Math.ceil(imgs.length / 2) * 65 + 5;
        }

        // Firmas
        if (y > 220) { doc.addPage(); y = M; }
        doc.setFont("helvetica", "bold"); doc.setFontSize(10);
        doc.text("Firmas", M, y); y += 5;

        const firmas = [
          { rol: "tecnico", nombre: ordenData.firmaTecnicoNombre, r2: ordenData.firmaTecnicoR2, label: "Técnico" },
          { rol: "jefe", nombre: ordenData.firmaJefeNombre, r2: ordenData.firmaJefeR2, label: "Jefe / Supervisor" },
          { rol: "solicitante", nombre: ordenData.firmaSolicitanteNombre, r2: ordenData.firmaSolicitanteR2, label: "Solicitante" },
        ];
        const colW = (W - M * 2) / 3;
        for (let i = 0; i < firmas.length; i++) {
          const f = firmas[i];
          const x = M + i * colW;
          doc.setLineWidth(0.3); doc.rect(x, y, colW - 4, 35);
          if (f.r2) {
            const dataUrl = await fetchImageAsDataURL(`/api/firmas/${ordenData.id}/${f.rol}`);
            if (dataUrl) try { doc.addImage(dataUrl, "PNG", x + 2, y + 2, colW - 8, 22); } catch {}
          }
          doc.setFont("helvetica", "bold"); doc.setFontSize(8);
          doc.text(f.label, x + 2, y + 30);
          doc.setFont("helvetica", "normal"); doc.setFontSize(7);
          doc.text(f.nombre ?? "—", x + 2, y + 33);
        }
        y += 40;

        // Footer
        const pages = doc.internal.getNumberOfPages();
        for (let p = 1; p <= pages; p++) {
          doc.setPage(p);
          doc.setFontSize(7); doc.setTextColor(120);
          doc.text(`Generado ${new Date().toLocaleString("es")} · Página ${p}/${pages}`, W / 2, 290, { align: "center" });
        }

        doc.save(`OT-${ordenData.id}.pdf`);
      } catch (e) {
        console.error(e);
        alert("Error al generar PDF");
      }
      $("pdfBtn").disabled = false;
      $("pdfBtn").textContent = "📄 Descargar PDF";
    });
  </script>
</Layout>
