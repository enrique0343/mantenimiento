---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { planesMantenimiento, activos, usuarios, sucursales, ubicaciones, actividades, actividadCategorias } from "@/lib/schema";
import { eq, asc, and } from "drizzle-orm";
import { siguienteFecha, type Frecuencia } from "@/lib/frecuencias";
export const prerender = false;

const user = Astro.locals.user!;
const db = getDb(Astro);

// Técnicos solo ven planes/actividades asignados a ellos
const esTecnico = user.rol === "tecnico";

// 1) Planes preventivos por equipo
const planRows = await db
  .select({ p: planesMantenimiento, a: activos, u: usuarios, s: sucursales, ub: ubicaciones })
  .from(planesMantenimiento)
  .leftJoin(activos, eq(activos.id, planesMantenimiento.activoId))
  .leftJoin(usuarios, eq(usuarios.id, planesMantenimiento.asignadoA))
  .leftJoin(ubicaciones, eq(ubicaciones.id, activos.ubicacionId))
  .leftJoin(sucursales, eq(sucursales.id, ubicaciones.sucursalId))
  .where(esTecnico
    ? and(eq(planesMantenimiento.activo, true), eq(planesMantenimiento.asignadoA, user.id))
    : eq(planesMantenimiento.activo, true))
  .orderBy(asc(planesMantenimiento.proximaFecha));

// 2) Actividades recurrentes
const actRows = await db
  .select({ a: actividades, c: actividadCategorias, u: usuarios, s: sucursales, ub: ubicaciones })
  .from(actividades)
  .leftJoin(actividadCategorias, eq(actividadCategorias.id, actividades.categoriaId))
  .leftJoin(usuarios, eq(usuarios.id, actividades.asignadoA))
  .leftJoin(sucursales, eq(sucursales.id, actividades.sucursalId))
  .leftJoin(ubicaciones, eq(ubicaciones.id, actividades.ubicacionId))
  .where(esTecnico
    ? and(eq(actividades.activo, true), eq(actividades.asignadoA, user.id))
    : eq(actividades.activo, true))
  .orderBy(asc(actividades.proximaFecha));

// Unificar en un solo timeline
type Item = {
  tipo: "plan" | "actividad";
  id: number;
  titulo: string;
  fecha: string;
  frecuencia: string;
  link: string;
  contexto: string;
  sucursal: string | null;
  ubicacion: string | null;
  asignado: string | null;
  icono: string;
  yaGenerada: boolean;
};

const items: Item[] = [
  ...planRows.map((r): Item => ({
    tipo: "plan",
    id: r.p.id,
    titulo: r.p.titulo,
    fecha: r.p.proximaFecha,
    frecuencia: r.p.frecuencia,
    link: `/activos/${r.a?.id}`,
    contexto: r.a ? `${r.a.codigo} · ${r.a.nombre}` : "",
    sucursal: r.s?.nombre ?? null,
    ubicacion: r.ub?.nombre ?? r.a?.ubicacion ?? null,
    asignado: r.u?.nombre ?? null,
    icono: "🛠",
    yaGenerada: !!(r.p.ultimaGeneracion && r.p.ultimaGeneracion.slice(0, 10) >= r.p.proximaFecha),
  })),
  ...actRows.map((r): Item => ({
    tipo: "actividad",
    id: r.a.id,
    titulo: r.a.titulo,
    fecha: r.a.proximaFecha,
    frecuencia: r.a.frecuencia,
    link: `/actividades/${r.a.id}`,
    contexto: `${r.a.codigo}${r.c ? ` · ${r.c.nombre}` : ""}`,
    sucursal: r.s?.nombre ?? null,
    ubicacion: r.ub?.nombre ?? r.a.ubicacionDetalle ?? null,
    asignado: r.u?.nombre ?? null,
    icono: r.c?.icono ?? "📌",
    yaGenerada: !!(r.a.ultimaGeneracion && r.a.ultimaGeneracion.slice(0, 10) >= r.a.proximaFecha),
  })),
].sort((a, b) => a.fecha.localeCompare(b.fecha));

const puedeGenerar = user.rol === "admin" || user.rol === "jefe";

const hoy = new Date().toISOString().slice(0, 10);
const en7 = new Date(); en7.setDate(en7.getDate() + 7);
const en30 = new Date(); en30.setDate(en30.getDate() + 30);
const en7Str = en7.toISOString().slice(0, 10);
const en30Str = en30.toISOString().slice(0, 10);

const vencidos   = items.filter((r) => r.fecha <= hoy);
const proximos7  = items.filter((r) => r.fecha > hoy && r.fecha <= en7Str);
const proximos30 = items.filter((r) => r.fecha > en7Str && r.fecha <= en30Str);
const futuros    = items.filter((r) => r.fecha > en30Str);

const fmt = (s: string) => new Date(s).toLocaleDateString("es", { timeZone: "America/El_Salvador" });

// ─── Vista anual (12 meses) + detección de colisiones de equipos críticos ────
const hoyD = new Date();
const horizonStart = new Date(Date.UTC(hoyD.getUTCFullYear(), hoyD.getUTCMonth(), 1));
const horizonEnd = new Date(Date.UTC(hoyD.getUTCFullYear(), hoyD.getUTCMonth() + 12, 1));
const horizonStartStr = horizonStart.toISOString().slice(0, 10);
const horizonEndStr = horizonEnd.toISOString().slice(0, 10);

const meses = Array.from({ length: 12 }, (_, i) => {
  const d = new Date(Date.UTC(horizonStart.getUTCFullYear(), horizonStart.getUTCMonth() + i, 1));
  return {
    label: d.toLocaleDateString("es", { month: "short", timeZone: "UTC" }).replace(".", "") + " " + String(d.getUTCFullYear()).slice(2),
    ym: d.toISOString().slice(0, 7),
    total: 0,
    criticos: 0,
  };
});
const mesIndex = (fecha: string) => {
  const d = new Date(fecha);
  return (d.getUTCFullYear() - horizonStart.getUTCFullYear()) * 12 + (d.getUTCMonth() - horizonStart.getUTCMonth());
};

// Por semana (bucket de 7 días desde el inicio del horizonte): equipos críticos programados.
const semanas = new Map<number, Map<number, { codigo: string; nombre: string; fecha: string }>>();

function proyectar(fechaInicial: string, frecuencia: Frecuencia, onOcc: (fecha: string) => void) {
  let f = fechaInicial;
  let guard = 0;
  while (f < horizonStartStr && guard < 500) { const n = siguienteFecha(f, frecuencia); if (n <= f) return; f = n; guard++; }
  guard = 0;
  while (f < horizonEndStr && guard < 400) { onOcc(f); const n = siguienteFecha(f, frecuencia); if (n <= f) break; f = n; guard++; }
}

for (const r of planRows) {
  const crit = r.a?.criticidadOperacional === "alta";
  proyectar(r.p.proximaFecha, r.p.frecuencia as Frecuencia, (fecha) => {
    const mi = mesIndex(fecha);
    if (mi >= 0 && mi < 12) { meses[mi].total++; if (crit) meses[mi].criticos++; }
    if (crit && r.a) {
      const wk = Math.floor((new Date(fecha).getTime() - horizonStart.getTime()) / (7 * 86400_000));
      const m = semanas.get(wk) ?? new Map();
      if (!m.has(r.a.id)) m.set(r.a.id, { codigo: r.a.codigo, nombre: r.a.nombre, fecha });
      semanas.set(wk, m);
    }
  });
}
for (const r of actRows) {
  proyectar(r.a.proximaFecha, r.a.frecuencia as Frecuencia, (fecha) => {
    const mi = mesIndex(fecha);
    if (mi >= 0 && mi < 12) meses[mi].total++;
  });
}

const colisiones = [...semanas.entries()]
  .filter(([, m]) => m.size >= 2)
  .map(([wk, m]) => {
    const ini = new Date(horizonStart.getTime() + wk * 7 * 86400_000);
    const fin = new Date(ini.getTime() + 6 * 86400_000);
    return { ini: ini.toISOString().slice(0, 10), fin: fin.toISOString().slice(0, 10), equipos: [...m.values()] };
  })
  .sort((a, b) => a.ini.localeCompare(b.ini));
const mesesConColision = new Set(colisiones.map((c) => c.ini.slice(0, 7)));
const maxMes = Math.max(1, ...meses.map((m) => m.total));
---

<Layout title="Cronograma">
  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-2xl font-bold">Cronograma de mantenimiento</h1>
      <p class="mt-1 text-sm text-slate-500">{planRows.length} plan(es) por equipo · {actRows.length} actividad(es) recurrente(s)</p>
    </div>
    <div class="flex flex-wrap gap-2 text-sm">
      <a href="/actividades" class="btn-secondary">📌 Actividades</a>
      <a href="/planificador" class="btn-secondary">📊 Planificador</a>
      {(user.rol === "admin" || user.rol === "jefe") && (
        <a href="/planes" class="btn-secondary">🛠 Gestionar planes</a>
      )}
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    {[
      { titulo: "Vencidos",         items: vencidos,   color: "border-red-300 bg-red-50",    text: "text-red-700" },
      { titulo: "Próximos 7 días",  items: proximos7,  color: "border-amber-300 bg-amber-50", text: "text-amber-700" },
      { titulo: "Próximos 30 días", items: proximos30, color: "border-blue-300 bg-blue-50",   text: "text-blue-700" },
      { titulo: "Más adelante",     items: futuros,    color: "border-slate-200 bg-slate-50", text: "text-slate-600" },
    ].map((seccion) => (
      <div class={`card ${seccion.color} p-4`}>
        <h2 class={`font-semibold ${seccion.text}`}>{seccion.titulo} ({seccion.items.length})</h2>
        {seccion.items.length === 0 ? (
          <p class="mt-2 text-xs text-slate-500">Sin elementos en este rango.</p>
        ) : (
          <ul class="mt-3 space-y-2 text-sm">
            {seccion.items.map((r) => (
              <li class="rounded-md bg-white p-2 shadow-sm" data-item-tipo={r.tipo} data-item-id={r.id}>
                <div class="flex items-center justify-between gap-2">
                  <a href={r.link} class="font-medium text-brand-700 hover:underline">
                    {r.icono} {r.titulo}
                  </a>
                  <span class="text-xs font-semibold whitespace-nowrap">{fmt(r.fecha)}</span>
                </div>
                <div class="text-xs text-slate-700">
                  <span class="font-mono">{r.contexto}</span>
                  <span class:list={["ml-1 rounded px-1 py-0.5 text-[10px]", r.tipo === "plan" ? "bg-slate-100 text-slate-600" : "bg-purple-100 text-purple-700"]}>
                    {r.tipo === "plan" ? "Equipo" : "Actividad"}
                  </span>
                </div>
                {(r.sucursal || r.ubicacion) && (
                  <div class="text-xs text-slate-500">
                    {r.sucursal && <span>🏢 {r.sucursal}</span>}
                    {r.ubicacion && <span> · 📍 {r.ubicacion}</span>}
                  </div>
                )}
                <div class="text-xs text-slate-400 capitalize">
                  {r.frecuencia}
                  {r.asignado && ` · 👤 ${r.asignado}`}
                </div>
                {puedeGenerar && (
                  r.yaGenerada
                    ? <div class="mt-2 text-[11px] text-emerald-700 font-medium">✓ OT ya generada para este ciclo</div>
                    : <button class="generar-ot-btn mt-2 px-2 py-1 rounded bg-brand-600 text-white text-[11px] font-medium hover:bg-brand-700 disabled:opacity-50" data-tipo={r.tipo} data-id={r.id}>
                        ⚡ Generar OT ahora
                      </button>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>

  <!-- Vista anual -->
  <div class="card mt-6 p-5">
    <h2 class="font-semibold text-slate-900">📆 Vista anual de preventivos (12 meses)</h2>
    <p class="text-xs text-slate-500">Proyección de mantenimientos programados por mes. Barra roja = mes con colisión de equipos críticos.</p>
    <div class="mt-4 flex items-end gap-1.5 overflow-x-auto pb-2">
      {meses.map((m) => {
        const h = Math.round((m.total / maxMes) * 120);
        const colision = mesesConColision.has(m.ym);
        return (
          <div class="flex min-w-[44px] flex-1 flex-col items-center gap-1">
            <div class="flex w-full flex-col-reverse" style="height:120px">
              <div class:list={["mx-auto w-6 rounded-t", colision ? "bg-red-400" : "bg-brand-500"]} style={`height:${h}px`} title={`${m.total} programados · ${m.criticos} críticos`}></div>
            </div>
            <div class="text-[9px] capitalize whitespace-nowrap text-slate-500">{m.label}</div>
            <div class="font-mono text-[9px] text-slate-700">{m.total}{m.criticos > 0 && <span class="text-red-600"> ({m.criticos})</span>}</div>
          </div>
        );
      })}
    </div>
    <div class="mt-1 text-xs text-slate-500">Número total por mes · (n) = equipos críticos · proyectado desde la frecuencia de cada plan</div>
  </div>

  <!-- Colisiones de equipos críticos -->
  <div class="card mt-4 p-5">
    <h2 class="font-semibold text-slate-900">⚠ Colisiones de equipos críticos</h2>
    <p class="text-xs text-slate-500">Semanas con 2 o más equipos críticos programados a la vez — evita dejarlos fuera de servicio simultáneamente.</p>
    {colisiones.length === 0 ? (
      <p class="mt-3 text-sm text-emerald-700">✓ Sin colisiones detectadas en los próximos 12 meses.</p>
    ) : (
      <ul class="mt-3 space-y-2 text-sm">
        {colisiones.map((c) => (
          <li class="rounded-md border border-amber-300 bg-amber-50 p-3">
            <div class="font-medium text-amber-800">Semana {fmt(c.ini)} – {fmt(c.fin)} · {c.equipos.length} equipos críticos</div>
            <div class="mt-1 text-xs text-slate-700">{c.equipos.map((e) => `${e.codigo} (${fmt(e.fecha)})`).join("  ·  ")}</div>
          </li>
        ))}
      </ul>
    )}
  </div>

  {puedeGenerar && (
    <script>
      document.querySelectorAll<HTMLButtonElement>(".generar-ot-btn").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          e.preventDefault();
          const tipo = btn.dataset.tipo;
          const id = btn.dataset.id;
          const labelOriginal = btn.textContent;
          if (!confirm(`¿Generar OT ahora para este ${tipo === "plan" ? "plan" : "actividad"}?`)) return;
          btn.disabled = true;
          btn.textContent = "Generando...";
          const url = tipo === "plan" ? `/api/planes/${id}/generar-ot` : `/api/actividades/${id}/generar-ot`;
          const res = await fetch(url, { method: "POST" });
          const j = await res.json().catch(() => ({}));
          if (res.ok && j.orden) {
            // Redirige a la nueva OT
            location.href = `/ordenes/${j.orden.id}`;
          } else {
            alert("✗ " + (j.error ?? "Error al generar OT"));
            btn.disabled = false;
            btn.textContent = labelOriginal;
          }
        });
      });
    </script>
  )}
</Layout>
