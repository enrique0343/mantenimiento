---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { planesMantenimiento, activos, usuarios, sucursales, ubicaciones } from "@/lib/schema";
import { eq, asc } from "drizzle-orm";
export const prerender = false;

const db = getDb(Astro);
const rows = await db
  .select({ p: planesMantenimiento, a: activos, u: usuarios, s: sucursales, ub: ubicaciones })
  .from(planesMantenimiento)
  .leftJoin(activos, eq(activos.id, planesMantenimiento.activoId))
  .leftJoin(usuarios, eq(usuarios.id, planesMantenimiento.asignadoA))
  .leftJoin(ubicaciones, eq(ubicaciones.id, activos.ubicacionId))
  .leftJoin(sucursales, eq(sucursales.id, ubicaciones.sucursalId))
  .where(eq(planesMantenimiento.activo, true))
  .orderBy(asc(planesMantenimiento.proximaFecha));

const hoy = new Date().toISOString().slice(0, 10);
const en7 = new Date(); en7.setDate(en7.getDate() + 7);
const en30 = new Date(); en30.setDate(en30.getDate() + 30);
const en7Str = en7.toISOString().slice(0, 10);
const en30Str = en30.toISOString().slice(0, 10);

const vencidos = rows.filter((r) => r.p.proximaFecha <= hoy);
const proximos7 = rows.filter((r) => r.p.proximaFecha > hoy && r.p.proximaFecha <= en7Str);
const proximos30 = rows.filter((r) => r.p.proximaFecha > en7Str && r.p.proximaFecha <= en30Str);
const futuros = rows.filter((r) => r.p.proximaFecha > en30Str);

const fmt = (s: string) => new Date(s).toLocaleDateString("es");

const Section = ({ titulo, items, color }: any) => null;
---

<Layout title="Cronograma">
  <h1 class="text-2xl font-bold">Cronograma de mantenimiento</h1>
  <p class="mt-1 text-sm text-slate-500">{rows.length} plan(es) activo(s)</p>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    {[
      { titulo: "Vencidos", items: vencidos, color: "border-red-300 bg-red-50", text: "text-red-700" },
      { titulo: "Proximos 7 dias", items: proximos7, color: "border-amber-300 bg-amber-50", text: "text-amber-700" },
      { titulo: "Proximos 30 dias", items: proximos30, color: "border-blue-300 bg-blue-50", text: "text-blue-700" },
      { titulo: "Mas adelante", items: futuros, color: "border-slate-200 bg-slate-50", text: "text-slate-600" },
    ].map((seccion) => (
      <div class={`card ${seccion.color} p-4`}>
        <h2 class={`font-semibold ${seccion.text}`}>{seccion.titulo} ({seccion.items.length})</h2>
        {seccion.items.length === 0 ? (
          <p class="mt-2 text-xs text-slate-500">Sin planes en este rango.</p>
        ) : (
          <ul class="mt-3 space-y-2 text-sm">
            {seccion.items.map((r: any) => (
              <li class="rounded-md bg-white p-2 shadow-sm">
                <div class="flex items-center justify-between gap-2">
                  <a href={`/activos/${r.a?.id}`} class="font-medium text-brand-700 hover:underline">{r.p.titulo}</a>
                  <span class="text-xs font-semibold whitespace-nowrap">{fmt(r.p.proximaFecha)}</span>
                </div>
                <div class="text-xs text-slate-700">
                  <span class="font-mono">{r.a?.codigo}</span> · {r.a?.nombre}
                </div>
                {(r.s || r.ub || r.a?.ubicacion) && (
                  <div class="text-xs text-slate-500">
                    {r.s && <span>🏢 {r.s.nombre}</span>}
                    {r.ub && <span> · 📍 {r.ub.nombre}</span>}
                    {!r.ub && r.a?.ubicacion && <span> · 📍 {r.a.ubicacion}</span>}
                  </div>
                )}
                <div class="text-xs text-slate-400 capitalize">
                  {r.p.frecuencia}
                  {r.u && ` · 👤 ${r.u.nombre}`}
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>
</Layout>
