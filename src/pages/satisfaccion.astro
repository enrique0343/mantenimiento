---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { encuestasSatisfaccion, ordenes, usuarios } from "@/lib/schema";
import { eq, and, isNotNull, isNull, desc, asc, sql } from "drizzle-orm";
import { fmtFechaLarga, fmtFechaSimple } from "@/lib/datetime";
export const prerender = false;

const user = Astro.locals.user!;
if (user.rol !== "admin" && user.rol !== "jefe") return Astro.redirect("/");

const db = getDb(Astro);
const url = new URL(Astro.request.url);
const filtroTec = url.searchParams.get("tecnico");
const filtroCal = url.searchParams.get("cal");
const soloComentadas = url.searchParams.get("conComentario") === "1";
const soloNoLeidas = url.searchParams.get("noLeidas") === "1";

// Técnicos para filtro (cualquiera que tenga al menos una encuesta)
const tecnicos = await db
  .select({ id: usuarios.id, nombre: usuarios.nombre })
  .from(usuarios)
  .where(eq(usuarios.activo, true))
  .orderBy(asc(usuarios.nombre));

// Todas las encuestas respondidas
const conds: any[] = [isNotNull(encuestasSatisfaccion.respondidaEn)];
if (filtroTec) conds.push(eq(ordenes.asignadoA, Number(filtroTec)));
if (filtroCal) conds.push(eq(encuestasSatisfaccion.calificacion, Number(filtroCal)));

const rowsAll = await db
  .select({
    e: encuestasSatisfaccion,
    o: ordenes,
    tec: usuarios,
  })
  .from(encuestasSatisfaccion)
  .leftJoin(ordenes, eq(ordenes.id, encuestasSatisfaccion.ordenId))
  .leftJoin(usuarios, eq(usuarios.id, ordenes.asignadoA))
  .where(and(...conds))
  .orderBy(desc(encuestasSatisfaccion.respondidaEn));

let rows = rowsAll;
if (soloComentadas) rows = rows.filter((r) => (r.e.comentario ?? "").trim().length > 0);
if (soloNoLeidas) rows = rows.filter((r) => !r.e.leidaEn);

// Conteos para badge en filtros
const bajasSinLeer = rowsAll.filter((r) =>
  (r.e.calificacion ?? 5) <= 3 && (r.e.comentario ?? "").trim().length > 0 && !r.e.leidaEn
).length;

// Construir querystring para CSV manteniendo filtros activos
const csvParams = new URLSearchParams();
if (filtroTec) csvParams.set("tecnico", filtroTec);
if (filtroCal) csvParams.set("cal", filtroCal);

// KPIs (sobre el set filtrado por técnico/calificación pero sin el "solo comentadas")
const total = rowsAll.length;
const suma = rowsAll.reduce((s, r) => s + (r.e.calificacion ?? 0), 0);
const promedio = total > 0 ? suma / total : 0;
const conteoPorCal = [1, 2, 3, 4, 5].map((n) => ({
  n, count: rowsAll.filter((r) => r.e.calificacion === n).length,
}));
const pct5 = total > 0 ? Math.round((conteoPorCal[4].count / total) * 100) : 0;
const pctBajas = total > 0 ? Math.round(((conteoPorCal[0].count + conteoPorCal[1].count + conteoPorCal[2].count) / total) * 100) : 0;

// Encuestas pendientes (enviadas pero sin responder)
const pendRows = await db
  .select({ n: sql<number>`count(*)` })
  .from(encuestasSatisfaccion)
  .where(isNull(encuestasSatisfaccion.respondidaEn));
const pendientes = Number(pendRows[0]?.n ?? 0);

const STARS: Record<number, { emoji: string; label: string; color: string }> = {
  1: { emoji: "😞", label: "Pésimo",    color: "bg-red-100 text-red-700 border-red-200" },
  2: { emoji: "😕", label: "Malo",      color: "bg-orange-100 text-orange-700 border-orange-200" },
  3: { emoji: "😬", label: "Regular",   color: "bg-amber-100 text-amber-700 border-amber-200" },
  4: { emoji: "🙂", label: "Bueno",     color: "bg-lime-100 text-lime-700 border-lime-200" },
  5: { emoji: "😎", label: "Excelente", color: "bg-emerald-100 text-emerald-700 border-emerald-200" },
};

// Ranking de técnicos
type RankRow = { id: number; nombre: string; n: number; suma: number; promedio: number; pct5: number };
const ranking = new Map<number, RankRow>();
for (const r of rowsAll) {
  if (!r.tec) continue;
  const id = r.tec.id;
  const cur = ranking.get(id) ?? { id, nombre: r.tec.nombre, n: 0, suma: 0, promedio: 0, pct5: 0 };
  cur.n += 1;
  cur.suma += r.e.calificacion ?? 0;
  if (r.e.calificacion === 5) cur.pct5 += 1;
  ranking.set(id, cur);
}
const rankingList = Array.from(ranking.values())
  .map((r) => ({ ...r, promedio: r.suma / r.n, pct5: Math.round((r.pct5 / r.n) * 100) }))
  .sort((a, b) => b.promedio - a.promedio || b.n - a.n);
---

<Layout title="Encuestas de satisfacción">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold">⭐ Encuestas de satisfacción</h1>
      <p class="text-sm text-slate-500">{total} respondidas · {pendientes} pendientes{bajasSinLeer > 0 ? ` · ⚠ ${bajasSinLeer} bajas sin atender` : ""}</p>
    </div>
    <a href={`/api/encuestas/export?${csvParams.toString()}`} class="btn-secondary text-sm">⬇ Exportar CSV</a>
  </div>

  <!-- KPIs -->
  <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Promedio</div>
      <div class="mt-1 text-3xl font-bold text-slate-900">{promedio.toFixed(2)} <span class="text-sm font-normal text-slate-500">/5</span></div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">% Excelente (5⭐)</div>
      <div class="mt-1 text-3xl font-bold text-emerald-600">{pct5}%</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">% Bajas (1–3⭐)</div>
      <div class="mt-1 text-3xl font-bold text-red-600">{pctBajas}%</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Pendientes</div>
      <div class="mt-1 text-3xl font-bold text-amber-600">{pendientes}</div>
    </div>
  </div>

  <!-- Distribución -->
  <div class="card mt-4 p-4">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Distribución</h2>
    <div class="space-y-1.5">
      {[5, 4, 3, 2, 1].map((n) => {
        const { count } = conteoPorCal[n - 1];
        const pct = total > 0 ? Math.round((count / total) * 100) : 0;
        const s = STARS[n];
        return (
          <div class="flex items-center gap-2 text-sm">
            <span class="w-24 text-slate-600">{s.emoji} {s.label}</span>
            <div class="flex-1 h-3 rounded-full bg-slate-100 overflow-hidden">
              <div class={`h-full ${n >= 4 ? "bg-emerald-500" : n === 3 ? "bg-amber-500" : "bg-red-500"}`} style={`width:${pct}%`}></div>
            </div>
            <span class="w-16 text-right text-slate-500 text-xs">{count} ({pct}%)</span>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Ranking de técnicos -->
  {rankingList.length > 0 && (
    <div class="card mt-4 overflow-hidden">
      <h2 class="px-4 pt-4 pb-2 text-sm font-semibold text-slate-700">🏆 Ranking de técnicos</h2>
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase text-slate-500">
          <tr>
            <th class="px-4 py-2">#</th>
            <th class="px-4 py-2">Técnico</th>
            <th class="px-4 py-2 text-center">Encuestas</th>
            <th class="px-4 py-2 text-center">Promedio</th>
            <th class="px-4 py-2 text-center">% 5⭐</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {rankingList.map((r, i) => (
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 font-mono text-xs text-slate-400">{i + 1}</td>
              <td class="px-4 py-2 font-medium text-slate-900">{r.nombre}</td>
              <td class="px-4 py-2 text-center">{r.n}</td>
              <td class="px-4 py-2 text-center">
                <span class={`font-bold ${r.promedio >= 4.5 ? "text-emerald-600" : r.promedio >= 3.5 ? "text-amber-600" : "text-red-600"}`}>
                  {r.promedio.toFixed(2)}
                </span>
              </td>
              <td class="px-4 py-2 text-center text-slate-600">{r.pct5}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <!-- Filtros -->
  <form method="get" class="card mt-4 p-4 flex flex-wrap gap-3 items-end text-sm">
    <div>
      <label class="block text-xs font-semibold text-slate-600 mb-1">Técnico</label>
      <select name="tecnico" class="input text-sm">
        <option value="">Todos</option>
        {tecnicos.map((t) => <option value={t.id} selected={filtroTec === String(t.id)}>{t.nombre}</option>)}
      </select>
    </div>
    <div>
      <label class="block text-xs font-semibold text-slate-600 mb-1">Calificación</label>
      <select name="cal" class="input text-sm">
        <option value="">Todas</option>
        {[5, 4, 3, 2, 1].map((n) => <option value={n} selected={filtroCal === String(n)}>{n}⭐ {STARS[n].label}</option>)}
      </select>
    </div>
    <label class="flex items-center gap-2">
      <input type="checkbox" name="conComentario" value="1" checked={soloComentadas} />
      <span class="text-slate-700">Solo con comentario</span>
    </label>
    <label class="flex items-center gap-2">
      <input type="checkbox" name="noLeidas" value="1" checked={soloNoLeidas} />
      <span class="text-slate-700">Solo no leídas</span>
    </label>
    <button type="submit" class="btn-primary">Filtrar</button>
    {(filtroTec || filtroCal || soloComentadas || soloNoLeidas) && (
      <a href="/satisfaccion" class="btn-secondary">Limpiar</a>
    )}
  </form>

  <!-- Listado de respuestas -->
  <div class="card mt-4 overflow-hidden">
    <table class="w-full text-left text-sm hidden sm:table">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          <th class="px-4 py-2">Fecha</th>
          <th class="px-4 py-2">OT</th>
          <th class="px-4 py-2">Técnico</th>
          <th class="px-4 py-2">Evaluado por</th>
          <th class="px-4 py-2 text-center">Calificación</th>
          <th class="px-4 py-2">Comentario</th>
          <th class="px-4 py-2 text-center">Acción</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && (
          <tr><td colspan="7" class="px-4 py-8 text-center text-slate-400">Sin respuestas con esos filtros.</td></tr>
        )}
        {rows.map(({ e, o, tec }) => {
          const s = STARS[e.calificacion ?? 0] ?? { emoji: "—", label: "—", color: "bg-slate-100 text-slate-500 border-slate-200" };
          const esBaja = e.calificacion && e.calificacion <= 3;
          return (
            <tr class:list={["hover:bg-slate-50", esBaja && !e.leidaEn ? "bg-red-50/40" : ""]}>
              <td class="px-4 py-2 text-xs text-slate-500 whitespace-nowrap">{fmtFechaSimple(e.respondidaEn)}</td>
              <td class="px-4 py-2">
                {o ? <a href={`/ordenes/${o.id}`} class="text-brand-600 hover:underline">#{o.id} — {o.titulo}</a> : <span class="text-slate-400">—</span>}
              </td>
              <td class="px-4 py-2 text-slate-700">{tec?.nombre ?? <span class="text-slate-400">—</span>}</td>
              <td class="px-4 py-2">
                <div class="font-medium text-slate-800">{e.destinatarioNombre ?? "—"}</div>
                <div class="text-xs text-slate-400">{e.destinatarioEmail}</div>
              </td>
              <td class="px-4 py-2 text-center">
                <span class={`inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-xs font-medium ${s.color}`}>
                  {s.emoji} {e.calificacion ?? "—"}/5
                </span>
              </td>
              <td class="px-4 py-2 text-slate-700 max-w-xl">
                {e.comentario ? <p class="whitespace-pre-wrap">{e.comentario}</p> : <span class="text-slate-300 text-xs italic">sin comentario</span>}
                {e.respuestaJefe && (
                  <div class="mt-2 rounded border-l-2 border-blue-400 bg-blue-50 p-2 text-xs text-slate-700">
                    <div class="font-semibold text-blue-800">Respuesta del jefe:</div>
                    <p class="whitespace-pre-wrap">{e.respuestaJefe}</p>
                  </div>
                )}
              </td>
              <td class="px-4 py-2 text-center whitespace-nowrap">
                {e.leidaEn ? (
                  <button type="button" class="text-xs text-emerald-700 hover:underline btn-atender"
                          data-token={e.token} data-comentario={e.respuestaJefe ?? ""} data-leida="1">
                    ✓ Atendida
                  </button>
                ) : (
                  <button type="button" class="text-xs text-amber-700 hover:underline btn-atender"
                          data-token={e.token} data-comentario={e.respuestaJefe ?? ""} data-leida="0">
                    Atender
                  </button>
                )}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <!-- Móvil: cards -->
    <div class="sm:hidden divide-y divide-slate-100">
      {rows.length === 0 && <div class="p-6 text-center text-slate-400">Sin respuestas con esos filtros.</div>}
      {rows.map(({ e, o, tec }) => {
        const s = STARS[e.calificacion ?? 0] ?? { emoji: "—", label: "—", color: "bg-slate-100 text-slate-500 border-slate-200" };
        return (
          <div class="p-4">
            <div class="flex items-start justify-between gap-2">
              <span class={`inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-xs font-medium ${s.color}`}>
                {s.emoji} {e.calificacion ?? "—"}/5
              </span>
              <span class="text-xs text-slate-400">{fmtFechaSimple(e.respondidaEn)}</span>
            </div>
            <div class="mt-2 text-sm">
              {o ? <a href={`/ordenes/${o.id}`} class="font-medium text-brand-600">#{o.id} — {o.titulo}</a> : <span class="text-slate-400">—</span>}
            </div>
            <div class="mt-1 text-xs text-slate-500">
              Técnico: <span class="font-medium text-slate-700">{tec?.nombre ?? "—"}</span> · Evaluó: <span class="font-medium text-slate-700">{e.destinatarioNombre ?? "—"}</span>
            </div>
            {e.comentario && (
              <p class="mt-2 rounded-md bg-slate-50 p-2 text-sm text-slate-700 whitespace-pre-wrap">{e.comentario}</p>
            )}
            {e.respuestaJefe && (
              <div class="mt-2 rounded border-l-2 border-blue-400 bg-blue-50 p-2 text-xs text-slate-700">
                <div class="font-semibold text-blue-800">Respuesta del jefe:</div>
                <p class="whitespace-pre-wrap">{e.respuestaJefe}</p>
              </div>
            )}
            <button type="button" class="mt-2 text-xs btn-atender" data-token={e.token} data-comentario={e.respuestaJefe ?? ""} data-leida={e.leidaEn ? "1" : "0"}>
              {e.leidaEn ? "✓ Atendida — editar" : "📝 Atender"}
            </button>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Modal atender encuesta -->
  <div id="modalAtender" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md">
      <div class="p-5">
        <h3 class="text-lg font-bold text-slate-900">Atender encuesta</h3>
        <p class="mt-1 text-xs text-slate-500">Registra qué acción tomaste (opcional). Marcarla como atendida la saca del filtro de "no leídas".</p>
        <textarea id="modalRespuesta" class="input mt-3 w-full" rows="4" placeholder="Ej: Hablé con el técnico, le indicamos que en próximos servicios..."></textarea>
        <div class="mt-4 flex justify-between gap-2">
          <button type="button" id="modalDesmarcar" class="text-xs text-slate-500 hover:underline hidden">Desmarcar como atendida</button>
          <div class="flex gap-2 ml-auto">
            <button type="button" id="modalCancelar" class="btn-secondary text-sm">Cancelar</button>
            <button type="button" id="modalGuardar" class="btn-primary text-sm">Guardar y marcar atendida</button>
          </div>
        </div>
        <p id="modalError" class="hidden mt-2 text-xs text-red-600"></p>
      </div>
    </div>
  </div>

  <script>
    let tokenActivo = null;
    const modal = document.getElementById("modalAtender");
    const ta = document.getElementById("modalRespuesta");
    const btnDesmarcar = document.getElementById("modalDesmarcar");
    const errBox = document.getElementById("modalError");

    function abrir(token, comentarioActual, yaLeida) {
      tokenActivo = token;
      ta.value = comentarioActual || "";
      btnDesmarcar.classList.toggle("hidden", !yaLeida);
      errBox.classList.add("hidden");
      modal.classList.remove("hidden");
      ta.focus();
    }
    function cerrar() { modal.classList.add("hidden"); tokenActivo = null; }

    document.querySelectorAll(".btn-atender").forEach((btn) => {
      btn.addEventListener("click", () => {
        abrir(btn.dataset.token, btn.dataset.comentario, btn.dataset.leida === "1");
      });
    });
    document.getElementById("modalCancelar")?.addEventListener("click", cerrar);
    modal?.addEventListener("click", (e) => { if (e.target === modal) cerrar(); });

    document.getElementById("modalGuardar")?.addEventListener("click", async () => {
      if (!tokenActivo) return;
      const res = await fetch(`/api/encuestas/${tokenActivo}/seguimiento`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ leida: true, respuestaJefe: ta.value.trim() || null }),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        errBox.textContent = typeof j.error === "string" ? j.error : "Error al guardar";
        errBox.classList.remove("hidden");
        return;
      }
      location.reload();
    });

    btnDesmarcar?.addEventListener("click", async () => {
      if (!tokenActivo) return;
      const res = await fetch(`/api/encuestas/${tokenActivo}/seguimiento`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ leida: false }),
      });
      if (res.ok) location.reload();
    });
  </script>
</Layout>
