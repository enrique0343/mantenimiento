---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { solicitudesCompra, usuarios, ordenes } from "@/lib/schema";
import { desc, eq } from "drizzle-orm";
export const prerender = false;

const user = Astro.locals.user!;
if (!["admin", "jefe", "tecnico"].includes(user.rol)) return Astro.redirect("/");

const db = getDb(Astro);
const rows = await db
  .select({ s: solicitudesCompra, u: usuarios, o: ordenes })
  .from(solicitudesCompra)
  .leftJoin(usuarios, eq(usuarios.id, solicitudesCompra.creadoPor))
  .leftJoin(ordenes, eq(ordenes.id, solicitudesCompra.ordenId))
  .where(user.rol === "tecnico" ? eq(solicitudesCompra.creadoPor, user.id) : undefined)
  .orderBy(desc(solicitudesCompra.id));

const ESTADO_COLOR: Record<string, string> = {
  borrador: "bg-slate-100 text-slate-600",
  enviada:  "bg-blue-100 text-blue-700",
  comprada: "bg-emerald-100 text-emerald-700",
  rechazada:"bg-red-100 text-red-700",
  cancelada:"bg-slate-200 text-slate-500",
};
const ESTADO_LABEL: Record<string, string> = {
  borrador: "Borrador",
  enviada:  "Enviada",
  comprada: "Comprada",
  rechazada:"Rechazada",
  cancelada:"Cancelada",
};
---

<Layout title="Solicitudes de Compra">
  <div class="flex items-center justify-between gap-2 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold">Solicitudes de Compra</h1>
      <p class="text-sm text-slate-500">Gestión de compras de contingencia y materiales</p>
    </div>
    <a href="/solicitudes-compra/nueva" class="btn-primary">+ Nueva solicitud</a>
  </div>

  <!-- Filtro estado -->
  <div class="mt-4 flex flex-wrap gap-2" id="filtros">
    {["todos","borrador","enviada","comprada","rechazada","cancelada"].map((f) => (
      <button data-f={f} class:list={["filtro-btn px-3 py-1 rounded-full text-xs font-medium border transition", f === "todos" ? "bg-brand-600 text-white border-brand-600" : "bg-white text-slate-600 border-slate-300 hover:bg-slate-50"]}>
        {f === "todos" ? "Todos" : ESTADO_LABEL[f]}
      </button>
    ))}
  </div>

  <div class="mt-4 space-y-2" id="lista">
    {rows.map(({ s, u, o }) => (
      <a href={`/solicitudes-compra/${s.id}`}
         data-estado={s.estado}
         class="card flex items-start gap-3 p-3 hover:shadow-md transition-shadow no-underline">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="font-mono text-xs text-slate-500">{s.codigo}</span>
            <span class:list={["badge text-xs px-2 py-0.5 rounded-full font-medium", ESTADO_COLOR[s.estado]]}>
              {ESTADO_LABEL[s.estado]}
            </span>
            {o && <span class="text-xs text-slate-400">OT #{o.id}</span>}
          </div>
          <p class="mt-1 font-medium text-slate-900 truncate">{s.titulo}</p>
          {s.descripcion && <p class="text-xs text-slate-500 line-clamp-1 mt-0.5">{s.descripcion}</p>}
        </div>
        <div class="text-right shrink-0">
          <p class="text-xs text-slate-400">{new Date(s.createdAt).toLocaleDateString("es", { timeZone: "America/El_Salvador" })}</p>
          <p class="text-xs text-slate-500">{u?.nombre ?? "—"}</p>
        </div>
      </a>
    ))}
    {rows.length === 0 && (
      <div class="card p-8 text-center text-slate-400">
        <p class="text-4xl mb-2">🛒</p>
        <p>No hay solicitudes de compra aún.</p>
        <a href="/solicitudes-compra/nueva" class="mt-3 inline-block text-sm text-brand-600 hover:underline">Crear primera solicitud →</a>
      </div>
    )}
  </div>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>(".filtro-btn");
  const items = document.querySelectorAll<HTMLElement>("[data-estado]");
  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      btns.forEach((b) => { b.className = b.className.replace("bg-brand-600 text-white border-brand-600", "bg-white text-slate-600 border-slate-300 hover:bg-slate-50"); });
      btn.className = btn.className.replace("bg-white text-slate-600 border-slate-300 hover:bg-slate-50", "bg-brand-600 text-white border-brand-600");
      const f = btn.dataset.f!;
      items.forEach((el) => {
        el.style.display = (f === "todos" || el.dataset.estado === f) ? "" : "none";
      });
    });
  });
</script>
