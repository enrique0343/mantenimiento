---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { ordenes, activos, planesMantenimiento, encuestasSatisfaccion, contratosMantenimiento, proveedores, ubicaciones, sucursales } from "@/lib/schema";
import { sql, eq, and, lte, gte, asc, isNotNull, inArray, desc } from "drizzle-orm";
import { diasParaVencer } from "@/lib/contratos";
import { fmtFechaSoloCompacta } from "@/lib/datetime";
export const prerender = false;

// Tecnico y Motorista → su panel personal
const user = Astro.locals.user;
if (user?.rol === "tecnico" || user?.rol === "motorista") return Astro.redirect("/mi-panel");

const db = getDb(Astro);

const ordenesPorEstado = await db
  .select({ estado: ordenes.estado, n: sql<number>`count(*)` })
  .from(ordenes)
  .groupBy(ordenes.estado);

const activosPorEstado = await db
  .select({ estado: activos.estado, n: sql<number>`count(*)` })
  .from(activos)
  .groupBy(activos.estado);

const vencidas = await db
  .select({ n: sql<number>`count(*)` })
  .from(ordenes)
  .where(
    sql`${ordenes.vencimiento} IS NOT NULL AND ${ordenes.vencimiento} < datetime('now') AND ${ordenes.estado} IN ('abierta','en_proceso')`
  );

const hoy = new Date().toISOString().slice(0, 10);
const en14 = new Date(); en14.setDate(en14.getDate() + 14);
const en14Str = en14.toISOString().slice(0, 10);

const proximos = await db
  .select({
    p: planesMantenimiento,
    a: activos,
    ub: ubicaciones,
    suc: sucursales,
  })
  .from(planesMantenimiento)
  .leftJoin(activos, eq(activos.id, planesMantenimiento.activoId))
  .leftJoin(ubicaciones, eq(ubicaciones.id, activos.ubicacionId))
  .leftJoin(sucursales, eq(sucursales.id, ubicaciones.sucursalId))
  .where(and(eq(planesMantenimiento.activo, true), lte(planesMantenimiento.proximaFecha, en14Str)))
  .orderBy(asc(planesMantenimiento.proximaFecha))
  .limit(10);

const proximosConVencido = proximos.map((r) => ({
  ...r,
  venc: r.p.proximaFecha <= hoy,
}));

const total = (rows: { estado: string; n: number }[]) => rows.reduce((s, r) => s + Number(r.n), 0);
const get = (rows: { estado: string; n: number }[], k: string) =>
  Number(rows.find((r) => r.estado === k)?.n ?? 0);

// KPI de satisfacción (encuestas respondidas)
const [satRow] = await db
  .select({
    n: sql<number>`COUNT(*)`,
    avg: sql<number>`AVG(${encuestasSatisfaccion.calificacion})`,
  })
  .from(encuestasSatisfaccion)
  .where(isNotNull(encuestasSatisfaccion.respondidaEn));

const [satEnviadas] = await db
  .select({ n: sql<number>`COUNT(*)` })
  .from(encuestasSatisfaccion);

const satN = Number(satRow?.n ?? 0);
const satAvg = satRow?.avg != null ? Number(satRow.avg) : null;
const satEnv = Number(satEnviadas?.n ?? 0);
const satTasa = satEnv > 0 ? Math.round((satN / satEnv) * 100) : 0;

const fmt = (s: string) => fmtFechaSoloCompacta(s);

// Contratos próximos a vencer (próximos 90 días)
const limite90d = new Date(Date.now() + 90 * 86400_000).toISOString().slice(0, 10);
const contratosProximosRaw = await db
  .select({ c: contratosMantenimiento, prov: proveedores })
  .from(contratosMantenimiento)
  .leftJoin(proveedores, eq(proveedores.id, contratosMantenimiento.proveedorId))
  .where(and(
    inArray(contratosMantenimiento.estado, ["vigente", "por_vencer"]),
    lte(contratosMantenimiento.fechaFin, limite90d),
    gte(contratosMantenimiento.fechaFin, hoy),
  ))
  .orderBy(asc(contratosMantenimiento.fechaFin))
  .limit(5);
const contratosProximos = contratosProximosRaw.map(({ c, prov }) => {
  const d = diasParaVencer(c.fechaFin);
  const color = d > 60 ? "text-amber-600" : d > 30 ? "text-orange-600" : "text-red-600";
  const diasLabel = d === 0 ? "Vence hoy" : `${d} día${d === 1 ? "" : "s"}`;
  return { c, prov, d, color, diasLabel };
});
---

<Layout title="Dashboard">
  <h1 class="text-2xl font-bold text-slate-900">Dashboard</h1>
  <p class="mt-1 text-sm text-slate-500">Resumen del estado del sistema</p>

  <div class="mt-6 grid grid-cols-2 gap-4 lg:grid-cols-5">
    <div class="card p-4">
      <div class="text-xs font-medium uppercase text-slate-500">Ordenes abiertas</div>
      <div class="mt-2 text-3xl font-bold text-brand-600">{get(ordenesPorEstado, "abierta")}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs font-medium uppercase text-slate-500">En proceso</div>
      <div class="mt-2 text-3xl font-bold text-amber-600">{get(ordenesPorEstado, "en_proceso")}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs font-medium uppercase text-slate-500">Completadas</div>
      <div class="mt-2 text-3xl font-bold text-emerald-600">{get(ordenesPorEstado, "completada")}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs font-medium uppercase text-slate-500">Vencidas</div>
      <div class="mt-2 text-3xl font-bold text-red-600">{vencidas[0]?.n ?? 0}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs font-medium uppercase text-slate-500">Satisfacción</div>
      {satAvg != null ? (
        <>
          <div class="mt-2 text-3xl font-bold text-violet-600">{satAvg.toFixed(1)}<span class="text-base text-slate-400">/5</span></div>
          <div class="mt-0.5 text-xs text-slate-500">{satN} de {satEnv} respondieron ({satTasa}%)</div>
        </>
      ) : (
        <>
          <div class="mt-2 text-2xl font-bold text-slate-300">—</div>
          <div class="mt-0.5 text-xs text-slate-500">Sin encuestas aún</div>
        </>
      )}
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Proximos mantenimientos preventivos</h2>
      <p class="text-xs text-slate-500">Planes con vencimiento en los proximos 14 dias</p>
      <ul class="mt-3 space-y-2 text-sm">
        {proximosConVencido.length === 0 && <li class="text-slate-500">Sin planes proximos a vencer.</li>}
        {proximosConVencido.map((r) => (
          <li class="flex items-center justify-between gap-3 rounded-md bg-slate-50 px-3 py-2">
            <div class="min-w-0">
              <a href={`/activos/${r.a?.id}`} class="font-medium text-brand-700 hover:underline">{r.p.titulo}</a>
              <div class="text-xs text-slate-500 truncate">{r.a?.codigo} · {r.a?.nombre}</div>
              {(r.suc?.nombre || r.ub?.nombre) && (
                <div class="text-xs text-slate-400 truncate">
                  {r.suc?.nombre ?? "Sin sede"}{r.ub?.nombre ? ` · ${r.ub.nombre}` : ""}
                </div>
              )}
            </div>
            <span class={`badge shrink-0 ${r.venc ? "bg-red-100 text-red-700" : "bg-amber-100 text-amber-700"}`}>{fmt(r.p.proximaFecha)}</span>
          </li>
        ))}
      </ul>
      <div class="mt-4">
        <a class="btn-secondary" href="/cronograma">Ver cronograma completo</a>
      </div>
    </div>

    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Equipos ({total(activosPorEstado)})</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {activosPorEstado.length === 0 && <li class="text-slate-500">Sin equipos aun.</li>}
        {activosPorEstado.map((r) => (
          <li class="flex justify-between">
            <span class="capitalize">{r.estado}</span>
            <span class="font-semibold">{r.n}</span>
          </li>
        ))}
      </ul>
      <div class="mt-4 flex gap-2">
        <a class="btn-primary" href="/ordenes/nueva">Nueva orden</a>
        <a class="btn-secondary" href="/activos">Ver equipos</a>
      </div>
    </div>
  </div>

  {contratosProximos.length > 0 && (
    <div class="card mt-6 p-5">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900">📜 Contratos próximos a vencer</h2>
        <a href="/contratos?proximos=90" class="text-sm text-brand-600 hover:underline">Ver todos →</a>
      </div>
      <ul class="mt-3 divide-y divide-slate-100 text-sm">
        {contratosProximos.map(({ c, prov, color, diasLabel }) => (
          <li class="flex items-center justify-between gap-2 py-2">
            <a href={`/contratos/${c.id}`} class="text-brand-600 hover:underline">
              <span class="font-mono text-xs text-slate-400 mr-2">{c.codigo}</span>
              <span class="font-medium text-slate-900">{c.nombre}</span>
            </a>
            <div class="text-right">
              <div class={`text-xs font-semibold ${color}`}>{diasLabel}</div>
              <div class="text-[10px] text-slate-500">{prov?.nombre ?? "—"}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  )}
</Layout>
