---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { ordenes, activos, ordenRepuestos, items as itemsTable, usuarios, encuestasSatisfaccion, metricasKpi } from "@/lib/schema";
import { eq, and, sql, isNotNull, desc, gte, inArray } from "drizzle-orm";
import { SCOPES, SCOPE_LABEL, ultimosPeriodos } from "@/lib/metricas";
export const prerender = false;

const user = Astro.locals.user!;
if (user.rol !== "admin" && user.rol !== "jefe") return Astro.redirect("/");
const esAdmin = user.rol === "admin";

const db = getDb(Astro);
const now = new Date();
const inicioAno = new Date(now.getFullYear(), 0, 1).toISOString().slice(0, 10);
const inicio30d = new Date(Date.now() - 30 * 86400_000).toISOString().slice(0, 10);

// Total OTs y por estado
const totalesEstado = await db
  .select({ estado: ordenes.estado, n: sql<number>`count(*)` })
  .from(ordenes)
  .groupBy(ordenes.estado);
const total = totalesEstado.reduce((s, r) => s + Number(r.n), 0);
const get = (estado: string) => Number(totalesEstado.find((r) => r.estado === estado)?.n ?? 0);

// OTs vencidas (sin cerrar y vencimiento pasado)
const vencidasRows = await db
  .select({ n: sql<number>`count(*)` })
  .from(ordenes)
  .where(sql`${ordenes.vencimiento} IS NOT NULL AND ${ordenes.vencimiento} < datetime('now') AND ${ordenes.estado} IN ('abierta','en_proceso','completada')`);
const vencidas = Number(vencidasRows[0]?.n ?? 0);

// % cumplimiento SLA: completadas a tiempo / total completadas con vencimiento
const slaRows = await db
  .select({
    total: sql<number>`COUNT(*)`,
    aTiempo: sql<number>`SUM(CASE WHEN ${ordenes.completadaEn} <= ${ordenes.vencimiento} THEN 1 ELSE 0 END)`,
  })
  .from(ordenes)
  .where(and(
    isNotNull(ordenes.completadaEn),
    isNotNull(ordenes.vencimiento),
    gte(ordenes.completadaEn, inicio30d),
  ));
const slaTotal = Number(slaRows[0]?.total ?? 0);
const slaATiempo = Number(slaRows[0]?.aTiempo ?? 0);
const cumplimientoSla = slaTotal > 0 ? (slaATiempo / slaTotal) * 100 : 100;

// OTs por tipo
const porTipo = await db
  .select({ tipo: ordenes.tipo, n: sql<number>`count(*)` })
  .from(ordenes)
  .groupBy(ordenes.tipo);

// MTTR (30d): tiempo promedio creación → completada
const completadas30d = await db
  .select({ createdAt: ordenes.createdAt, completadaEn: ordenes.completadaEn })
  .from(ordenes)
  .where(and(gte(ordenes.completadaEn, inicio30d), isNotNull(ordenes.completadaEn)));
let mttrHoras = 0;
if (completadas30d.length > 0) {
  const totalMs = completadas30d.reduce((s, r) => {
    const a = new Date(r.createdAt).getTime();
    const b = r.completadaEn ? new Date(r.completadaEn).getTime() : a;
    return s + Math.max(b - a, 0);
  }, 0);
  mttrHoras = totalMs / completadas30d.length / 3_600_000;
}

// MTBF aproximado
const correctivos30dRows = await db
  .select({ n: sql<number>`count(*)` })
  .from(ordenes)
  .where(and(eq(ordenes.tipo, "correctivo"), gte(ordenes.createdAt, inicio30d)));
const correctivos30d = Number(correctivos30dRows[0]?.n ?? 0);
const mtbfHoras = correctivos30d > 0 ? (30 * 24) / correctivos30d : 0;

// Top 10 equipos con más correctivos en el año
const topEquipos = await db
  .select({
    activoId: ordenes.activoId,
    codigo: activos.codigo,
    nombre: activos.nombre,
    n: sql<number>`count(*)`,
  })
  .from(ordenes)
  .leftJoin(activos, eq(activos.id, ordenes.activoId))
  .where(and(eq(ordenes.tipo, "correctivo"), gte(ordenes.createdAt, inicioAno), isNotNull(ordenes.activoId)))
  .groupBy(ordenes.activoId)
  .orderBy(desc(sql`count(*)`))
  .limit(10);

// Top 10 técnicos por OTs completadas en el año
const topTecnicos = await db
  .select({
    tecnicoId: ordenes.asignadoA,
    nombre: usuarios.nombre,
    completadas: sql<number>`COUNT(*)`,
    horas: sql<number>`SUM(COALESCE(${ordenes.horasTrabajadas}, 0))`,
    aTiempo: sql<number>`SUM(CASE WHEN ${ordenes.vencimiento} IS NOT NULL AND ${ordenes.completadaEn} <= ${ordenes.vencimiento} THEN 1 ELSE 0 END)`,
    conSla: sql<number>`SUM(CASE WHEN ${ordenes.vencimiento} IS NOT NULL THEN 1 ELSE 0 END)`,
  })
  .from(ordenes)
  .leftJoin(usuarios, eq(usuarios.id, ordenes.asignadoA))
  .where(and(isNotNull(ordenes.asignadoA), isNotNull(ordenes.completadaEn), gte(ordenes.completadaEn, inicioAno)))
  .groupBy(ordenes.asignadoA)
  .orderBy(desc(sql`COUNT(*)`))
  .limit(10);

// Disponibilidad estimada
const totalActivos = (await db.select({ n: sql<number>`count(*)` }).from(activos))[0]?.n ?? 0;
const operativos = (await db.select({ n: sql<number>`count(*)` }).from(activos).where(eq(activos.estado, "operativo")))[0]?.n ?? 0;
const disponibilidad = totalActivos > 0 ? (Number(operativos) / Number(totalActivos)) * 100 : 0;

// Costo estimado de repuestos en el año
const costoRepRows = await db
  .select({
    total: sql<number>`SUM(${ordenRepuestos.cantidad} * COALESCE(${ordenRepuestos.precioUnitario}, ${itemsTable.precioReferencia}, 0))`,
  })
  .from(ordenRepuestos)
  .leftJoin(itemsTable, eq(itemsTable.id, ordenRepuestos.itemId))
  .where(gte(ordenRepuestos.createdAt, inicioAno));
const costoTotal = Number(costoRepRows[0]?.total ?? 0);

// Satisfacción
const [satRow] = await db
  .select({
    n: sql<number>`COUNT(*)`,
    avg: sql<number>`AVG(${encuestasSatisfaccion.calificacion})`,
  })
  .from(encuestasSatisfaccion)
  .where(isNotNull(encuestasSatisfaccion.respondidaEn));
const satN = Number(satRow?.n ?? 0);
const satAvg = satRow?.avg != null ? Number(satRow.avg) : null;

// Tendencia mensual (últimos 12 meses): completadas y correctivas
const tendencia: { mes: string; completadas: number; correctivas: number }[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const inicio = d.toISOString().slice(0, 10);
  const fin = new Date(d.getFullYear(), d.getMonth() + 1, 1).toISOString().slice(0, 10);
  const [completadas] = await db
    .select({ n: sql<number>`COUNT(*)` })
    .from(ordenes)
    .where(and(gte(ordenes.completadaEn, inicio), sql`${ordenes.completadaEn} < ${fin}`));
  const [correctivas] = await db
    .select({ n: sql<number>`COUNT(*)` })
    .from(ordenes)
    .where(and(eq(ordenes.tipo, "correctivo"), gte(ordenes.createdAt, inicio), sql`${ordenes.createdAt} < ${fin}`));
  const mesEs = d.toLocaleDateString("es", { month: "short", timeZone: "America/El_Salvador" }).replace(".", "");
  tendencia.push({
    mes: `${mesEs} ${String(d.getFullYear()).slice(2)}`,
    completadas: Number(completadas?.n ?? 0),
    correctivas: Number(correctivas?.n ?? 0),
  });
}
const maxTendencia = Math.max(1, ...tendencia.map((t) => Math.max(t.completadas, t.correctivas)));

const TIPO_LABEL = { preventivo: "Preventivo", correctivo: "Correctivo", predictivo: "Predictivo" };
function pct(n: number) { return Math.round(n * 100) / 100; }
function fmtH(h: number) { return h < 1 ? `${(h * 60).toFixed(0)} min` : `${pct(h)} h`; }

// ─── Indicadores JCI persistidos (Fase 36): tendencia documentada ────────────
const periodos12 = ultimosPeriodos(12);
const metricasRows = await db.select().from(metricasKpi).where(inArray(metricasKpi.periodo, periodos12));
const serie: Record<string, Record<string, typeof metricasRows[number]>> = { global: {}, general: {}, biomedico: {} };
for (const r of metricasRows) { (serie[r.scope] ??= {})[r.periodo] = r; }
const hayMetricas = metricasRows.length > 0;
const periodosConDatos = periodos12.filter((p) => metricasRows.some((r) => r.periodo === p));
const ultimoPeriodo = periodosConDatos[periodosConDatos.length - 1] ?? null;
const metricasJson = JSON.stringify({ periodos: periodos12, serie });

function mesLabel(periodo: string): string {
  const [y, m] = periodo.split("-").map(Number);
  const d = new Date(Date.UTC(y, m - 1, 1));
  return d.toLocaleDateString("es", { month: "short", timeZone: "UTC" }).replace(".", "") + " " + String(y).slice(2);
}
function fmtKpiH(h: number | null): string {
  if (h == null) return "—";
  if (h >= 48) return `${(h / 24).toFixed(1)} d`;
  return h < 1 ? `${(h * 60).toFixed(0)} min` : `${h.toFixed(1)} h`;
}
function colorPct(v: number | null, bueno: number, regular: number): string {
  if (v == null) return "text-slate-300";
  return v >= bueno ? "text-emerald-600" : v >= regular ? "text-amber-600" : "text-red-600";
}
// Definición de los 6 indicadores para la tabla de tendencia.
const KPIS_DEF = [
  { key: "cumplimientoPreventivo", label: "Cumplimiento preventivo", fmt: (v: any) => v == null ? "—" : `${pct(v)}%` },
  { key: "disponibilidadPct", label: "Disponibilidad", fmt: (v: any) => v == null ? "—" : `${pct(v)}%` },
  { key: "mttrHoras", label: "MTTR", fmt: fmtKpiH },
  { key: "mtbfHoras", label: "MTBF", fmt: fmtKpiH },
  { key: "backlogCorrectivos", label: "Backlog correctivos", fmt: (v: any) => v == null ? "—" : String(v) },
  { key: "costoPorActivo", label: "Costo por activo", fmt: (v: any) => v == null ? "—" : `$${Number(v).toFixed(2)}` },
] as const;
---

<Layout title="KPIs">
  <div class="flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-2xl font-bold">Indicadores de mantenimiento</h1>
      <p class="text-sm text-slate-500">Vista ejecutiva · ventana: últimos 30 días / año en curso</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <button id="pdfBtn" class="btn-secondary" disabled={!hayMetricas}>📄 Reporte JCI (PDF)</button>
      <a href="/reportes" class="btn-secondary">📑 Reportes CSV</a>
    </div>
  </div>

  <!-- ─── Indicadores JCI con tendencia documentada (persistidos) ─── -->
  <section class="card mt-4 p-5">
    <div class="flex flex-wrap items-start justify-between gap-2">
      <div>
        <h2 class="font-semibold text-slate-900">📊 Indicadores JCI con tendencia</h2>
        <p class="text-xs text-slate-500">Snapshot mensual persistido — evidencia auditable de "medir y mejorar" (FMS). {ultimoPeriodo ? `Último período: ${mesLabel(ultimoPeriodo)}` : ""}</p>
      </div>
      {esAdmin && (
        <div class="flex flex-wrap gap-2">
          <button id="capturarBtn" class="btn-secondary text-xs">📸 Capturar mes actual</button>
          <button id="recalcularBtn" class="btn-secondary text-xs">♻ Recalcular 12 meses</button>
        </div>
      )}
    </div>

    {!hayMetricas ? (
      <div class="mt-4 rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
        Aún no hay snapshots de KPIs. {esAdmin ? "Pulsa «Recalcular 12 meses» para generar la tendencia histórica desde las OTs existentes." : "Pide a un administrador que ejecute el recálculo histórico."}
      </div>
    ) : (
      <>
        <!-- Tabs de alcance -->
        <div class="mt-4 flex gap-1 border-b border-slate-200">
          {SCOPES.map((s) => (
            <button class="scope-tab px-3 py-1.5 text-sm font-medium border-b-2 -mb-px" data-scope={s}
              class:list={[s === "global" ? "border-brand-600 text-brand-700" : "border-transparent text-slate-500 hover:text-slate-700"]}>
              {SCOPE_LABEL[s]}
            </button>
          ))}
        </div>

        {SCOPES.map((scope) => {
          const latest = ultimoPeriodo ? serie[scope]?.[ultimoPeriodo] : null;
          return (
            <div class="scope-panel mt-4" data-scope={scope} class:list={[scope !== "global" && "hidden"]}>
              <!-- Tarjetas del último período -->
              <div class="grid grid-cols-2 gap-3 lg:grid-cols-6">
                <div class="card p-4">
                  <div class="text-xs uppercase text-slate-500">Cumpl. preventivo</div>
                  <div class:list={["mt-1 text-2xl font-bold", colorPct(latest?.cumplimientoPreventivo ?? null, 90, 70)]}>{latest?.cumplimientoPreventivo != null ? `${pct(latest.cumplimientoPreventivo)}%` : "—"}</div>
                  <div class="text-[11px] text-slate-500">{latest?.preventivosProgramados ?? 0} programados</div>
                </div>
                <div class="card p-4">
                  <div class="text-xs uppercase text-slate-500">Disponibilidad</div>
                  <div class:list={["mt-1 text-2xl font-bold", colorPct(latest?.disponibilidadPct ?? null, 95, 85)]}>{latest?.disponibilidadPct != null ? `${pct(latest.disponibilidadPct)}%` : "—"}</div>
                  <div class="text-[11px] text-slate-500">{latest?.numActivos ?? 0} equipos</div>
                </div>
                <div class="card p-4">
                  <div class="text-xs uppercase text-slate-500">MTTR</div>
                  <div class="mt-1 text-2xl font-bold text-blue-600">{fmtKpiH(latest?.mttrHoras ?? null)}</div>
                  <div class="text-[11px] text-slate-500">Reparación</div>
                </div>
                <div class="card p-4">
                  <div class="text-xs uppercase text-slate-500">MTBF</div>
                  <div class="mt-1 text-2xl font-bold text-purple-600">{fmtKpiH(latest?.mtbfHoras ?? null)}</div>
                  <div class="text-[11px] text-slate-500">Entre fallas</div>
                </div>
                <div class="card p-4">
                  <div class="text-xs uppercase text-slate-500">Backlog correctivos</div>
                  <div class="mt-1 text-2xl font-bold text-red-600">{latest?.backlogCorrectivos ?? "—"}</div>
                  <div class="text-[11px] text-slate-500">Abiertos fin de mes</div>
                </div>
                <div class="card p-4">
                  <div class="text-xs uppercase text-slate-500">Costo por activo</div>
                  <div class="mt-1 text-2xl font-bold text-slate-700">{latest?.costoPorActivo != null ? `$${Number(latest.costoPorActivo).toFixed(0)}` : "—"}</div>
                  <div class="text-[11px] text-slate-500">${latest?.costoTotal != null ? Number(latest.costoTotal).toFixed(0) : "0"} total</div>
                </div>
              </div>

              <!-- Tabla de tendencia 12 meses -->
              <div class="mt-4 overflow-x-auto">
                <table class="w-full text-left text-xs">
                  <thead class="bg-slate-50 text-slate-500">
                    <tr>
                      <th class="px-2 py-1.5 sticky left-0 bg-slate-50">Indicador</th>
                      {periodos12.map((p) => <th class="px-2 py-1.5 text-right whitespace-nowrap">{mesLabel(p)}</th>)}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    {KPIS_DEF.map((kpi) => (
                      <tr>
                        <td class="px-2 py-1.5 font-medium text-slate-700 sticky left-0 bg-white whitespace-nowrap">{kpi.label}</td>
                        {periodos12.map((p) => {
                          const row = serie[scope]?.[p];
                          const val = row ? (row as any)[kpi.key] : null;
                          return <td class="px-2 py-1.5 text-right font-mono text-slate-600 whitespace-nowrap">{row ? kpi.fmt(val) : "·"}</td>;
                        })}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          );
        })}
      </>
    )}
  </section>

  <!-- Top KPIs -->
  <div class="mt-4 grid grid-cols-2 gap-3 lg:grid-cols-6">
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Disponibilidad</div>
      <div class="mt-1 text-2xl font-bold text-emerald-600">{pct(disponibilidad)}%</div>
      <div class="text-[11px] text-slate-500">{operativos}/{totalActivos} operativos</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Cumplimiento SLA</div>
      <div class:list={["mt-1 text-2xl font-bold", cumplimientoSla >= 90 ? "text-emerald-600" : cumplimientoSla >= 70 ? "text-amber-600" : "text-red-600"]}>{pct(cumplimientoSla)}%</div>
      <div class="text-[11px] text-slate-500">{slaATiempo}/{slaTotal} a tiempo (30d)</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">MTTR (30d)</div>
      <div class="mt-1 text-2xl font-bold text-blue-600">{fmtH(mttrHoras)}</div>
      <div class="text-[11px] text-slate-500">Reparación promedio</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">MTBF (30d)</div>
      <div class="mt-1 text-2xl font-bold text-purple-600">{fmtH(mtbfHoras)}</div>
      <div class="text-[11px] text-slate-500">Entre fallas</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Backlog vencido</div>
      <div class="mt-1 text-2xl font-bold text-red-600">{vencidas}</div>
      <div class="text-[11px] text-slate-500">OTs sin cerrar</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Satisfacción</div>
      {satAvg != null ? (
        <>
          <div class="mt-1 text-2xl font-bold text-violet-600">{satAvg.toFixed(1)}<span class="text-sm text-slate-400">/5</span></div>
          <div class="text-[11px] text-slate-500">{satN} respuestas</div>
        </>
      ) : (
        <>
          <div class="mt-1 text-2xl font-bold text-slate-300">—</div>
          <div class="text-[11px] text-slate-500">Sin encuestas</div>
        </>
      )}
    </div>
  </div>

  <!-- Tendencia mensual -->
  <div class="card mt-6 p-5">
    <h2 class="font-semibold text-slate-900">Tendencia 12 meses</h2>
    <p class="text-xs text-slate-500">Completadas (verde) vs correctivos abiertos (rojo) por mes</p>
    <div class="mt-4 flex items-end gap-2 overflow-x-auto pb-2" style="height:160px">
      {tendencia.map((t) => {
        const hC = (t.completadas / maxTendencia) * 130;
        const hX = (t.correctivas / maxTendencia) * 130;
        return (
          <div class="flex min-w-[40px] flex-1 flex-col items-center gap-1">
            <div class="flex flex-1 items-end gap-0.5">
              <div class="w-3 rounded-t bg-emerald-500" style={`height:${hC}px`} title={`${t.completadas} completadas`}></div>
              <div class="w-3 rounded-t bg-red-400" style={`height:${hX}px`} title={`${t.correctivas} correctivos`}></div>
            </div>
            <div class="text-[9px] text-slate-500 capitalize whitespace-nowrap">{t.mes}</div>
          </div>
        );
      })}
    </div>
    <div class="mt-2 flex gap-4 text-xs text-slate-600">
      <span><span class="inline-block h-3 w-3 rounded bg-emerald-500"></span> Completadas</span>
      <span><span class="inline-block h-3 w-3 rounded bg-red-400"></span> Correctivos</span>
    </div>
  </div>

  <!-- Distribuciones -->
  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Estado de las OTs</h2>
      <div class="mt-3 space-y-2 text-sm">
        {[
          { k: "abierta", l: "Abiertas", c: "bg-blue-500" },
          { k: "en_proceso", l: "En proceso", c: "bg-amber-500" },
          { k: "completada", l: "Completadas", c: "bg-emerald-500" },
          { k: "verificada", l: "Verificadas", c: "bg-teal-500" },
          { k: "cerrada", l: "Cerradas", c: "bg-slate-700" },
          { k: "cancelada", l: "Canceladas", c: "bg-red-400" },
        ].map((s) => {
          const v = get(s.k);
          const w = total > 0 ? (v / total) * 100 : 0;
          return (
            <div>
              <div class="flex justify-between text-xs">
                <span>{s.l}</span><span class="font-mono">{v} ({pct(w)}%)</span>
              </div>
              <div class="h-2 overflow-hidden rounded bg-slate-100">
                <div class={`h-full ${s.c}`} style={`width: ${w}%`}></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Por tipo (año)</h2>
      <div class="mt-3 space-y-2 text-sm">
        {porTipo.map((t) => {
          const v = Number(t.n);
          const w = total > 0 ? (v / total) * 100 : 0;
          return (
            <div>
              <div class="flex justify-between text-xs">
                <span>{TIPO_LABEL[t.tipo as keyof typeof TIPO_LABEL] ?? t.tipo}</span>
                <span class="font-mono">{v}</span>
              </div>
              <div class="h-2 overflow-hidden rounded bg-slate-100">
                <div class="h-full bg-brand-500" style={`width: ${w}%`}></div>
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-5 rounded bg-slate-50 p-3">
        <div class="text-xs uppercase text-slate-500">Costo de repuestos (año)</div>
        <div class="mt-1 text-2xl font-bold">${costoTotal.toFixed(2)}</div>
      </div>
    </div>
  </div>

  <!-- Top equipos problemáticos + Top técnicos -->
  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div class="card overflow-hidden">
      <div class="px-5 pt-4 pb-2"><h2 class="font-semibold text-slate-900">Top 10 equipos con más correctivos (año)</h2></div>
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase text-slate-500">
          <tr>
            <th class="px-4 py-2">#</th>
            <th class="px-4 py-2">Equipo</th>
            <th class="px-4 py-2 text-right">Correctivos</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {topEquipos.length === 0 && <tr><td colspan="3" class="px-4 py-6 text-center text-slate-400">Sin datos.</td></tr>}
          {topEquipos.map((e, i) => (
            <tr>
              <td class="px-4 py-2 font-mono text-xs">{i + 1}</td>
              <td class="px-4 py-2"><a href={`/activos/${e.activoId}`} class="text-brand-700 hover:underline">{e.codigo} — {e.nombre}</a></td>
              <td class="px-4 py-2 text-right font-bold text-red-600">{Number(e.n)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="card overflow-hidden">
      <div class="px-5 pt-4 pb-2"><h2 class="font-semibold text-slate-900">Top 10 técnicos por OTs completadas (año)</h2></div>
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase text-slate-500">
          <tr>
            <th class="px-4 py-2">#</th>
            <th class="px-4 py-2">Técnico</th>
            <th class="px-4 py-2 text-right">OTs</th>
            <th class="px-4 py-2 text-right">Horas</th>
            <th class="px-4 py-2 text-right">A tiempo</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {topTecnicos.length === 0 && <tr><td colspan="5" class="px-4 py-6 text-center text-slate-400">Sin datos.</td></tr>}
          {topTecnicos.map((t, i) => {
            const conSla = Number(t.conSla);
            const aTiempo = Number(t.aTiempo);
            const pctTiempo = conSla > 0 ? Math.round((aTiempo / conSla) * 100) : null;
            return (
              <tr>
                <td class="px-4 py-2 font-mono text-xs">{i + 1}</td>
                <td class="px-4 py-2">{t.nombre ?? "—"}</td>
                <td class="px-4 py-2 text-right font-bold text-emerald-700">{Number(t.completadas)}</td>
                <td class="px-4 py-2 text-right font-mono text-slate-600">{Number(t.horas).toFixed(1)}h</td>
                <td class="px-4 py-2 text-right">
                  {pctTiempo != null ? (
                    <span class:list={["badge", pctTiempo >= 90 ? "bg-emerald-100 text-emerald-700" : pctTiempo >= 70 ? "bg-amber-100 text-amber-700" : "bg-red-100 text-red-700"]}>{pctTiempo}%</span>
                  ) : <span class="text-slate-400 text-xs">—</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <script define:vars={{ metricasJson, periodos: periodos12, scopeLabels: SCOPE_LABEL, scopes: SCOPES }}>
    // Tabs de alcance
    document.querySelectorAll(".scope-tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const scope = tab.dataset.scope;
        document.querySelectorAll(".scope-tab").forEach((t) => {
          const active = t.dataset.scope === scope;
          t.classList.toggle("border-brand-600", active);
          t.classList.toggle("text-brand-700", active);
          t.classList.toggle("border-transparent", !active);
          t.classList.toggle("text-slate-500", !active);
        });
        document.querySelectorAll(".scope-panel").forEach((p) => {
          p.classList.toggle("hidden", p.dataset.scope !== scope);
        });
      });
    });

    // Acciones admin
    document.getElementById("capturarBtn")?.addEventListener("click", async (e) => {
      const btn = e.currentTarget;
      btn.disabled = true; btn.textContent = "Capturando…";
      const r = await fetch("/api/cron/snapshot-kpis");
      if (r.ok) location.reload(); else { alert("Error al capturar"); btn.disabled = false; btn.textContent = "📸 Capturar mes actual"; }
    });
    document.getElementById("recalcularBtn")?.addEventListener("click", async (e) => {
      if (!confirm("¿Recalcular los KPIs de los últimos 12 meses desde el historial de OTs? Sobrescribe los snapshots existentes de ese rango.")) return;
      const btn = e.currentTarget;
      btn.disabled = true; btn.textContent = "Recalculando…";
      const r = await fetch("/api/metricas/recalcular", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ meses: 12 }) });
      if (r.ok) location.reload(); else { alert("Error al recalcular"); btn.disabled = false; btn.textContent = "♻ Recalcular 12 meses"; }
    });

    // ── PDF ──
    async function loadJsPdf() {
      if (window.jspdf) return window.jspdf;
      await new Promise((resolve, reject) => {
        const s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js";
        s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });
      return window.jspdf;
    }
    function mesLbl(p) {
      const [y, m] = p.split("-").map(Number);
      const d = new Date(Date.UTC(y, m - 1, 1));
      return d.toLocaleDateString("es", { month: "short", timeZone: "UTC" }).replace(".", "") + " " + String(y).slice(2);
    }
    const KPIS = [
      { key: "cumplimientoPreventivo", label: "Cumpl. preventivo (%)", fmt: (v) => v == null ? "-" : (Math.round(v * 10) / 10).toString() },
      { key: "disponibilidadPct", label: "Disponibilidad (%)", fmt: (v) => v == null ? "-" : (Math.round(v * 10) / 10).toString() },
      { key: "mttrHoras", label: "MTTR (h)", fmt: (v) => v == null ? "-" : (Math.round(v * 10) / 10).toString() },
      { key: "mtbfHoras", label: "MTBF (h)", fmt: (v) => v == null ? "-" : (Math.round(v * 10) / 10).toString() },
      { key: "backlogCorrectivos", label: "Backlog correctivos", fmt: (v) => v == null ? "-" : String(v) },
      { key: "costoPorActivo", label: "Costo por activo ($)", fmt: (v) => v == null ? "-" : Number(v).toFixed(0) },
    ];

    document.getElementById("pdfBtn")?.addEventListener("click", async () => {
      const { serie } = JSON.parse(metricasJson);
      let empresa = "Mantenimiento";
      try { const r = await fetch("/api/empresa"); if (r.ok) empresa = (await r.json()).empresa?.nombre ?? empresa; } catch {}
      const { jsPDF } = await loadJsPdf();
      const doc = new jsPDF({ unit: "mm", format: "a4" });
      const W = doc.internal.pageSize.getWidth();
      const M = 10;
      let y = M;
      const cols = periodos.slice(-6); // últimos 6 meses para que quepan

      doc.setFontSize(14); doc.setFont("helvetica", "bold");
      doc.text("Reporte de indicadores JCI", M, y); y += 6;
      doc.setFontSize(9); doc.setFont("helvetica", "normal");
      doc.text(`${empresa} · Generado ${new Date().toLocaleString("es", { timeZone: "America/El_Salvador" })}`, M, y); y += 7;

      const labelW = 45;
      const colW = (W - M * 2 - labelW) / cols.length;
      for (const scope of scopes) {
        if (y > 250) { doc.addPage(); y = M; }
        doc.setFont("helvetica", "bold"); doc.setFontSize(11);
        doc.text(scopeLabels[scope], M, y); y += 5;
        // Cabecera de meses
        doc.setFontSize(8); doc.setFont("helvetica", "bold");
        cols.forEach((p, i) => doc.text(mesLbl(p), M + labelW + i * colW + colW - 2, y, { align: "right" }));
        y += 1; doc.setDrawColor(200); doc.line(M, y, W - M, y); y += 4;
        doc.setFont("helvetica", "normal");
        for (const kpi of KPIS) {
          doc.setFont("helvetica", "bold"); doc.text(kpi.label, M, y); doc.setFont("helvetica", "normal");
          cols.forEach((p, i) => {
            const row = serie[scope]?.[p];
            const v = row ? kpi.fmt(row[kpi.key]) : "·";
            doc.text(String(v), M + labelW + i * colW + colW - 2, y, { align: "right" });
          });
          y += 5;
          if (y > 285) { doc.addPage(); y = M; }
        }
        y += 4;
      }
      doc.save(`indicadores-jci-${new Date().toISOString().slice(0, 10)}.pdf`);
    });
  </script>
</Layout>
