---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { activos } from "@/lib/schema";
import { desc } from "drizzle-orm";
export const prerender = false;

const db = getDb(Astro);
const rows = await db.select().from(activos).orderBy(desc(activos.id));
const user = Astro.locals.user!;
const canEdit = user.rol === "admin" || user.rol === "tecnico";

const estadoColor: Record<string, string> = {
  operativo: "bg-emerald-100 text-emerald-700",
  averiado: "bg-red-100 text-red-700",
  mantenimiento: "bg-amber-100 text-amber-700",
  baja: "bg-slate-200 text-slate-600",
};
---

<Layout title="Activos">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">Activos</h1>
      <p class="text-sm text-slate-500">{rows.length} equipos registrados</p>
    </div>
    {canEdit && <button id="newBtn" class="btn-primary">+ Nuevo activo</button>}
  </div>

  <div id="newForm" class="card mt-4 hidden p-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div><label class="label">Codigo</label><input class="input" id="f_codigo" /></div>
      <div><label class="label">Nombre</label><input class="input" id="f_nombre" /></div>
      <div class="sm:col-span-2"><label class="label">Descripcion</label><input class="input" id="f_descripcion" /></div>
      <div><label class="label">Ubicacion</label><input class="input" id="f_ubicacion" /></div>
      <div>
        <label class="label">Estado</label>
        <select class="input" id="f_estado">
          <option value="operativo">Operativo</option>
          <option value="averiado">Averiado</option>
          <option value="mantenimiento">En mantenimiento</option>
          <option value="baja">Dado de baja</option>
        </select>
      </div>
    </div>
    <div class="mt-3 flex gap-2"><button id="saveBtn" class="btn-primary">Guardar</button><button id="cancelBtn" class="btn-secondary">Cancelar</button></div>
    <p id="formErr" class="mt-2 hidden text-sm text-red-600"></p>
  </div>

  <div class="card mt-4 overflow-hidden">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          <th class="px-4 py-2">Codigo</th>
          <th class="px-4 py-2">Nombre</th>
          <th class="px-4 py-2">Ubicacion</th>
          <th class="px-4 py-2">Estado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && (
          <tr><td colspan="4" class="px-4 py-6 text-center text-slate-500">Aun no hay activos.</td></tr>
        )}
        {rows.map((a) => (
          <tr>
            <td class="px-4 py-2 font-mono text-xs">{a.codigo}</td>
            <td class="px-4 py-2">{a.nombre}</td>
            <td class="px-4 py-2 text-slate-600">{a.ubicacion ?? "-"}</td>
            <td class="px-4 py-2">
              <span class={`badge ${estadoColor[a.estado]}`}>{a.estado}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script>
    const newBtn = document.getElementById("newBtn");
    const newForm = document.getElementById("newForm");
    const cancelBtn = document.getElementById("cancelBtn");
    const saveBtn = document.getElementById("saveBtn");
    const formErr = document.getElementById("formErr") as HTMLElement | null;

    newBtn?.addEventListener("click", () => newForm?.classList.remove("hidden"));
    cancelBtn?.addEventListener("click", () => newForm?.classList.add("hidden"));

    saveBtn?.addEventListener("click", async () => {
      const get = (id: string) => (document.getElementById(id) as HTMLInputElement).value.trim();
      const payload = {
        codigo: get("f_codigo"),
        nombre: get("f_nombre"),
        descripcion: get("f_descripcion") || null,
        ubicacion: get("f_ubicacion") || null,
        estado: (document.getElementById("f_estado") as HTMLSelectElement).value,
      };
      if (!payload.codigo || !payload.nombre) {
        formErr!.textContent = "Codigo y nombre son obligatorios";
        formErr!.classList.remove("hidden");
        return;
      }
      const res = await fetch("/api/activos", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        formErr!.textContent = typeof j.error === "string" ? j.error : "Error al guardar";
        formErr!.classList.remove("hidden");
        return;
      }
      location.reload();
    });
  </script>
</Layout>
