---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { activos, planesMantenimiento } from "@/lib/schema";
import { desc, sql } from "drizzle-orm";
export const prerender = false;

const db = getDb(Astro);
const rows = await db.select().from(activos).orderBy(desc(activos.id));
const user = Astro.locals.user!;
const canEdit = user.rol === "admin" || user.rol === "tecnico";

const planesCount = await db
  .select({ activoId: planesMantenimiento.activoId, n: sql<number>`count(*)` })
  .from(planesMantenimiento)
  .where(sql`${planesMantenimiento.activo} = 1`)
  .groupBy(planesMantenimiento.activoId);
const planesByActivo = new Map(planesCount.map((r) => [r.activoId, Number(r.n)]));

const estadoColor: Record<string, string> = {
  operativo: "bg-emerald-100 text-emerald-700",
  averiado: "bg-red-100 text-red-700",
  mantenimiento: "bg-amber-100 text-amber-700",
  baja: "bg-slate-200 text-slate-600",
};
---

<Layout title="Equipos">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">Equipos / Activos</h1>
      <p class="text-sm text-slate-500">{rows.length} equipos registrados</p>
    </div>
    {canEdit && <a href="/activos/nuevo" class="btn-primary">+ Nuevo equipo</a>}
  </div>

  <div class="card mt-4 overflow-hidden">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          <th class="px-4 py-2">Codigo</th>
          <th class="px-4 py-2">Nombre</th>
          <th class="px-4 py-2">Tipo</th>
          <th class="px-4 py-2">Marca / Modelo</th>
          <th class="px-4 py-2">Ubicacion</th>
          <th class="px-4 py-2">Estado</th>
          <th class="px-4 py-2">Cronograma</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && (
          <tr><td colspan="7" class="px-4 py-6 text-center text-slate-500">Aun no hay equipos.</td></tr>
        )}
        {rows.map((a) => (
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2 font-mono text-xs">{a.codigo}</td>
            <td class="px-4 py-2">
              <a href={`/activos/${a.id}`} class="font-medium text-brand-700 hover:underline">{a.nombre}</a>
            </td>
            <td class="px-4 py-2">
              {a.tipo === "biomedico" ? (
                <span class="badge bg-purple-100 text-purple-700">Biomedico</span>
              ) : (
                <span class="badge bg-slate-100 text-slate-600">General</span>
              )}
            </td>
            <td class="px-4 py-2 text-slate-600">{[a.marca, a.modelo].filter(Boolean).join(" / ") || "-"}</td>
            <td class="px-4 py-2 text-slate-600">{a.ubicacion ?? "-"}</td>
            <td class="px-4 py-2"><span class={`badge ${estadoColor[a.estado]}`}>{a.estado}</span></td>
            <td class="px-4 py-2">
              {planesByActivo.get(a.id) ? (
                <span class="badge bg-blue-100 text-blue-700">{planesByActivo.get(a.id)} plan(es)</span>
              ) : (
                <span class="text-xs text-slate-400">sin cronograma</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>
