---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { activos, planesMantenimiento, ordenes, usuarios, sucursales, ubicaciones, proveedores, auditLog, contratosMantenimiento, contratoEquipos } from "@/lib/schema";
import { eq, asc, desc, and, inArray } from "drizzle-orm";
import { FRECUENCIAS } from "@/lib/frecuencias";
import { labelCampo } from "@/lib/audit";
import { ESTADO_CONTRATO_LABEL, ESTADO_CONTRATO_COLOR, diasParaVencer } from "@/lib/contratos";
export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect("/activos");

const db = getDb(Astro);
const [a] = await db.select().from(activos).where(eq(activos.id, id)).limit(1);
if (!a) return Astro.redirect("/activos");

// Sucursal + ubicación + proveedor (vía FKs)
let sucursalInfo: { id: number; nombre: string } | null = null;
let ubicacionInfo: { id: number; nombre: string; tipo: string } | null = null;
let proveedorInfo: { id: number; nombre: string } | null = null;
if (a.ubicacionId) {
  const [u] = await db
    .select({ id: ubicaciones.id, nombre: ubicaciones.nombre, tipo: ubicaciones.tipo, sucursalId: ubicaciones.sucursalId })
    .from(ubicaciones).where(eq(ubicaciones.id, a.ubicacionId)).limit(1);
  if (u) {
    ubicacionInfo = { id: u.id, nombre: u.nombre, tipo: u.tipo };
    const [s] = await db.select({ id: sucursales.id, nombre: sucursales.nombre })
      .from(sucursales).where(eq(sucursales.id, u.sucursalId)).limit(1);
    if (s) sucursalInfo = s;
  }
}
if (a.proveedorId) {
  const [p] = await db.select({ id: proveedores.id, nombre: proveedores.nombre })
    .from(proveedores).where(eq(proveedores.id, a.proveedorId)).limit(1);
  if (p) proveedorInfo = p;
}

const planes = await db
  .select({ p: planesMantenimiento, u: usuarios })
  .from(planesMantenimiento)
  .leftJoin(usuarios, eq(usuarios.id, planesMantenimiento.asignadoA))
  .where(eq(planesMantenimiento.activoId, id))
  .orderBy(asc(planesMantenimiento.proximaFecha));

const ordsRel = await db
  .select()
  .from(ordenes)
  .where(eq(ordenes.activoId, id))
  .orderBy(desc(ordenes.id))
  .limit(10);

const tecnicos = await db
  .select({ id: usuarios.id, nombre: usuarios.nombre, rol: usuarios.rol })
  .from(usuarios)
  .where(and(eq(usuarios.activo, true), inArray(usuarios.rol, ["tecnico", "jefe", "proveedor"])))
  .orderBy(asc(usuarios.nombre));

// Historial de cambios (audit log) — solo de este equipo
const auditRows = await db
  .select({ a: auditLog, u: usuarios })
  .from(auditLog)
  .leftJoin(usuarios, eq(usuarios.id, auditLog.usuarioId))
  .where(and(eq(auditLog.entidad, "activo"), eq(auditLog.entidadId, id)))
  .orderBy(desc(auditLog.id))
  .limit(50);

const user = Astro.locals.user!;
const canEdit = user.rol === "admin" || user.rol === "jefe" || user.rol === "tecnico";
const canDelete = user.rol === "admin";

const fmt = (s: string | null | undefined) => (s ? new Date(s).toLocaleDateString("es", { timeZone: "America/El_Salvador" }) : "-");
const fmtFull = (s: string | null | undefined) => (s ? new Date(s).toLocaleString("es", { timeZone: "America/El_Salvador" }) : "-");

function parsearCambios(json: string | null) {
  if (!json) return [];
  try {
    const obj = JSON.parse(json);
    return Object.entries(obj).map(([campo, val]: any) => ({
      campo, label: labelCampo(campo),
      antes: val?.antes ?? "(vacío)",
      despues: val?.despues ?? "(vacío)",
    }));
  } catch { return []; }
}
const isBio = a.tipo === "biomedico";

// Contratos vigentes/por vencer que cubren este equipo
const contratosActivoRaw = await db
  .select({ c: contratosMantenimiento, prov: proveedores })
  .from(contratoEquipos)
  .innerJoin(contratosMantenimiento, eq(contratosMantenimiento.id, contratoEquipos.contratoId))
  .leftJoin(proveedores, eq(proveedores.id, contratosMantenimiento.proveedorId))
  .where(and(
    eq(contratoEquipos.activoId, a.id),
    inArray(contratosMantenimiento.estado, ["vigente", "por_vencer"]),
  ))
  .orderBy(asc(contratosMantenimiento.fechaFin));

const contratosActivo = contratosActivoRaw.map(({ c, prov }) => {
  const d = diasParaVencer(c.fechaFin);
  let colorBadge = "bg-emerald-100 text-emerald-700";
  if (c.estado === "por_vencer") {
    colorBadge = d > 60 ? "bg-amber-100 text-amber-700"
      : d > 30 ? "bg-orange-100 text-orange-700"
      : "bg-red-100 text-red-700";
  }
  const labelBadge = c.estado === "por_vencer"
    ? (d > 0 ? `Vence en ${d}d` : "Vencido")
    : ESTADO_CONTRATO_LABEL[c.estado as keyof typeof ESTADO_CONTRATO_LABEL];
  return { c, prov, colorBadge, labelBadge };
});
---

<Layout title={a.nombre}>
  <a href="/activos" class="text-sm text-slate-500 hover:underline">&larr; Equipos</a>

  <div class="mt-2 flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-2">
        <h1 class="text-2xl font-bold">{a.nombre}</h1>
        {isBio ? (
          <span class="badge bg-purple-100 text-purple-700">Biomedico</span>
        ) : (
          <span class="badge bg-slate-100 text-slate-600">General</span>
        )}
      </div>
      <p class="text-sm text-slate-500 font-mono">{a.codigo} {a.numeroActivo && `· ${a.numeroActivo}`}</p>
    </div>
    {canEdit && (
      <div class="flex flex-wrap gap-2">
        <a href={`/activos/${a.id}/historial`} class="btn-secondary">📜 Historial</a>
        <a href={`/activos/${a.id}/editar`} class="btn-primary">✎ Editar</a>
        {canDelete && <button id="deleteBtn" class="btn-secondary text-red-600 hover:bg-red-50">🗑 Eliminar</button>}
      </div>
    )}
    {!canEdit && (
      <a href={`/activos/${a.id}/historial`} class="btn-secondary">📜 Historial</a>
    )}
  </div>

  <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
    <div class="card lg:col-span-2 p-5">
      <h2 class="font-semibold">Datos del equipo</h2>
      <div class="mt-3 grid grid-cols-2 gap-3 text-sm">
        <div><div class="text-xs uppercase text-slate-500">Marca / Modelo</div><div>{[a.marca, a.modelo].filter(Boolean).join(" / ") || "-"}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Serie</div><div class="font-mono text-xs">{a.serial ?? "-"}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Año</div><div>{a.anio ?? "-"}</div></div>
        <div><div class="text-xs uppercase text-slate-500">Categoria</div><div>{a.categoria ?? "-"}</div></div>
        <div>
          <div class="text-xs uppercase text-slate-500">Sucursal</div>
          <div>{sucursalInfo ? <span class="font-medium">🏢 {sucursalInfo.nombre}</span> : "-"}</div>
        </div>
        <div>
          <div class="text-xs uppercase text-slate-500">Ubicación</div>
          <div>
            {ubicacionInfo ? <span><span class="font-medium">📍 {ubicacionInfo.nombre}</span> <span class="text-xs text-slate-400 capitalize">({ubicacionInfo.tipo})</span></span> : "-"}
            {a.ubicacion && <div class="text-xs text-slate-500">{a.ubicacion}</div>}
          </div>
        </div>
        {proveedorInfo && (
          <div class="col-span-2"><div class="text-xs uppercase text-slate-500">Proveedor</div><div>{proveedorInfo.nombre}</div></div>
        )}
        <div class="col-span-2"><div class="text-xs uppercase text-slate-500">Descripcion</div><div class="whitespace-pre-wrap">{a.descripcion ?? "-"}</div></div>
      </div>

      <div class="mt-5 border-t border-slate-200 pt-4">
        <h3 class="font-semibold text-amber-700">⏱ SLA del equipo</h3>
        <div class="mt-2 grid grid-cols-4 gap-3 text-sm">
          <div><div class="text-xs uppercase text-slate-500">🔴 Urgente</div><div class="font-mono">{a.slaUrgenteHoras} h</div></div>
          <div><div class="text-xs uppercase text-slate-500">🟠 Alta</div><div class="font-mono">{a.slaAltaHoras} h</div></div>
          <div><div class="text-xs uppercase text-slate-500">🟡 Media</div><div class="font-mono">{a.slaMediaHoras} h</div></div>
          <div><div class="text-xs uppercase text-slate-500">🟢 Baja</div><div class="font-mono">{a.slaBajaHoras} h</div></div>
        </div>
      </div>

      {isBio && (
        <div class="mt-5 border-t border-slate-200 pt-4">
          <h3 class="font-semibold text-purple-700">Datos biomedicos</h3>
          <div class="mt-2 grid grid-cols-2 gap-3 text-sm">
            <div><div class="text-xs uppercase text-slate-500">Registro DNM</div><div>{a.registroSanitario ?? "-"}</div></div>
            <div><div class="text-xs uppercase text-slate-500">Clase de riesgo</div><div>{a.claseRiesgo ?? "-"}</div></div>
            <div><div class="text-xs uppercase text-slate-500">Ultima calibracion</div><div>{fmt(a.ultimaCalibracion)}</div></div>
            <div><div class="text-xs uppercase text-slate-500">Proxima calibracion</div><div>{fmt(a.proximaCalibracion)}</div></div>
          </div>
        </div>
      )}
    </div>

    <div class="card p-5">
      <h2 class="font-semibold">QR / Identificacion</h2>
      <div class="mt-3">
        <div class="text-xs uppercase text-slate-500">Codigo QR</div>
        <div class="font-mono text-xs">{a.qrCode ?? "-"}</div>
      </div>
      <div class="mt-3">
        <div class="text-xs uppercase text-slate-500">Estado</div>
        <div class="capitalize">{a.estado}</div>
      </div>
    </div>

    {contratosActivo.length > 0 && (
      <div class="card p-5">
        <h2 class="font-semibold">📜 Contratos de mantenimiento</h2>
        <ul class="mt-3 space-y-2 text-sm">
          {contratosActivo.map(({ c, prov, colorBadge, labelBadge }) => (
            <li class="border-l-2 border-slate-200 pl-3">
              <a href={`/contratos/${c.id}`} class="text-brand-600 hover:underline font-medium">{c.codigo}</a>
              <div class="text-xs text-slate-600">{c.nombre}</div>
              <div class="text-xs text-slate-500">{prov?.nombre ?? "—"}</div>
              <div class="mt-1">
                <span class={`badge text-[10px] ${colorBadge}`}>{labelBadge}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    <a href={`/activos/${a.id}/predictivo`} class="btn-secondary text-sm">📊 Mantenimiento predictivo</a>
  </div>

  <!-- Cronograma de mantenimiento -->
  <div class="card mt-6 p-5">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold">Cronograma de mantenimiento preventivo</h2>
      {canEdit && <button id="newPlanBtn" class="btn-primary">+ Agregar al cronograma</button>}
    </div>

    <div id="newPlanForm" class="mt-4 hidden rounded-md border border-slate-200 bg-slate-50 p-4">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="sm:col-span-2"><label class="label">Titulo *</label><input class="input" id="p_titulo" placeholder="Ej: Limpieza general, calibracion semestral..." /></div>
        <div class="sm:col-span-2"><label class="label">Descripcion / instrucciones</label><textarea class="input" id="p_descripcion" rows="2"></textarea></div>
        <div>
          <label class="label">Frecuencia *</label>
          <select class="input" id="p_frecuencia">
            {FRECUENCIAS.map((f) => <option value={f.value}>{f.label}</option>)}
          </select>
        </div>
        <div><label class="label">Proxima ejecucion *</label><input class="input" id="p_proxima" type="date" required /></div>
        <div><label class="label">Alerta dias antes</label><input class="input" id="p_alerta" type="number" min="0" max="90" value="7" /></div>
        <div>
          <label class="label">Prioridad</label>
          <select class="input" id="p_prioridad">
            <option value="baja">Baja</option>
            <option value="media" selected>Media</option>
            <option value="alta">Alta</option>
            <option value="urgente">Urgente</option>
          </select>
        </div>
        <div><label class="label">Horas estimadas</label><input class="input" id="p_horas" type="number" step="0.5" min="0" /></div>
        <div>
          <label class="label">Asignar a (opcional)</label>
          <select class="input" id="p_asignado">
            <option value="">- Sin asignar -</option>
            {tecnicos.map((t) => <option value={t.id}>{t.nombre}</option>)}
          </select>
        </div>
        <div class="sm:col-span-2 border-t border-slate-200 pt-3 mt-1">
          <label class="label">📋 Plantilla de checklist <span class="text-slate-400 font-normal">(opcional pero recomendada)</span></label>
          <select class="input" id="p_plantilla">
            <option value="">— Sin plantilla (checklist vacío) —</option>
          </select>
          <p class="mt-1 text-xs text-slate-500">Al seleccionar una plantilla, los puntos críticos se cargan abajo y podrás ajustarlos para este equipo específico.</p>
        </div>
        <div class="sm:col-span-2">
          <label class="label">Puntos críticos del checklist</label>
          <textarea id="p_checklist" class="input font-mono text-xs" rows="6" placeholder="Selecciona una plantilla arriba o escribe los puntos uno por línea&#10;Ej:&#10;Limpieza de filtros&#10;Verificación de gas refrigerante"></textarea>
          <p class="mt-1 text-xs text-slate-500">Cada línea es un punto. El técnico debe marcar cada uno como OK, N/A o Desviación antes de cerrar la OT.</p>
        </div>
      </div>
      <p id="p_err" class="mt-2 hidden text-sm text-red-600"></p>
      <div class="mt-3 flex gap-2">
        <button id="p_save" class="btn-primary">Guardar plan</button>
        <button id="p_cancel" class="btn-secondary">Cancelar</button>
      </div>
    </div>

    <div class="mt-4">
      {planes.length === 0 ? (
        <p class="text-sm text-slate-500">Aun no hay planes de mantenimiento para este equipo. {canEdit && "Agrega uno para que el sistema genere ordenes automaticamente."}</p>
      ) : (
        <ul class="divide-y divide-slate-100">
          {planes.map((r) => (
            <li class="py-3" id={`plan-${r.p.id}`}>
              <div class="flex items-start justify-between gap-2">
                <div class="flex-1">
                  <div class="font-medium">{r.p.titulo}</div>
                  <div class="mt-1 flex flex-wrap items-center gap-2 text-xs">
                    <span class="rounded bg-slate-100 px-2 py-0.5 capitalize">📅 {r.p.frecuencia}</span>
                    <span class="rounded bg-blue-100 px-2 py-0.5 text-blue-700">Próxima: <strong>{fmt(r.p.proximaFecha)}</strong></span>
                    {r.u
                      ? <span class="rounded bg-emerald-100 px-2 py-0.5 text-emerald-700">👤 {r.u.nombre}</span>
                      : <span class="rounded bg-amber-100 px-2 py-0.5 text-amber-700">👤 Sin asignar</span>
                    }
                    {r.p.prioridad && <span class="rounded bg-slate-100 px-2 py-0.5 capitalize text-slate-600">⚡ {r.p.prioridad}</span>}
                  </div>
                  {r.p.ultimaGeneracion && <div class="mt-1 text-xs text-slate-400">Última OT generada: {fmt(r.p.ultimaGeneracion)}</div>}
                  {r.p.descripcion && <div class="mt-1 text-sm text-slate-600">{r.p.descripcion}</div>}
                </div>
                <div class="flex items-center gap-2">
                  <span class={`badge ${r.p.activo ? "bg-emerald-100 text-emerald-700" : "bg-slate-200 text-slate-500"}`}>
                    {r.p.activo ? "activo" : "pausado"}
                  </span>
                  {canEdit && (
                    <>
                      <button data-id={r.p.id} data-edit class="btn-secondary text-xs">✎ Editar</button>
                      <button data-id={r.p.id} data-pause class="btn-secondary text-xs">{r.p.activo ? "Pausar" : "Activar"}</button>
                      <button data-id={r.p.id} data-del class="btn-secondary text-xs text-red-600">Eliminar</button>
                    </>
                  )}
                </div>
              </div>

              {canEdit && (
                <div id={`edit-${r.p.id}`} class="mt-3 hidden rounded border border-brand-200 bg-brand-50/40 p-3">
                  <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    <div class="sm:col-span-2">
                      <label class="label">Título</label>
                      <input class="input edit-titulo" data-id={r.p.id} value={r.p.titulo} />
                    </div>
                    <div class="sm:col-span-2">
                      <label class="label">Descripción</label>
                      <textarea class="input edit-descripcion" data-id={r.p.id} rows="2">{r.p.descripcion ?? ""}</textarea>
                    </div>
                    <div>
                      <label class="label">Frecuencia</label>
                      <select class="input edit-frecuencia" data-id={r.p.id}>
                        {FRECUENCIAS.map((f) => <option value={f.value} selected={f.value === r.p.frecuencia}>{f.label}</option>)}
                      </select>
                    </div>
                    <div>
                      <label class="label">Próxima ejecución</label>
                      <input class="input edit-proxima" data-id={r.p.id} type="date" value={r.p.proximaFecha} />
                    </div>
                    <div>
                      <label class="label">Alerta días antes</label>
                      <input class="input edit-alerta" data-id={r.p.id} type="number" min="0" max="90" value={r.p.alertaDiasAntes} />
                    </div>
                    <div>
                      <label class="label">Prioridad</label>
                      <select class="input edit-prioridad" data-id={r.p.id}>
                        <option value="baja" selected={r.p.prioridad === "baja"}>Baja</option>
                        <option value="media" selected={r.p.prioridad === "media"}>Media</option>
                        <option value="alta" selected={r.p.prioridad === "alta"}>Alta</option>
                        <option value="urgente" selected={r.p.prioridad === "urgente"}>Urgente</option>
                      </select>
                    </div>
                    <div>
                      <label class="label">Horas estimadas</label>
                      <input class="input edit-horas" data-id={r.p.id} type="number" step="0.5" min="0" value={r.p.horasEstimadas ?? ""} />
                    </div>
                    <div>
                      <label class="label">Asignar a</label>
                      <select class="input edit-asignado" data-id={r.p.id}>
                        <option value="">- Sin asignar -</option>
                        {tecnicos.map((t) => <option value={t.id} selected={t.id === r.p.asignadoA}>{t.nombre}</option>)}
                      </select>
                    </div>
                  </div>
                  <p class="mt-2 text-xs text-slate-500">Si cambias la frecuencia o la próxima fecha, los próximos ciclos se calcularán a partir de aquí.</p>
                  <p class="edit-msg mt-2 hidden text-xs" data-id={r.p.id}></p>
                  <div class="mt-2 flex gap-2">
                    <button data-id={r.p.id} data-save class="btn-primary text-sm">Guardar</button>
                    <button data-id={r.p.id} data-cancel class="btn-secondary text-sm">Cancelar</button>
                  </div>
                </div>
              )}
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>

  <!-- Historial de OT -->
  <div class="card mt-6 p-5">
    <h2 class="font-semibold">Ultimas ordenes de trabajo</h2>
    {ordsRel.length === 0 ? (
      <p class="mt-2 text-sm text-slate-500">Sin ordenes registradas para este equipo.</p>
    ) : (
      <ul class="mt-3 divide-y divide-slate-100 text-sm">
        {ordsRel.map((o) => (
          <li class="flex items-center justify-between py-2">
            <a href={`/ordenes/${o.id}`} class="text-brand-700 hover:underline">#{o.id} - {o.titulo}</a>
            <span class="text-xs text-slate-500 capitalize">{o.tipo} · {o.estado.replace("_"," ")}</span>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Historial de cambios (audit) -->
  <div class="card mt-6 p-5">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold">📋 Historial de cambios</h2>
      <span class="text-xs text-slate-500">{auditRows.length} {auditRows.length === 1 ? "evento" : "eventos"}</span>
    </div>
    {auditRows.length === 0 ? (
      <p class="mt-2 text-sm text-slate-500">Sin cambios registrados todavía.</p>
    ) : (
      <ul class="mt-3 divide-y divide-slate-100 text-sm">
        {auditRows.map((r) => {
          const cambios = parsearCambios(r.a.cambios);
          const accionLabel = r.a.accion === "create" ? "✨ Creó" : r.a.accion === "delete" ? "🗑 Eliminó" : "✎ Modificó";
          const accionColor = r.a.accion === "create" ? "bg-emerald-50 text-emerald-700"
            : r.a.accion === "delete" ? "bg-red-50 text-red-700"
            : "bg-blue-50 text-blue-700";
          return (
            <li class="py-3">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <span class={`badge ${accionColor}`}>{accionLabel}</span>
                  <span class="ml-2 text-sm font-medium">{r.u?.nombre ?? "Sistema"}</span>
                  {r.a.resumen && <span class="ml-2 text-sm text-slate-600">— {r.a.resumen}</span>}
                </div>
                <span class="whitespace-nowrap text-xs text-slate-400">{fmtFull(r.a.createdAt)}</span>
              </div>
              {cambios.length > 0 && (
                <table class="mt-2 ml-2 text-xs text-slate-600">
                  <tbody>
                    {cambios.map((c) => (
                      <tr>
                        <td class="pr-3 font-medium text-slate-500">{c.label}:</td>
                        <td class="pr-2 text-red-600 line-through">{String(c.antes)}</td>
                        <td class="pr-2">→</td>
                        <td class="text-emerald-700">{String(c.despues)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </li>
          );
        })}
      </ul>
    )}
  </div>

  <script define:vars={{ activoId: id, activoCodigo: a.codigo, activoNombre: a.nombre, ubicacionNombre: ubicacionInfo?.nombre ?? null }}>
    const $ = (id) => document.getElementById(id);
    // Cache de plantillas para repoblar el textarea de checklist
    let plantillasCache = [];

    async function cargarPlantillas() {
      try {
        const res = await fetch("/api/checklist-plantillas?activas=1");
        if (!res.ok) return;
        const j = await res.json();
        plantillasCache = j.plantillas ?? [];
        const sel = $("p_plantilla");
        if (!sel) return;
        sel.innerHTML = '<option value="">— Sin plantilla (checklist vacío) —</option>';
        for (const p of plantillasCache) {
          const opt = document.createElement("option");
          opt.value = String(p.id);
          opt.textContent = `${p.nombre} (${p.items.length} puntos)`;
          sel.appendChild(opt);
        }
      } catch {}
    }

    $("p_plantilla")?.addEventListener("change", () => {
      const id = Number($("p_plantilla").value);
      if (!id) return;
      const p = plantillasCache.find((x) => x.id === id);
      if (!p) return;
      const textareaEl = $("p_checklist");
      if (!textareaEl) return;
      // Si hay contenido previo, confirmar antes de sobrescribir
      if (textareaEl.value.trim() && !confirm("¿Reemplazar los puntos actuales con los de esta plantilla?")) return;
      textareaEl.value = p.items.map((it) => it.texto).join("\n");
    });

    $("newPlanBtn")?.addEventListener("click", () => {
      $("newPlanForm").classList.remove("hidden");
      // Pre-llenar título: "Mantenimiento preventivo {nombre equipo} {ubicación}"
      const tituloEl = $("p_titulo");
      if (tituloEl && !tituloEl.value) {
        const partes = ["Mantenimiento preventivo", activoNombre];
        if (ubicacionNombre) partes.push(ubicacionNombre);
        tituloEl.value = partes.filter(Boolean).join(" ");
      }
      // Pre-llenar próxima fecha con hoy (hora SV)
      const fechaEl = $("p_proxima");
      if (fechaEl && !fechaEl.value) {
        const hoy = new Date();
        hoy.setHours(hoy.getHours() - 6); // ajuste UTC -> SV
        fechaEl.value = hoy.toISOString().slice(0, 10);
      }
      // Cargar plantillas si aún no se cargaron
      if (plantillasCache.length === 0) cargarPlantillas();
    });
    $("p_cancel")?.addEventListener("click", () => $("newPlanForm").classList.add("hidden"));

    $("p_save")?.addEventListener("click", async () => {
      const err = $("p_err");
      err.classList.add("hidden");
      // Construir checklist desde el textarea (formato esperado por la API: [{texto}])
      const checklistRaw = $("p_checklist")?.value?.trim() || "";
      let checklist = null;
      if (checklistRaw) {
        const items = checklistRaw.split("\n").map((l) => l.trim()).filter(Boolean)
          .map((texto) => ({ texto }));
        if (items.length > 0) checklist = items;
      }
      const payload = {
        titulo: $("p_titulo").value.trim(),
        descripcion: $("p_descripcion").value.trim() || null,
        frecuencia: $("p_frecuencia").value,
        proximaFecha: $("p_proxima").value,
        alertaDiasAntes: Number($("p_alerta").value || 7),
        prioridad: $("p_prioridad").value,
        horasEstimadas: $("p_horas").value ? Number($("p_horas").value) : null,
        asignadoA: $("p_asignado").value ? Number($("p_asignado").value) : null,
        checklist,
      };
      if (!payload.titulo || !payload.proximaFecha) {
        err.textContent = "Titulo y proxima fecha son obligatorios";
        err.classList.remove("hidden");
        return;
      }
      const res = await fetch(`/api/activos/${activoId}/planes`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        err.textContent = typeof j.error === "string" ? j.error : "Error al guardar";
        err.classList.remove("hidden");
        return;
      }
      location.reload();
    });

    document.querySelectorAll("[data-pause]").forEach((b) => {
      b.addEventListener("click", async (e) => {
        const id = e.currentTarget.dataset.id;
        const isActive = e.currentTarget.textContent.trim() === "Pausar";
        await fetch(`/api/planes/${id}`, {
          method: "PATCH",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ activo: !isActive }),
        });
        location.reload();
      });
    });

    document.querySelectorAll("[data-del]").forEach((b) => {
      b.addEventListener("click", async (e) => {
        if (!confirm("Eliminar este plan de mantenimiento?")) return;
        const id = e.currentTarget.dataset.id;
        await fetch(`/api/planes/${id}`, { method: "DELETE" });
        location.reload();
      });
    });

    // Editar plan inline
    document.querySelectorAll("[data-edit]").forEach((b) => {
      b.addEventListener("click", (e) => {
        const id = e.currentTarget.dataset.id;
        document.getElementById(`edit-${id}`)?.classList.remove("hidden");
      });
    });
    document.querySelectorAll("[data-cancel]").forEach((b) => {
      b.addEventListener("click", (e) => {
        const id = e.currentTarget.dataset.id;
        document.getElementById(`edit-${id}`)?.classList.add("hidden");
      });
    });
    document.querySelectorAll("[data-save]").forEach((b) => {
      b.addEventListener("click", async (e) => {
        const id = e.currentTarget.dataset.id;
        const get = (cls) => document.querySelector(`.${cls}[data-id="${id}"]`);
        const v = (cls) => get(cls)?.value?.trim() ?? "";
        const num = (cls) => { const x = get(cls)?.value; return x === "" || x == null ? null : Number(x); };
        const asign = get("edit-asignado")?.value;
        const payload = {
          titulo: v("edit-titulo"),
          descripcion: v("edit-descripcion") || null,
          frecuencia: get("edit-frecuencia").value,
          proximaFecha: v("edit-proxima"),
          alertaDiasAntes: num("edit-alerta") ?? 7,
          prioridad: get("edit-prioridad").value,
          horasEstimadas: num("edit-horas"),
          asignadoA: asign ? Number(asign) : null,
        };
        const msg = document.querySelector(`.edit-msg[data-id="${id}"]`);
        msg?.classList.add("hidden");
        const res = await fetch(`/api/planes/${id}`, {
          method: "PATCH",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          if (msg) {
            msg.textContent = typeof j.error === "string" ? j.error : "Error al guardar";
            msg.className = "edit-msg mt-2 text-xs text-red-600";
            msg.classList.remove("hidden");
          }
          return;
        }
        location.reload();
      });
    });

    // Eliminar equipo (solo admin)
    document.getElementById("deleteBtn")?.addEventListener("click", async () => {
      if (!confirm("¿Eliminar este equipo? Esta acción borra también sus planes de mantenimiento, OTs no se borran.")) return;
      const res = await fetch(`/api/activos/${activoId}`, { method: "DELETE" });
      if (res.ok) location.href = "/activos";
      else alert("Error al eliminar");
    });
  </script>
</Layout>
