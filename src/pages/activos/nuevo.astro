---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { sucursales, ubicaciones, proveedores } from "@/lib/schema";
import { eq } from "drizzle-orm";
export const prerender = false;

const user = Astro.locals.user!;
if (user.rol === "solicitante" || user.rol === "visualizador" || user.rol === "proveedor") {
  return Astro.redirect("/activos");
}

const db = getDb(Astro);
const sucRows = await db.select({ id: sucursales.id, nombre: sucursales.nombre }).from(sucursales).orderBy(sucursales.nombre);
const ubRows = await db.select().from(ubicaciones).orderBy(ubicaciones.nombre);
const provRows = await db.select({ id: proveedores.id, nombre: proveedores.nombre }).from(proveedores).where(eq(proveedores.activo, true)).orderBy(proveedores.nombre);

const ubJson = JSON.stringify(ubRows);
---

<Layout title="Nuevo equipo">
  <a href="/activos" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>
  <h1 class="mt-2 text-2xl font-bold">Nuevo equipo</h1>

  <form id="form" class="card mt-4 space-y-5 p-5">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="label">Tipo de equipo *</label>
        <select class="input" id="tipo">
          <option value="general">General / Industrial</option>
          <option value="biomedico">Biomedico</option>
        </select>
      </div>
      <div>
        <label class="label">Categoria</label>
        <input class="input" id="categoria" placeholder="Ej: Refrigeracion, Quirofano..." />
      </div>
      <div>
        <label class="label">Codigo interno *</label>
        <input class="input" id="codigo" required placeholder="EQ-001" />
      </div>
      <div>
        <label class="label">Numero de activo</label>
        <input class="input" id="numeroActivo" placeholder="Ej: AC-2024-001" />
      </div>
      <div class="sm:col-span-2">
        <label class="label">Nombre *</label>
        <input class="input" id="nombre" required />
      </div>
      <div class="sm:col-span-2">
        <label class="label">Descripcion</label>
        <textarea class="input" id="descripcion" rows="2"></textarea>
      </div>
      <div>
        <label class="label">Marca</label>
        <input class="input" id="marca" />
      </div>
      <div>
        <label class="label">Modelo</label>
        <input class="input" id="modelo" />
      </div>
      <div>
        <label class="label">Numero de serie</label>
        <input class="input" id="serial" />
      </div>
      <div>
        <label class="label">Año</label>
        <input class="input" id="anio" type="number" min="1900" max="2100" />
      </div>

      <!-- Ubicacion estructurada (si hay sucursales) -->
      {sucRows.length > 0 && (
        <>
          <div>
            <label class="label">Sucursal</label>
            <select class="input" id="sucursalSel">
              <option value="">— Seleccionar —</option>
              {sucRows.map((s) => <option value={s.id}>{s.nombre}</option>)}
            </select>
          </div>
          <div>
            <label class="label">Ubicacion</label>
            <select class="input" id="ubicacionSel">
              <option value="">— Seleccionar —</option>
            </select>
          </div>
        </>
      )}

      <div class="sm:col-span-2">
        <label class="label">{sucRows.length > 0 ? "Ubicacion adicional / Detalle" : "Ubicacion"}</label>
        <input class="input" id="ubicacion" placeholder="Ej: Sala 3 - Quirofano A" />
      </div>

      <div>
        <label class="label">Estado</label>
        <select class="input" id="estado">
          <option value="operativo">Operativo</option>
          <option value="averiado">Averiado</option>
          <option value="mantenimiento">En mantenimiento</option>
          <option value="baja">Dado de baja</option>
        </select>
      </div>

      {provRows.length > 0 && (
        <div>
          <label class="label">Proveedor / Fabricante</label>
          <select class="input" id="proveedorSel">
            <option value="">— Sin proveedor —</option>
            {provRows.map((p) => <option value={p.id}>{p.nombre}</option>)}
          </select>
        </div>
      )}
    </div>

    <div class="border-t border-slate-200 pt-5">
      <h2 class="mb-3 font-semibold text-emerald-700">🛡️ Mantenimiento preventivo automático</h2>
      <p class="text-xs text-slate-500 mb-3">Si configuras la frecuencia, el sistema generará automáticamente las órdenes preventivas en cada ciclo. Si después se hace un correctivo, el contador se reinicia automáticamente.</p>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label class="label">Frecuencia de mantenimiento</label>
          <select class="input" id="mantenimientoFrecuencia">
            <option value="">— Sin programación automática —</option>
            <option value="diaria">Diaria</option>
            <option value="semanal">Semanal</option>
            <option value="quincenal">Quincenal</option>
            <option value="mensual">Mensual</option>
            <option value="bimestral">Bimestral (2 meses)</option>
            <option value="trimestral" selected>Trimestral (3 meses)</option>
            <option value="semestral">Semestral (6 meses)</option>
            <option value="anual">Anual</option>
          </select>
        </div>
        <div>
          <label class="label">Primera ejecución (próxima fecha)</label>
          <input class="input" id="mantenimientoProximaFecha" type="date" />
          <p class="text-xs text-slate-400 mt-1">Si lo dejas vacío, se calcula automáticamente desde hoy.</p>
        </div>
        <div>
          <label class="label">Prioridad de la OT</label>
          <select class="input" id="mantenimientoPrioridad">
            <option value="baja">Baja</option>
            <option value="media" selected>Media</option>
            <option value="alta">Alta</option>
            <option value="urgente">Urgente</option>
          </select>
        </div>
        <div>
          <label class="label">Título del plan (opcional)</label>
          <input class="input" id="mantenimientoTitulo" placeholder="Ej: Limpieza filtros y revisión general" />
        </div>
      </div>
    </div>

    <div id="bioFields" class="hidden border-t border-slate-200 pt-5">
      <h2 class="mb-3 font-semibold text-purple-700">Datos biomedicos</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label class="label">Registro sanitario (DNM)</label>
          <input class="input" id="registroSanitario" placeholder="DNM-XXXX" />
        </div>
        <div>
          <label class="label">Clase de riesgo</label>
          <select class="input" id="claseRiesgo">
            <option value="">- Sin clasificar -</option>
            <option value="I">Clase I (riesgo bajo)</option>
            <option value="IIa">Clase IIa (riesgo moderado)</option>
            <option value="IIb">Clase IIb (riesgo moderado-alto)</option>
            <option value="III">Clase III (riesgo alto)</option>
          </select>
        </div>
        <div>
          <label class="label">Ultima calibracion</label>
          <input class="input" id="ultimaCalibracion" type="date" />
        </div>
        <div>
          <label class="label">Proxima calibracion</label>
          <input class="input" id="proximaCalibracion" type="date" />
        </div>
      </div>
    </div>

    <p id="err" class="hidden text-sm text-red-600"></p>
    <div class="flex gap-2">
      <button class="btn-primary" type="submit">Crear equipo</button>
      <a class="btn-secondary" href="/activos">Cancelar</a>
    </div>
  </form>

  <script define:vars={{ ubJson }}>
    const allUbs = JSON.parse(ubJson);

    // Biomedico toggle
    const tipoSel = document.getElementById("tipo");
    const bioFields = document.getElementById("bioFields");
    const toggleBio = () => bioFields?.classList.toggle("hidden", tipoSel?.value !== "biomedico");
    tipoSel?.addEventListener("change", toggleBio);
    toggleBio();

    // Sucursal → ubicacion filter
    const sucursalSel = document.getElementById("sucursalSel");
    const ubicacionSel = document.getElementById("ubicacionSel");
    if (sucursalSel && ubicacionSel) {
      sucursalSel.addEventListener("change", () => {
        const sid = Number(sucursalSel.value);
        const filtered = sid ? allUbs.filter((u) => u.sucursalId === sid) : [];
        ubicacionSel.innerHTML = '<option value="">— Seleccionar —</option>';
        filtered.forEach((u) => {
          const opt = document.createElement("option");
          opt.value = u.id;
          opt.textContent = `${u.nombre} (${u.tipo})`;
          ubicacionSel.appendChild(opt);
        });
      });
    }

    // Form submit
    const form = document.getElementById("form");
    const err = document.getElementById("err");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      err?.classList.add("hidden");
      const v = (id) => document.getElementById(id)?.value?.trim() ?? "";
      const sv = (id) => document.getElementById(id)?.value ?? "";
      const isBio = sv("tipo") === "biomedico";
      const payload = {
        codigo: v("codigo"),
        nombre: v("nombre"),
        descripcion: v("descripcion") || null,
        ubicacion: v("ubicacion") || null,
        estado: sv("estado"),
        tipo: sv("tipo"),
        categoria: v("categoria") || null,
        numeroActivo: v("numeroActivo") || null,
        marca: v("marca") || null,
        modelo: v("modelo") || null,
        serial: v("serial") || null,
        anio: v("anio") ? Number(v("anio")) : null,
        ubicacionId: sv("ubicacionSel") ? Number(sv("ubicacionSel")) : null,
        proveedorId: sv("proveedorSel") ? Number(sv("proveedorSel")) : null,
      };
      if (isBio) {
        payload.registroSanitario = v("registroSanitario") || null;
        payload.claseRiesgo = sv("claseRiesgo") || null;
        payload.ultimaCalibracion = v("ultimaCalibracion") || null;
        payload.proximaCalibracion = v("proximaCalibracion") || null;
      }

      // Mantenimiento preventivo auto
      const frec = sv("mantenimientoFrecuencia");
      if (frec) {
        payload.mantenimientoFrecuencia = frec;
        payload.mantenimientoProximaFecha = v("mantenimientoProximaFecha") || null;
        payload.mantenimientoTitulo = v("mantenimientoTitulo") || null;
        payload.mantenimientoPrioridad = sv("mantenimientoPrioridad") || "media";
      }
      const res = await fetch("/api/activos", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        if (err) { err.textContent = typeof j.error === "string" ? j.error : "Error al crear"; err.classList.remove("hidden"); }
        return;
      }
      const j = await res.json();
      location.href = `/activos/${j.activo.id}`;
    });
  </script>
</Layout>
