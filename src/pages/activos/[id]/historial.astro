---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import {
  activos, ordenes, usuarios, comentarios, ordenRepuestos, items as itemsTable,
  movimientosInventario, encuestasSatisfaccion,
} from "@/lib/schema";
import { eq, desc, and, sql, isNotNull, gte } from "drizzle-orm";
import { ESTADO_LABEL, ESTADO_COLOR, TIPO_COLOR, PRIO_COLOR, type EstadoOT } from "@/lib/ordenes";
export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect("/activos");

const db = getDb(Astro);
const [a] = await db.select().from(activos).where(eq(activos.id, id)).limit(1);
if (!a) return Astro.redirect("/activos");

// Todas las OTs del equipo (orden cronológico inverso)
const ots = await db
  .select({ o: ordenes, asignado: usuarios })
  .from(ordenes)
  .leftJoin(usuarios, eq(usuarios.id, ordenes.asignadoA))
  .where(eq(ordenes.activoId, id))
  .orderBy(desc(ordenes.id));

const otIds = ots.map((r) => r.o.id);

// Comentarios de esas OTs
const coms = otIds.length > 0 ? await db
  .select({ c: comentarios, u: usuarios })
  .from(comentarios)
  .leftJoin(usuarios, eq(usuarios.id, comentarios.usuarioId))
  .where(sql`${comentarios.ordenId} IN (${sql.raw(otIds.join(","))})`)
  .orderBy(desc(comentarios.id))
  : [];

// Repuestos consumidos
const repuestos = otIds.length > 0 ? await db
  .select({ rep: ordenRepuestos, it: itemsTable })
  .from(ordenRepuestos)
  .leftJoin(itemsTable, eq(itemsTable.id, ordenRepuestos.itemId))
  .where(sql`${ordenRepuestos.ordenId} IN (${sql.raw(otIds.join(","))})`)
  .orderBy(desc(ordenRepuestos.id))
  : [];

// ─── Métricas agregadas ──────────────────────────────────────────────────────
const totalOts = ots.length;
const totalCorrectivos = ots.filter((r) => r.o.tipo === "correctivo").length;
const totalPreventivos = ots.filter((r) => r.o.tipo === "preventivo").length;
const totalCerradas = ots.filter((r) => r.o.estado === "cerrada" || r.o.estado === "verificada" || r.o.estado === "completada").length;

// Costo total acumulado
const tarifaUserMap = new Map<number, number>();
const userIds = Array.from(new Set(ots.map((r) => r.o.asignadoA).filter((x): x is number => !!x)));
if (userIds.length > 0) {
  const us = await db.select({ id: usuarios.id, t: usuarios.tarifaHora })
    .from(usuarios).where(sql`${usuarios.id} IN (${sql.raw(userIds.join(","))})`);
  for (const u of us) tarifaUserMap.set(u.id, Number(u.t));
}

let costoMOTotal = 0;
let costoRepTotal = 0;
const costoPorOt = new Map<number, { mo: number; rep: number }>();
for (const r of ots) {
  const tarifa = r.o.asignadoA ? tarifaUserMap.get(r.o.asignadoA) ?? 0 : 0;
  const mo = Number(r.o.horasTrabajadas ?? 0) * tarifa;
  costoMOTotal += mo;
  costoPorOt.set(r.o.id, { mo, rep: 0 });
}
for (const r of repuestos) {
  const sub = r.rep.cantidad * Number(r.rep.precioUnitario ?? 0);
  costoRepTotal += sub;
  const cur = costoPorOt.get(r.rep.ordenId) ?? { mo: 0, rep: 0 };
  cur.rep += sub;
  costoPorOt.set(r.rep.ordenId, cur);
}
const costoTotal = costoMOTotal + costoRepTotal;

// Tiempo medio entre fallas correctivas (MTBF)
const correctivosConFecha = ots
  .filter((r) => r.o.tipo === "correctivo")
  .map((r) => new Date(r.o.createdAt).getTime())
  .sort((a, b) => a - b);
let mtbfDias: number | null = null;
if (correctivosConFecha.length >= 2) {
  const diffs: number[] = [];
  for (let i = 1; i < correctivosConFecha.length; i++) {
    diffs.push((correctivosConFecha[i] - correctivosConFecha[i - 1]) / 86400_000);
  }
  mtbfDias = diffs.reduce((s, x) => s + x, 0) / diffs.length;
}

// Repuestos más usados
const repuestosCount = new Map<string, { codigo: string | null; nombre: string | null; cantidad: number; subtotal: number }>();
for (const r of repuestos) {
  const key = String(r.rep.itemId);
  const cur = repuestosCount.get(key) ?? { codigo: r.it?.codigo ?? null, nombre: r.it?.nombre ?? null, cantidad: 0, subtotal: 0 };
  cur.cantidad += r.rep.cantidad;
  cur.subtotal += r.rep.cantidad * Number(r.rep.precioUnitario ?? 0);
  repuestosCount.set(key, cur);
}
const topRepuestos = Array.from(repuestosCount.values()).sort((a, b) => b.cantidad - a.cantidad).slice(0, 10);

// Encuestas de satisfacción ligadas a OTs de este equipo
const sats = otIds.length > 0 ? await db
  .select()
  .from(encuestasSatisfaccion)
  .where(and(
    sql`${encuestasSatisfaccion.ordenId} IN (${sql.raw(otIds.join(","))})`,
    isNotNull(encuestasSatisfaccion.respondidaEn)
  ))
  : [];
const satAvg = sats.length > 0 ? sats.reduce((s, r) => s + (r.calificacion ?? 0), 0) / sats.length : null;

// Costo por mes (últimos 12 meses)
const now = new Date();
type CostoMes = { mes: string; mo: number; rep: number; total: number; ots: number };
const costoMes: CostoMes[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const inicio = d.toISOString().slice(0, 10);
  const fin = new Date(d.getFullYear(), d.getMonth() + 1, 1).toISOString().slice(0, 10);
  let mo = 0, rep = 0, count = 0;
  for (const r of ots) {
    if (r.o.createdAt >= inicio && r.o.createdAt < fin) {
      const c = costoPorOt.get(r.o.id) ?? { mo: 0, rep: 0 };
      mo += c.mo; rep += c.rep; count++;
    }
  }
  costoMes.push({
    mes: d.toLocaleDateString("es", { month: "short", timeZone: "America/El_Salvador" }).replace(".", "") + " " + String(d.getFullYear()).slice(2),
    mo, rep, total: mo + rep, ots: count,
  });
}
const maxCosto = Math.max(1, ...costoMes.map((m) => m.total));

// ─── Construir timeline unificado ────────────────────────────────────────────
type EventoTL = {
  fecha: string;
  tipo: "ot_creada" | "ot_completada" | "ot_cerrada" | "comentario" | "repuesto" | "calibracion";
  titulo: string;
  detalle: string;
  meta?: string;
  link?: string;
  color: string;
  icono: string;
};

const eventos: EventoTL[] = [];
for (const r of ots) {
  eventos.push({
    fecha: r.o.createdAt,
    tipo: "ot_creada",
    titulo: `OT #${r.o.id}: ${r.o.titulo}`,
    detalle: r.o.descripcion ?? "",
    meta: `${r.o.tipo} · ${r.o.prioridad}${r.asignado ? ` · ${r.asignado.nombre}` : ""}`,
    link: `/ordenes/${r.o.id}`,
    color: r.o.tipo === "correctivo" ? "border-red-400" : r.o.tipo === "preventivo" ? "border-emerald-400" : "border-purple-400",
    icono: r.o.tipo === "correctivo" ? "🔴" : r.o.tipo === "preventivo" ? "🟢" : "🟣",
  });
  if (r.o.completadaEn) {
    eventos.push({
      fecha: r.o.completadaEn,
      tipo: "ot_completada",
      titulo: `Completada OT #${r.o.id}`,
      detalle: r.o.solucionAplicada ?? r.o.trabajosRealizados ?? "",
      meta: `${r.o.horasTrabajadas ?? 0}h trabajadas`,
      link: `/ordenes/${r.o.id}`,
      color: "border-emerald-500",
      icono: "✅",
    });
  }
  if (r.o.cerradoEn) {
    eventos.push({
      fecha: r.o.cerradoEn,
      tipo: "ot_cerrada",
      titulo: `Cerrada OT #${r.o.id}`,
      detalle: "",
      link: `/ordenes/${r.o.id}`,
      color: "border-slate-400",
      icono: "🔒",
    });
  }
}
for (const c of coms) {
  eventos.push({
    fecha: c.c.createdAt,
    tipo: "comentario",
    titulo: `Comentario en OT #${c.c.ordenId}`,
    detalle: c.c.texto.slice(0, 200),
    meta: c.u?.nombre,
    link: `/ordenes/${c.c.ordenId}`,
    color: "border-blue-300",
    icono: "💬",
  });
}
for (const r of repuestos) {
  eventos.push({
    fecha: r.rep.createdAt,
    tipo: "repuesto",
    titulo: `Repuesto: ${r.it?.codigo ?? ""} ${r.it?.nombre ?? ""}`,
    detalle: `${r.rep.cantidad} ${r.it?.unidad ?? ""}${r.rep.precioUnitario ? ` × $${r.rep.precioUnitario}` : ""}`,
    meta: `OT #${r.rep.ordenId}`,
    link: `/ordenes/${r.rep.ordenId}`,
    color: "border-amber-400",
    icono: "🔧",
  });
}
if (a.tipo === "biomedico") {
  if (a.ultimaCalibracion) {
    eventos.push({
      fecha: a.ultimaCalibracion,
      tipo: "calibracion",
      titulo: `Calibración registrada`,
      detalle: a.proximaCalibracion ? `Próxima: ${new Date(a.proximaCalibracion).toLocaleDateString("es", { timeZone: "America/El_Salvador" })}` : "",
      meta: a.claseRiesgo ? `Clase ${a.claseRiesgo}` : "",
      color: "border-purple-500",
      icono: "🩺",
    });
  }
}

eventos.sort((a, b) => b.fecha.localeCompare(a.fecha));

const fmt = (s: string) => new Date(s).toLocaleString("es", { timeZone: "America/El_Salvador" });
const fmtDate = (s: string | null) => s ? new Date(s).toLocaleDateString("es", { timeZone: "America/El_Salvador" }) : "—";
---

<Layout title={`Historial · ${a.codigo}`}>
  <a href={`/activos/${a.id}`} class="text-sm text-slate-500 hover:underline">← Volver al equipo</a>
  <div class="mt-2 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold">📜 Historial: {a.codigo}</h1>
      <p class="text-sm text-slate-500">{a.nombre} · {a.tipo === "biomedico" ? "🩺 Biomédico" : "🔧 General"}</p>
    </div>
  </div>

  <!-- KPIs del equipo -->
  <div class="mt-4 grid grid-cols-2 gap-3 lg:grid-cols-6">
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Total OTs</div>
      <div class="mt-1 text-2xl font-bold text-slate-700">{totalOts}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Correctivos</div>
      <div class="mt-1 text-2xl font-bold text-red-600">{totalCorrectivos}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Preventivos</div>
      <div class="mt-1 text-2xl font-bold text-emerald-600">{totalPreventivos}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">MTBF</div>
      <div class="mt-1 text-2xl font-bold text-purple-600">{mtbfDias != null ? `${mtbfDias.toFixed(0)}d` : "—"}</div>
      <div class="text-[10px] text-slate-500">Entre correctivos</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Costo total</div>
      <div class="mt-1 text-2xl font-bold text-slate-700">${costoTotal.toFixed(0)}</div>
      <div class="text-[10px] text-slate-500">MO ${costoMOTotal.toFixed(0)} · Rep ${costoRepTotal.toFixed(0)}</div>
    </div>
    <div class="card p-4">
      <div class="text-xs uppercase text-slate-500">Satisfacción</div>
      {satAvg != null ? (
        <>
          <div class="mt-1 text-2xl font-bold text-violet-600">{satAvg.toFixed(1)}<span class="text-sm text-slate-400">/5</span></div>
          <div class="text-[10px] text-slate-500">{sats.length} respuestas</div>
        </>
      ) : (
        <>
          <div class="mt-1 text-2xl font-bold text-slate-300">—</div>
          <div class="text-[10px] text-slate-500">Sin encuestas</div>
        </>
      )}
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-3">
    <!-- Costo mensual -->
    <div class="card lg:col-span-2 p-5">
      <h2 class="font-semibold text-slate-900">Costo de mantenimiento (12 meses)</h2>
      <div class="mt-4 flex items-end gap-1.5 overflow-x-auto pb-2" style="height:160px">
        {costoMes.map((m) => {
          const hMo = (m.mo / maxCosto) * 130;
          const hRep = (m.rep / maxCosto) * 130;
          return (
            <div class="flex min-w-[40px] flex-1 flex-col items-center gap-1">
              <div class="flex flex-1 flex-col-reverse gap-0 w-5">
                <div class="w-full rounded-b bg-amber-400" style={`height:${hRep}px`} title={`Repuestos $${m.rep.toFixed(0)}`}></div>
                <div class="w-full rounded-t bg-blue-500" style={`height:${hMo}px`} title={`Mano obra $${m.mo.toFixed(0)}`}></div>
              </div>
              <div class="text-[9px] text-slate-500 capitalize whitespace-nowrap">{m.mes}</div>
              <div class="text-[9px] text-slate-700 font-mono">${m.total.toFixed(0)}</div>
            </div>
          );
        })}
      </div>
      <div class="mt-2 flex gap-4 text-xs text-slate-600">
        <span><span class="inline-block h-3 w-3 rounded bg-blue-500"></span> Mano de obra</span>
        <span><span class="inline-block h-3 w-3 rounded bg-amber-400"></span> Repuestos</span>
      </div>
    </div>

    <!-- Top repuestos -->
    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Top repuestos usados</h2>
      <ul class="mt-3 divide-y divide-slate-100 text-sm">
        {topRepuestos.length === 0 && <li class="py-2 text-slate-400">Sin repuestos consumidos.</li>}
        {topRepuestos.map((r) => (
          <li class="flex items-center justify-between py-2">
            <div class="min-w-0 flex-1">
              <div class="truncate font-medium">{r.codigo} · {r.nombre}</div>
              <div class="text-xs text-slate-500">{r.cantidad} usados · ${r.subtotal.toFixed(2)}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Timeline -->
  <div class="mt-6">
    <h2 class="font-semibold text-slate-900 mb-3">Timeline ({eventos.length} eventos)</h2>
    {eventos.length === 0 && <div class="card p-6 text-center text-slate-400">Sin actividad registrada en este equipo.</div>}
    <div class="relative">
      <div class="absolute left-4 top-0 bottom-0 w-px bg-slate-200"></div>
      <ul class="space-y-3">
        {eventos.map((e) => (
          <li class:list={["relative pl-12 border-l-4 ml-4", e.color]}>
            <div class="absolute left-0 -ml-2 flex h-8 w-8 items-center justify-center rounded-full bg-white border border-slate-200 shadow-sm" style="margin-left:-1rem">
              <span class="text-base">{e.icono}</span>
            </div>
            <div class="card p-3 ml-4">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0 flex-1">
                  {e.link ? (
                    <a href={e.link} class="font-semibold text-brand-700 hover:underline">{e.titulo}</a>
                  ) : (
                    <span class="font-semibold">{e.titulo}</span>
                  )}
                  {e.detalle && <p class="mt-1 text-sm text-slate-700 whitespace-pre-wrap">{e.detalle}</p>}
                  {e.meta && <div class="mt-1 text-xs text-slate-500">{e.meta}</div>}
                </div>
                <span class="text-xs text-slate-400 whitespace-nowrap">{fmt(e.fecha)}</span>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>
