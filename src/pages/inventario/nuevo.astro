---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { proveedores, items } from "@/lib/schema";
import { eq, sql, like } from "drizzle-orm";
import { UNIDADES } from "@/lib/inventario";
import { CATEGORIAS_INVENTARIO } from "@/lib/categorias-inventario";
export const prerender = false;

const user = Astro.locals.user!;
if (!["admin", "jefe", "tecnico"].includes(user.rol)) return Astro.redirect("/inventario");

const db = getDb(Astro);
const provRows = await db
  .select({ id: proveedores.id, nombre: proveedores.nombre })
  .from(proveedores)
  .where(eq(proveedores.activo, true))
  .orderBy(proveedores.nombre);

// Auto-generación del código: busca el ultimo INV-XXXX y sugiere el siguiente
const ultimosCodigos = await db
  .select({ codigo: items.codigo })
  .from(items)
  .where(like(items.codigo, "INV-%"));

let nextNum = 1;
for (const { codigo } of ultimosCodigos) {
  const m = codigo.match(/^INV-(\d+)$/);
  if (m) {
    const n = parseInt(m[1], 10);
    if (n >= nextNum) nextNum = n + 1;
  }
}
const codigoSugerido = `INV-${String(nextNum).padStart(4, "0")}`;
---

<Layout title="Nuevo item">
  <a href="/inventario" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>
  <h1 class="mt-2 text-2xl font-bold">Nuevo item de inventario</h1>

  <form id="form" class="card mt-4 space-y-4 p-5">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="label">Código *</label>
        <div class="flex gap-2">
          <input class="input flex-1 font-mono" id="codigo" required value={codigoSugerido} />
          <button type="button" id="autoCodeBtn" class="btn-secondary text-sm" title="Volver al código sugerido">↻</button>
        </div>
        <p class="mt-1 text-xs text-slate-500">Se sugiere automáticamente. Puedes cambiarlo si necesitas otro prefijo.</p>
      </div>
      <div>
        <label class="label">Categoría</label>
        <input class="input" id="categoria" list="categoriasList" placeholder="Selecciona o escribe..." />
        <datalist id="categoriasList">
          {CATEGORIAS_INVENTARIO.map((g) => (
            g.items.map((it) => <option value={`${g.icono} ${it}`}>{g.grupo}</option>)
          ))}
        </datalist>
        <p class="mt-1 text-xs text-slate-500">Empieza a escribir o haz click para ver sugerencias.</p>
      </div>
      <div class="sm:col-span-2">
        <label class="label">Nombre *</label>
        <input class="input" id="nombre" required placeholder="Ej: Filtro de aire 12,000 BTU genérico" />
      </div>
      <div class="sm:col-span-2">
        <label class="label">Descripción</label>
        <textarea class="input" id="descripcion" rows="2" placeholder="Marca, especificaciones, compatibilidad..."></textarea>
      </div>
      <div>
        <label class="label">Unidad de medida</label>
        <select class="input" id="unidad">
          {UNIDADES.map((u) => <option value={u.value}>{u.label}</option>)}
        </select>
      </div>
      <div>
        <label class="label">Stock mínimo (alerta)</label>
        <input class="input" id="stockMinimo" type="number" min="0" step="0.01" value="0" />
        <p class="mt-1 text-xs text-slate-500">Si el stock cae por debajo, se sugiere comprar.</p>
      </div>
      <div>
        <label class="label">Stock máximo (objetivo)</label>
        <input class="input" id="stockMaximo" type="number" min="0" step="0.01" value="0" />
        <p class="mt-1 text-xs text-slate-500">Cantidad meta a tener en bodega. Define cuánto comprar al llegar al mínimo.</p>
      </div>
      <div>
        <label class="label">Presentación de compra (opcional)</label>
        <input class="input" id="presentacion" placeholder="Ej: Galón, Caja x 12, Saco 25 kg" />
        <p class="mt-1 text-xs text-slate-500">Cómo se compra al proveedor.</p>
      </div>
      <div>
        <label class="label">Factor de presentación</label>
        <input class="input" id="factorPresentacion" type="number" min="0.01" step="0.01" value="1" />
        <p class="mt-1 text-xs text-slate-500">¿Cuántas <em>unidades de medida</em> trae la presentación? Ej: galón = 3.785 L.</p>
      </div>
      <div>
        <label class="label">Precio de referencia</label>
        <input class="input" id="precioReferencia" type="number" min="0" step="0.01" placeholder="0.00" />
      </div>
      {provRows.length > 0 && (
        <div>
          <label class="label">Proveedor principal</label>
          <select class="input" id="proveedorPrincipalId">
            <option value="">— Sin proveedor —</option>
            {provRows.map((p) => <option value={p.id}>{p.nombre}</option>)}
          </select>
        </div>
      )}
    </div>
    <p id="err" class="hidden text-sm text-red-600"></p>
    <div class="flex gap-2">
      <button class="btn-primary" type="submit">Crear item</button>
      <a class="btn-secondary" href="/inventario">Cancelar</a>
    </div>
  </form>

  <script define:vars={{ codigoSugerido }}>
    const form = document.getElementById("form");
    const err = document.getElementById("err");
    document.getElementById("autoCodeBtn")?.addEventListener("click", () => {
      document.getElementById("codigo").value = codigoSugerido;
    });
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      err.classList.add("hidden");
      const v = (id) => document.getElementById(id).value.trim();
      const sv = (id) => document.getElementById(id)?.value;
      const provEl = document.getElementById("proveedorPrincipalId");
      const payload = {
        codigo: v("codigo"),
        nombre: v("nombre"),
        descripcion: v("descripcion") || null,
        categoria: v("categoria") || null,
        unidad: v("unidad"),
        stockMinimo: Number(sv("stockMinimo") || 0),
        stockMaximo: Number(sv("stockMaximo") || 0),
        presentacion: v("presentacion") || null,
        factorPresentacion: Number(sv("factorPresentacion") || 1),
        precioReferencia: sv("precioReferencia") ? Number(sv("precioReferencia")) : null,
        proveedorPrincipalId: provEl?.value ? Number(provEl.value) : null,
      };
      const res = await fetch("/api/items", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        err.textContent = typeof j.error === "string" ? j.error : "Error al crear";
        err.classList.remove("hidden");
        return;
      }
      const j = await res.json();
      location.href = `/inventario/${j.item.id}`;
    });
  </script>
</Layout>
