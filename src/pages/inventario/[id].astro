---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import {
  items, stock, movimientosInventario, usuarios, proveedores,
} from "@/lib/schema";
import { eq, desc } from "drizzle-orm";
import { fmtCantidad, TIPO_MOV_LABEL, TIPO_MOV_COLOR, MOTIVO_MOV } from "@/lib/inventario";
export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect("/inventario");

const user = Astro.locals.user!;
const db = getDb(Astro);

const [row] = await db
  .select({ item: items, prov: proveedores })
  .from(items)
  .leftJoin(proveedores, eq(proveedores.id, items.proveedorPrincipalId))
  .where(eq(items.id, id))
  .limit(1);
if (!row) return Astro.redirect("/inventario");
const it = row.item;

const [stockRow] = await db.select().from(stock).where(eq(stock.itemId, id)).limit(1);
const stockTotal = stockRow?.cantidad ?? 0;

const movRows = await db
  .select({ m: movimientosInventario, u: usuarios })
  .from(movimientosInventario)
  .leftJoin(usuarios, eq(usuarios.id, movimientosInventario.usuarioId))
  .where(eq(movimientosInventario.itemId, id))
  .orderBy(desc(movimientosInventario.id))
  .limit(50);

const fmt = (s: string | null) => (s ? new Date(s).toLocaleString("es", { timeZone: "America/El_Salvador" }) : "-");
const puedeMover = ["admin", "jefe", "tecnico"].includes(user.rol);

const bajoMinimo = stockTotal < it.stockMinimo;
const sugerenciaCompra = bajoMinimo && it.stockMaximo > 0 ? Math.max(0, it.stockMaximo - stockTotal) : 0;
---

<Layout title={it.nombre}>
  <a href="/inventario" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>

  <div class="mt-2 flex flex-wrap items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-2">
        <span class="rounded bg-slate-100 px-2 py-0.5 font-mono text-xs text-slate-700">{it.codigo}</span>
        <h1 class="text-2xl font-bold">{it.nombre}</h1>
      </div>
      <p class="mt-1 text-sm text-slate-500">
        {it.categoria && <span>{it.categoria} · </span>}
        Unidad: <strong>{it.unidad}</strong>
        {it.presentacion && <span> · Presentación: <strong>{it.presentacion}</strong> ({it.factorPresentacion} {it.unidad})</span>}
        {row.prov && <span> · Proveedor: {row.prov.nombre}</span>}
      </p>
      {it.descripcion && <p class="mt-2 text-sm text-slate-700">{it.descripcion}</p>}
    </div>
    <div class="text-right">
      <div class="text-xs uppercase text-slate-500">Stock en bodega</div>
      <div class:list={["text-3xl font-bold", bajoMinimo ? "text-red-600" : "text-brand-600"]}>
        {fmtCantidad(stockTotal, it.unidad)}
      </div>
      <div class="text-xs text-slate-500">Mínimo {fmtCantidad(it.stockMinimo, it.unidad)} · Máximo {fmtCantidad(it.stockMaximo, it.unidad)}</div>
      {sugerenciaCompra > 0 && (
        <div class="mt-2 rounded bg-orange-50 px-3 py-1.5 text-xs font-medium text-orange-700">
          ⚠ Comprar {fmtCantidad(sugerenciaCompra, it.unidad)} para llegar al máximo
        </div>
      )}
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <!-- Stock & resumen -->
    <div class="card p-5">
      <h2 class="font-semibold text-slate-900">Resumen de stock</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div class="flex justify-between"><dt class="text-slate-500">Disponible</dt><dd class:list={["font-mono", bajoMinimo ? "text-red-600" : "text-slate-700"]}>{fmtCantidad(stockTotal, it.unidad)}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Mínimo (alerta)</dt><dd class="font-mono text-slate-700">{fmtCantidad(it.stockMinimo, it.unidad)}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Máximo (objetivo)</dt><dd class="font-mono text-slate-700">{fmtCantidad(it.stockMaximo, it.unidad)}</dd></div>
        {it.presentacion && (
          <div class="flex justify-between border-t border-slate-100 pt-2">
            <dt class="text-slate-500">Presentación de compra</dt>
            <dd class="font-mono text-slate-700">{it.presentacion} = {it.factorPresentacion} {it.unidad}</dd>
          </div>
        )}
        {sugerenciaCompra > 0 && it.factorPresentacion > 0 && it.presentacion && (
          <div class="flex justify-between rounded bg-orange-50 px-2 py-2 text-orange-700">
            <dt>Comprar (en presentación)</dt>
            <dd class="font-mono font-semibold">≈ {Math.ceil(sugerenciaCompra / it.factorPresentacion)} {it.presentacion}</dd>
          </div>
        )}
      </dl>
    </div>

    <!-- Movimiento manual (sin sucursal) -->
    {puedeMover && (
      <div class="card p-5">
        <h2 class="font-semibold text-slate-900">Registrar movimiento</h2>
        <div class="mt-3 grid grid-cols-1 gap-3 text-sm">
          <div>
            <label class="label">Tipo</label>
            <select class="input" id="m_tipo">
              <option value="entrada">⬆ Entrada (suma al stock)</option>
              <option value="salida">⬇ Salida (resta del stock)</option>
              <option value="ajuste">⚙ Ajuste (cantidad absoluta)</option>
            </select>
          </div>
          <div>
            <label class="label">Cantidad ({it.unidad})</label>
            <input class="input" id="m_cantidad" type="number" min="0" step="0.01" required />
          </div>
          <div>
            <label class="label">Motivo</label>
            <select class="input" id="m_motivo">
              <option value="ajuste_manual">Ajuste manual</option>
              <option value="inicial">Inventario inicial</option>
              <option value="devolucion">Devolución</option>
              <option value="consumo">Consumo en OT</option>
              <option value="merma">Merma / pérdida</option>
            </select>
          </div>
          <div>
            <label class="label">Notas (opcional)</label>
            <textarea class="input" id="m_notas" rows="2"></textarea>
          </div>
          <button id="m_save" class="btn-primary">Registrar</button>
          <p id="m_msg" class="hidden text-sm"></p>
        </div>
      </div>
    )}
  </div>

  <!-- Historial de movimientos -->
  <div class="card mt-6 overflow-hidden">
    <div class="px-5 pt-4 pb-2"><h2 class="font-semibold text-slate-900">Movimientos recientes ({movRows.length})</h2></div>
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          <th class="px-4 py-2">Fecha</th>
          <th class="px-4 py-2">Tipo</th>
          <th class="px-4 py-2 text-right">Cantidad</th>
          <th class="px-4 py-2">Motivo</th>
          <th class="px-4 py-2">Usuario</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {movRows.length === 0 && (
          <tr><td colspan="5" class="px-4 py-6 text-center text-slate-400">Sin movimientos.</td></tr>
        )}
        {movRows.map((r) => (
          <tr>
            <td class="px-4 py-2 text-xs text-slate-500">{fmt(r.m.createdAt)}</td>
            <td class="px-4 py-2">
              <span class={`badge ${TIPO_MOV_COLOR[r.m.tipo]}`}>{TIPO_MOV_LABEL[r.m.tipo]}</span>
            </td>
            <td class:list={["px-4 py-2 text-right font-mono", r.m.tipo === "salida" ? "text-red-600" : "text-emerald-700"]}>
              {r.m.tipo === "salida" ? "−" : "+"}{fmtCantidad(Math.abs(r.m.cantidad))}
            </td>
            <td class="px-4 py-2 text-slate-600">{MOTIVO_MOV[r.m.motivo ?? ""] ?? r.m.motivo ?? "—"}</td>
            <td class="px-4 py-2 text-slate-600">{r.u?.nombre ?? "—"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script define:vars={{ id }}>
    document.getElementById("m_save")?.addEventListener("click", async () => {
      const msg = document.getElementById("m_msg");
      msg.classList.add("hidden");
      const payload = {
        tipo: document.getElementById("m_tipo").value,
        cantidad: Number(document.getElementById("m_cantidad").value),
        motivo: document.getElementById("m_motivo").value,
        notas: document.getElementById("m_notas").value.trim() || null,
      };
      const res = await fetch(`/api/items/${id}/movimiento`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        msg.textContent = typeof j.error === "string" ? j.error : "Error al registrar";
        msg.className = "text-sm text-red-600";
        msg.classList.remove("hidden");
        return;
      }
      location.reload();
    });
  </script>
</Layout>
