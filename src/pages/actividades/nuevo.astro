---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { actividadCategorias, sucursales, ubicaciones, usuarios, proveedores } from "@/lib/schema";
import { eq, asc, and, inArray } from "drizzle-orm";
import { puedeAdministrarActividades } from "@/lib/actividades";
export const prerender = false;

const user = Astro.locals.user!;
if (!puedeAdministrarActividades(user.rol)) return Astro.redirect("/actividades");

const db = getDb(Astro);
const cats = await db.select().from(actividadCategorias).where(eq(actividadCategorias.activo, true)).orderBy(asc(actividadCategorias.orden));
const sucs = await db.select({ id: sucursales.id, nombre: sucursales.nombre }).from(sucursales).where(eq(sucursales.activa, true)).orderBy(sucursales.nombre);
const ubRows = await db.select().from(ubicaciones).where(eq(ubicaciones.activa, true));
const tecnicos = await db.select({ id: usuarios.id, nombre: usuarios.nombre, rol: usuarios.rol }).from(usuarios).where(and(eq(usuarios.activo, true), inArray(usuarios.rol, ["tecnico", "jefe", "proveedor"]))).orderBy(asc(usuarios.nombre));
const provs = await db.select({ id: proveedores.id, nombre: proveedores.nombre }).from(proveedores).where(eq(proveedores.activo, true)).orderBy(proveedores.nombre);
const ubJson = JSON.stringify(ubRows);
const hoy = new Date().toISOString().slice(0, 10);
---

<Layout title="Nueva actividad">
  <a href="/actividades" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>
  <h1 class="mt-2 text-2xl font-bold">Nueva actividad recurrente</h1>

  <form id="form" class="card mt-4 space-y-5 p-5">
    <p class="text-xs text-slate-500">El código se genera automáticamente (ACT-XXXX).</p>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label class="label">Título *</label>
        <input class="input" id="titulo" required placeholder="Ej: Limpieza trampa de grasa cocina" />
      </div>
      <div>
        <label class="label">Categoría</label>
        <select class="input" id="categoriaId">
          <option value="">— Seleccionar —</option>
          {cats.map((c) => <option value={c.id}>{c.icono} {c.nombre}</option>)}
        </select>
      </div>
      <div class="sm:col-span-2">
        <label class="label">Descripción / instrucciones</label>
        <textarea class="input" id="descripcion" rows="3"></textarea>
      </div>
    </div>

    <div>
      <h2 class="font-semibold text-slate-900">Ubicación</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div>
          <label class="label">Sucursal</label>
          <select class="input" id="sucursalId">
            <option value="">— Seleccionar —</option>
            {sucs.map((s) => <option value={s.id}>{s.nombre}</option>)}
          </select>
        </div>
        <div>
          <label class="label">Ubicación específica</label>
          <select class="input" id="ubicacionId">
            <option value="">— Seleccionar —</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="label">Detalle de ubicación</label>
          <input class="input" id="ubicacionDetalle" placeholder="Ej: Cocina principal, junto al fregadero" />
        </div>
      </div>
    </div>

    <div>
      <h2 class="font-semibold text-slate-900">Programación</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div>
          <label class="label">Frecuencia *</label>
          <select class="input" id="frecuencia" required>
            <option value="diaria">Diaria</option>
            <option value="semanal">Semanal</option>
            <option value="quincenal">Quincenal</option>
            <option value="mensual" selected>Mensual</option>
            <option value="bimestral">Bimestral</option>
            <option value="trimestral">Trimestral</option>
            <option value="semestral">Semestral</option>
            <option value="anual">Anual</option>
          </select>
        </div>
        <div>
          <label class="label">Próxima fecha *</label>
          <input class="input" id="proximaFecha" type="date" required value={hoy} />
        </div>
        <div>
          <label class="label">Alerta días antes</label>
          <input class="input" id="alertaDiasAntes" type="number" min="0" max="60" value="7" />
        </div>
        <div>
          <label class="label">Prioridad</label>
          <select class="input" id="prioridad">
            <option value="baja">Baja</option>
            <option value="media" selected>Media</option>
            <option value="alta">Alta</option>
            <option value="urgente">Urgente</option>
          </select>
        </div>
        <div>
          <label class="label">Horas estimadas</label>
          <input class="input" id="horasEstimadas" type="number" min="0" step="0.5" />
        </div>
      </div>
    </div>

    <div>
      <h2 class="font-semibold text-slate-900">Responsables</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div>
          <label class="label">Técnico responsable</label>
          <select class="input" id="asignadoA">
            <option value="">— Sin asignar —</option>
            {tecnicos.map((t) => <option value={t.id}>{t.nombre}</option>)}
          </select>
        </div>
        <div>
          <label class="label">Proveedor externo (opcional)</label>
          <select class="input" id="proveedorExternoId">
            <option value="">— Ninguno —</option>
            {provs.map((p) => <option value={p.id}>{p.nombre}</option>)}
          </select>
        </div>
      </div>
    </div>

    <details class="rounded-lg border border-slate-200 bg-white p-3">
      <summary class="cursor-pointer text-sm font-medium text-slate-700">+ Agregar checklist (opcional)</summary>
      <p class="mt-2 text-xs text-slate-500">Una línea por item. Se copiará a cada OT generada.</p>
      <textarea id="checklistRaw" class="input mt-2" rows="4" placeholder="Verificar nivel de grasa&#10;Limpiar filtros&#10;Desinfectar superficie"></textarea>
    </details>

    <div>
      <label class="label">Notas internas</label>
      <textarea class="input" id="notas" rows="2"></textarea>
    </div>

    <p id="err" class="hidden text-sm text-red-600"></p>
    <div class="flex gap-2">
      <button class="btn-primary" type="submit">Crear actividad</button>
      <a class="btn-secondary" href="/actividades">Cancelar</a>
    </div>
  </form>

  <script define:vars={{ ubJson }}>
    const allUbs = JSON.parse(ubJson);
    const sucEl = document.getElementById("sucursalId");
    const ubEl = document.getElementById("ubicacionId");
    sucEl?.addEventListener("change", () => {
      const sid = Number(sucEl.value);
      const filtered = sid ? allUbs.filter((u) => u.sucursalId === sid) : [];
      ubEl.innerHTML = '<option value="">— Seleccionar —</option>';
      filtered.forEach((u) => {
        const o = document.createElement("option");
        o.value = u.id; o.textContent = `${u.nombre} (${u.tipo})`;
        ubEl.appendChild(o);
      });
    });

    document.getElementById("form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const err = document.getElementById("err");
      err.classList.add("hidden");
      const v = (id) => document.getElementById(id).value.trim();
      const num = (id) => { const x = document.getElementById(id).value; return x === "" ? null : Number(x); };
      const checkRaw = v("checklistRaw");
      let checklist = null;
      if (checkRaw) {
        const items = checkRaw.split("\n").map((l) => l.trim()).filter(Boolean).map((texto) => ({ texto, hecho: false }));
        if (items.length) checklist = JSON.stringify(items);
      }
      const sucV = sucEl.value;
      const ubV = ubEl.value;
      const catV = document.getElementById("categoriaId").value;
      const asignV = document.getElementById("asignadoA").value;
      const provV = document.getElementById("proveedorExternoId").value;
      const payload = {
        titulo: v("titulo"),
        descripcion: v("descripcion") || null,
        categoriaId: catV ? Number(catV) : null,
        sucursalId: sucV ? Number(sucV) : null,
        ubicacionId: ubV ? Number(ubV) : null,
        ubicacionDetalle: v("ubicacionDetalle") || null,
        frecuencia: document.getElementById("frecuencia").value,
        proximaFecha: v("proximaFecha"),
        alertaDiasAntes: num("alertaDiasAntes") ?? 7,
        prioridad: document.getElementById("prioridad").value,
        horasEstimadas: num("horasEstimadas"),
        checklist,
        asignadoA: asignV ? Number(asignV) : null,
        proveedorExternoId: provV ? Number(provV) : null,
        notas: v("notas") || null,
      };
      const res = await fetch("/api/actividades", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(payload) });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        err.textContent = typeof j.error === "string" ? j.error : "Error al crear";
        err.classList.remove("hidden");
        return;
      }
      const j = await res.json();
      location.href = `/actividades/${j.actividad.id}`;
    });
  </script>
</Layout>
