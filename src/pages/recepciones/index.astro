---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { recepciones, proveedores, usuarios } from "@/lib/schema";
import { eq, desc } from "drizzle-orm";
export const prerender = false;

const user = Astro.locals.user!;
const db = getDb(Astro);

const rows = await db
  .select({ r: recepciones, p: proveedores, u: usuarios })
  .from(recepciones)
  .leftJoin(proveedores, eq(proveedores.id, recepciones.proveedorId))
  .leftJoin(usuarios, eq(usuarios.id, recepciones.recibidoPor))
  .orderBy(desc(recepciones.id));

const fmt = (s: string) => new Date(s).toLocaleDateString("es");
const puedeCrear = ["admin", "jefe", "tecnico"].includes(user.rol);
---

<Layout title="Recepciones">
  <a href="/inventario" class="text-sm text-slate-500 hover:underline">&larr; Inventario</a>
  <div class="mt-2 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">Recepciones de proveedor</h1>
      <p class="text-sm text-slate-500">{rows.length} recepciones registradas</p>
    </div>
    {puedeCrear && <a href="/recepciones/nueva" class="btn-primary">+ Nueva recepción</a>}
  </div>

  <div class="card mt-4 overflow-hidden">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase text-slate-500">
        <tr>
          <th class="px-4 py-2">#</th>
          <th class="px-4 py-2">Fecha</th>
          <th class="px-4 py-2">Factura</th>
          <th class="px-4 py-2">Proveedor</th>
          <th class="px-4 py-2 text-right">Total</th>
          <th class="px-4 py-2">Recibió</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.length === 0 && (
          <tr><td colspan="6" class="px-4 py-6 text-center text-slate-400">Sin recepciones aún.</td></tr>
        )}
        {rows.map((r) => (
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2 font-mono text-xs">#{r.r.id}</td>
            <td class="px-4 py-2">{fmt(r.r.fecha)}</td>
            <td class="px-4 py-2 text-slate-600">{r.r.numeroFactura ?? "—"}</td>
            <td class="px-4 py-2">{r.p?.nombre ?? <span class="text-slate-400">Sin proveedor</span>}</td>
            <td class="px-4 py-2 text-right font-mono">{r.r.total != null ? `$${r.r.total.toFixed(2)}` : "—"}</td>
            <td class="px-4 py-2 text-slate-600">{r.u?.nombre ?? "—"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>
