---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/lib/db";
import { items, proveedores } from "@/lib/schema";
import { eq } from "drizzle-orm";
export const prerender = false;

const user = Astro.locals.user!;
if (!["admin", "jefe", "tecnico"].includes(user.rol)) return Astro.redirect("/requisiciones");

const db = getDb(Astro);

const provRows = await db
  .select({ id: proveedores.id, nombre: proveedores.nombre })
  .from(proveedores)
  .where(eq(proveedores.activo, true))
  .orderBy(proveedores.nombre);

const itRows = await db
  .select({
    id: items.id, codigo: items.codigo, nombre: items.nombre,
    unidad: items.unidad, presentacion: items.presentacion,
    factorPresentacion: items.factorPresentacion,
    precio: items.precioReferencia,
  })
  .from(items)
  .where(eq(items.activo, true))
  .orderBy(items.nombre);

const itemsJson = JSON.stringify(itRows);
---

<Layout title="Nueva requisición">
  <a href="/requisiciones" class="text-sm text-slate-500 hover:underline">&larr; Volver</a>
  <h1 class="mt-2 text-2xl font-bold">Nueva requisición de compra</h1>

  <div class="mt-3 flex gap-2 text-sm">
    <button id="modoManual" class="rounded-md bg-brand-600 px-3 py-1.5 font-medium text-white">📝 Manual</button>
    <button id="modoAuto" class="rounded-md bg-slate-100 px-3 py-1.5 font-medium text-slate-700 hover:bg-slate-200">⚠ Auto: items bajo mínimo</button>
  </div>

  <div id="autoBox" class="hidden card mt-3 p-4">
    <p class="text-sm text-slate-600">Items con stock por debajo del mínimo. Cantidad sugerida = máximo − actual.</p>
    <div id="autoLista" class="mt-3 text-sm">Cargando...</div>
    <button id="autoCargar" class="btn-primary mt-3 hidden">Cargar items seleccionados al borrador →</button>
  </div>

  <form id="form" class="card mt-4 space-y-4 p-5">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div>
        <label class="label">Proveedor sugerido</label>
        <select class="input" id="proveedorId">
          <option value="">— Sin proveedor —</option>
          {provRows.map((p) => <option value={p.id}>{p.nombre}</option>)}
        </select>
      </div>
      <div>
        <label class="label">Fecha necesidad</label>
        <input class="input" id="fechaNecesidad" type="date" />
      </div>
      <div>
        <label class="label">Origen</label>
        <input class="input" id="origenLabel" value="Manual" disabled />
        <input type="hidden" id="origen" value="manual" />
      </div>
      <div class="sm:col-span-3">
        <label class="label">Notas</label>
        <textarea class="input" id="notas" rows="2"></textarea>
      </div>
    </div>

    <div>
      <div class="mb-2 flex items-center justify-between">
        <h2 class="font-semibold text-slate-900">Items solicitados</h2>
        <button type="button" id="addLine" class="btn-secondary text-sm">+ Agregar línea</button>
      </div>
      <div class="overflow-x-auto rounded border border-slate-200">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-50 text-xs uppercase text-slate-500">
            <tr>
              <th class="px-3 py-2">Item</th>
              <th class="px-3 py-2 w-32">Cantidad</th>
              <th class="px-3 py-2 w-32">Precio unit.</th>
              <th class="px-3 py-2 w-32 text-right">Subtotal</th>
              <th class="px-3 py-2 w-12"></th>
            </tr>
          </thead>
          <tbody id="lines"></tbody>
          <tfoot class="bg-slate-50 text-sm font-semibold">
            <tr>
              <td colspan="3" class="px-3 py-2 text-right">Total</td>
              <td class="px-3 py-2 text-right font-mono"><span id="total">0.00</span></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <p id="err" class="hidden text-sm text-red-600"></p>
    <div class="flex gap-2">
      <button class="btn-primary" type="submit">Crear requisición</button>
      <a class="btn-secondary" href="/requisiciones">Cancelar</a>
    </div>
  </form>

  <script define:vars={{ itemsJson }}>
    const ITEMS = JSON.parse(itemsJson);
    const lines = document.getElementById("lines");
    let idx = 0;

    function recalcTotal() {
      let total = 0;
      lines.querySelectorAll("tr.line").forEach((tr) => {
        const cant = Number(tr.querySelector(".cant").value) || 0;
        const precio = Number(tr.querySelector(".precio").value) || 0;
        const sub = cant * precio;
        tr.querySelector(".sub").textContent = sub.toFixed(2);
        total += sub;
      });
      document.getElementById("total").textContent = total.toFixed(2);
    }

    function addLine(prefill) {
      const row = document.createElement("tr");
      row.className = "line";
      row.innerHTML = `
        <td class="px-3 py-1.5">
          <select class="input item text-sm">
            <option value="">— Selecciona item —</option>
            ${ITEMS.map((it) => `<option value="${it.id}" data-precio="${it.precio ?? ""}" data-unidad="${it.unidad}">${it.codigo} · ${it.nombre}${it.presentacion ? ` (${it.presentacion})` : ""}</option>`).join("")}
          </select>
        </td>
        <td class="px-3 py-1.5"><input type="number" min="0" step="0.01" class="input cant text-sm" /></td>
        <td class="px-3 py-1.5"><input type="number" min="0" step="0.01" class="input precio text-sm" /></td>
        <td class="px-3 py-1.5 text-right font-mono"><span class="sub">0.00</span></td>
        <td class="px-3 py-1.5"><button type="button" class="text-red-600 del">×</button></td>
      `;
      lines.appendChild(row);

      const sel = row.querySelector(".item");
      const precio = row.querySelector(".precio");
      const cant = row.querySelector(".cant");
      sel.addEventListener("change", () => {
        const opt = sel.selectedOptions[0];
        if (opt?.dataset.precio && !precio.value) precio.value = opt.dataset.precio;
        recalcTotal();
      });
      [cant, precio].forEach((el) => el.addEventListener("input", recalcTotal));
      row.querySelector(".del").addEventListener("click", () => { row.remove(); recalcTotal(); });

      if (prefill) {
        sel.value = String(prefill.itemId);
        cant.value = prefill.cantidad;
        if (prefill.precio) precio.value = prefill.precio;
        sel.dispatchEvent(new Event("change"));
      }
    }

    document.getElementById("addLine").addEventListener("click", () => addLine());
    addLine();

    // Modos manual / auto
    const modoManualBtn = document.getElementById("modoManual");
    const modoAutoBtn = document.getElementById("modoAuto");
    const autoBox = document.getElementById("autoBox");
    modoManualBtn.addEventListener("click", () => {
      autoBox.classList.add("hidden");
      modoManualBtn.className = "rounded-md bg-brand-600 px-3 py-1.5 font-medium text-white";
      modoAutoBtn.className = "rounded-md bg-slate-100 px-3 py-1.5 font-medium text-slate-700 hover:bg-slate-200";
      document.getElementById("origen").value = "manual";
      document.getElementById("origenLabel").value = "Manual";
    });
    modoAutoBtn.addEventListener("click", async () => {
      autoBox.classList.remove("hidden");
      modoAutoBtn.className = "rounded-md bg-brand-600 px-3 py-1.5 font-medium text-white";
      modoManualBtn.className = "rounded-md bg-slate-100 px-3 py-1.5 font-medium text-slate-700 hover:bg-slate-200";
      document.getElementById("origen").value = "auto_stock_minimo";
      document.getElementById("origenLabel").value = "Auto: stock mínimo";
      await cargarSugerencias();
    });

    async function cargarSugerencias() {
      const cont = document.getElementById("autoLista");
      cont.innerHTML = "Cargando...";
      const res = await fetch("/api/requisiciones/sugerencia");
      const j = await res.json();
      const items = j.items ?? [];
      if (items.length === 0) {
        cont.innerHTML = '<div class="text-slate-400">No hay items bajo mínimo. ¡Stock saludable!</div>';
        document.getElementById("autoCargar").classList.add("hidden");
        return;
      }
      cont.innerHTML = `<div class="overflow-x-auto rounded border border-slate-200">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-50 text-xs uppercase"><tr>
            <th class="px-3 py-2"><input type="checkbox" id="chkAll" checked /></th>
            <th class="px-3 py-2">Item</th>
            <th class="px-3 py-2 text-right">Actual</th>
            <th class="px-3 py-2 text-right">Mín</th>
            <th class="px-3 py-2 text-right">Máx</th>
            <th class="px-3 py-2 text-right">Sugerida</th>
            <th class="px-3 py-2">Proveedor</th>
          </tr></thead>
          <tbody>
          ${items.map((s, i) => `
            <tr>
              <td class="px-3 py-1.5"><input type="checkbox" class="chkAuto" data-i="${i}" checked /></td>
              <td class="px-3 py-1.5">${s.codigo} · ${s.nombre}</td>
              <td class="px-3 py-1.5 text-right font-mono text-red-600">${s.stockActual}</td>
              <td class="px-3 py-1.5 text-right font-mono text-slate-500">${s.stockMinimo}</td>
              <td class="px-3 py-1.5 text-right font-mono text-slate-500">${s.stockMaximo}</td>
              <td class="px-3 py-1.5 text-right font-mono font-semibold text-orange-700">${s.cantidadSugerida}</td>
              <td class="px-3 py-1.5 text-xs">${s.proveedorNombre ?? "—"}</td>
            </tr>
          `).join("")}
          </tbody>
        </table>
      </div>`;
      document.getElementById("autoCargar").classList.remove("hidden");
      document.getElementById("chkAll").addEventListener("change", (e) => {
        document.querySelectorAll(".chkAuto").forEach((c) => c.checked = e.target.checked);
      });
      document.getElementById("autoCargar").onclick = () => {
        // Limpiar líneas existentes y agregar las seleccionadas
        lines.innerHTML = "";
        document.querySelectorAll(".chkAuto").forEach((c) => {
          if (!c.checked) return;
          const s = items[Number(c.dataset.i)];
          addLine({ itemId: s.itemId, cantidad: s.cantidadSugerida, precio: s.precioReferencia });
        });
        recalcTotal();
      };
    }

    // Submit
    document.getElementById("form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const err = document.getElementById("err");
      err.classList.add("hidden");
      const lineas = [];
      lines.querySelectorAll("tr.line").forEach((tr) => {
        const itemId = Number(tr.querySelector(".item").value);
        const cantidad = Number(tr.querySelector(".cant").value);
        const precio = tr.querySelector(".precio").value;
        if (itemId && cantidad > 0) {
          lineas.push({
            itemId, cantidad,
            precioUnitario: precio ? Number(precio) : null,
          });
        }
      });
      if (lineas.length === 0) {
        err.textContent = "Agrega al menos una línea con item y cantidad.";
        err.classList.remove("hidden");
        return;
      }
      const provV = document.getElementById("proveedorId").value;
      const payload = {
        proveedorId: provV ? Number(provV) : null,
        fechaNecesidad: document.getElementById("fechaNecesidad").value || null,
        notas: document.getElementById("notas").value.trim() || null,
        origen: document.getElementById("origen").value,
        items: lineas,
      };
      const res = await fetch("/api/requisiciones", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        err.textContent = typeof j.error === "string" ? j.error : "Error al crear";
        err.classList.remove("hidden");
        return;
      }
      const j = await res.json();
      location.href = `/requisiciones/${j.requisicion.id}`;
    });
  </script>
</Layout>
