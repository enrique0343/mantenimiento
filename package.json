{
  "name": "mantenimiento",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist --d1=DB --r2=R2 --compatibility-date=2025-01-01",
    "deploy": "npm run build && wrangler pages deploy ./dist --project-name=mantenimiento-49c",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply mantenimiento-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply mantenimiento-db --remote",
    "db:seed:local": "wrangler d1 execute mantenimiento-db --local --file=./scripts/seed.sql",
    "db:seed:remote": "wrangler d1 execute mantenimiento-db --remote --file=./scripts/seed.sql",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.2.1",
    "@astrojs/react": "^4.2.0",
    "@astrojs/tailwind": "^6.0.0",
    "astro": "^5.2.5",
    "drizzle-orm": "^0.39.3",
    "jose": "^5.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250129.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "wrangler": "^3.105.0"
  }
}
