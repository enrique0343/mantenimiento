{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["@cloudflare/workers-types", "astro/client"]
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", ".wrangler", "node_modules"]
}
