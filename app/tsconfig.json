{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["@cloudflare/workers-types/2023-07-01"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
