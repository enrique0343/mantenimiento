---
import Layout from '../layouts/Layout.astro';
const user = Astro.locals.user!;
---
<Layout title="Dashboard">
  <h2 class="text-xl font-bold mb-6">Dashboard — KPIs</h2>

  <!-- Period selector -->
  <div class="flex flex-wrap gap-3 mb-6">
    <select id="period" class="input w-40">
      <option value="7">Últimos 7 días</option>
      <option value="30" selected>Últimos 30 días</option>
      <option value="90">Últimos 90 días</option>
    </select>
    <select id="branch" class="input w-48">
      <option value="">Todas las sucursales</option>
    </select>
  </div>

  <!-- KPI cards -->
  <div id="kpis" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="card text-center animate-pulse h-24 bg-gray-100"></div>
    <div class="card text-center animate-pulse h-24 bg-gray-100"></div>
    <div class="card text-center animate-pulse h-24 bg-gray-100"></div>
    <div class="card text-center animate-pulse h-24 bg-gray-100"></div>
  </div>

  <!-- Recent work orders -->
  <div class="card mb-6">
    <h3 class="font-semibold mb-4">Órdenes de trabajo recientes</h3>
    <div class="table-container">
      <table>
        <thead><tr>
          <th>Código</th><th>Tipo</th><th>Prioridad</th><th>Estado</th><th>Equipo</th><th>Fecha</th>
        </tr></thead>
        <tbody id="wo-table"><tr><td colspan="6" class="text-center text-gray-400 py-6">Cargando…</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- Open helpdesk tickets -->
  <div class="card">
    <h3 class="font-semibold mb-4">Tickets de helpdesk abiertos</h3>
    <div class="table-container">
      <table>
        <thead><tr>
          <th>Código</th><th>Solicitante</th><th>Área</th><th>Prioridad</th><th>SLA</th>
        </tr></thead>
        <tbody id="hd-table"><tr><td colspan="5" class="text-center text-gray-400 py-6">Cargando…</td></tr></tbody>
      </table>
    </div>
  </div>

  <script>
    const PRIORITY_COLORS: Record<string,string> = {
      CRITICAL:'bg-red-100 text-red-800', HIGH:'bg-orange-100 text-orange-800',
      MEDIUM:'bg-yellow-100 text-yellow-800', LOW:'bg-green-100 text-green-800',
    };
    const STATUS_COLORS: Record<string,string> = {
      OPEN:'bg-blue-100 text-blue-800', IN_PROGRESS:'bg-yellow-100 text-yellow-800',
      COMPLETED:'bg-green-100 text-green-800', CLOSED:'bg-gray-100 text-gray-600',
      ESCALATED:'bg-red-100 text-red-800',
    };
    const STATUS_LABELS: Record<string,string> = {
      OPEN:'Abierta', IN_PROGRESS:'En progreso', COMPLETED:'Completada',
      VERIFIED:'Verificada', CLOSED:'Cerrada', ESCALATED:'Escalado', RESOLVED:'Resuelta',
    };
    const TYPE_LABELS: Record<string,string> = {
      PREVENTIVE:'Preventivo', CORRECTIVE:'Correctivo', PREDICTIVE:'Predictivo',
    };
    function badge(label: string, cls: string) {
      return `<span class="badge ${cls}">${label}</span>`;
    }
    function slaLabel(deadline: string) {
      if (!deadline) return '—';
      const diff = (new Date(deadline).getTime() - Date.now()) / 36e5;
      if (diff < 0) return `<span class="text-red-600 font-medium">Vencido</span>`;
      if (diff < 4) return `<span class="text-orange-600 font-medium">${diff.toFixed(1)}h</span>`;
      return `<span class="text-green-600">${diff.toFixed(1)}h</span>`;
    }
    function fmtDate(d: string) {
      if (!d) return '—';
      return new Date(d).toLocaleDateString('es-CO', { day:'2-digit', month:'2-digit', year:'numeric' });
    }

    async function loadKpis() {
      const days     = (document.getElementById('period') as HTMLSelectElement).value;
      const branchId = (document.getElementById('branch') as HTMLSelectElement).value;
      const from = new Date(Date.now() - Number(days)*864e5).toISOString();
      const to   = new Date().toISOString();
      const qs   = new URLSearchParams({ from, to, ...(branchId ? { branch: branchId } : {}) });
      const data = await fetch(`/api/kpis/dashboard?${qs}`).then(r => r.json());

      document.getElementById('kpis')!.innerHTML = `
        <div class="card text-center">
          <div class="text-3xl font-bold text-primary-600">${data.equipment.availability}%</div>
          <div class="text-sm text-gray-500 mt-1">Disponibilidad</div>
          <div class="text-xs text-gray-400">${data.equipment.active}/${data.equipment.total} equipos</div>
        </div>
        <div class="card text-center">
          <div class="text-3xl font-bold text-green-600">${data.workOrders.compliancePct}%</div>
          <div class="text-sm text-gray-500 mt-1">Cumplimiento prev.</div>
          <div class="text-xs text-gray-400">${data.workOrders.completedPrev}/${data.workOrders.preventive} OTs</div>
        </div>
        <div class="card text-center">
          <div class="text-3xl font-bold text-orange-500">${data.workOrders.mttr}h</div>
          <div class="text-sm text-gray-500 mt-1">MTTR</div>
          <div class="text-xs text-gray-400">Tiempo medio reparación</div>
        </div>
        <div class="card text-center">
          <div class="text-3xl font-bold text-red-500">${data.workOrders.backlog}</div>
          <div class="text-sm text-gray-500 mt-1">Backlog correctivo</div>
          <div class="text-xs text-gray-400">OTs abiertas</div>
        </div>
      `;
    }

    async function loadWOs() {
      const rows = await fetch('/api/work-orders?').then(r => r.json());
      const tbody = document.getElementById('wo-table')!;
      if (!rows.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-center text-gray-400 py-4">Sin órdenes</td></tr>'; return; }
      tbody.innerHTML = rows.slice(0, 10).map((w: any) => `
        <tr>
          <td><a href="/ordenes/${w.id}" class="text-primary-600 hover:underline">${w.code}</a></td>
          <td>${TYPE_LABELS[w.type] ?? w.type}</td>
          <td>${badge(w.priority, PRIORITY_COLORS[w.priority] ?? '')}</td>
          <td>${badge(STATUS_LABELS[w.status] ?? w.status, STATUS_COLORS[w.status] ?? '')}</td>
          <td>${w.equipmentName ?? '—'}</td>
          <td>${fmtDate(w.createdAt)}</td>
        </tr>`).join('');
    }

    async function loadTickets() {
      const rows = await fetch('/api/helpdesk/tickets?status=OPEN').then(r => r.json());
      const tbody = document.getElementById('hd-table')!;
      if (!rows.length) { tbody.innerHTML = '<tr><td colspan="5" class="text-center text-gray-400 py-4">Sin tickets</td></tr>'; return; }
      tbody.innerHTML = rows.slice(0, 10).map((t: any) => `
        <tr>
          <td><a href="/helpdesk/${t.id}" class="text-primary-600 hover:underline">${t.code}</a></td>
          <td>${t.requesterName}</td>
          <td>${t.area}</td>
          <td>${badge(t.priority, PRIORITY_COLORS[t.priority] ?? '')}</td>
          <td>${slaLabel(t.slaDeadline)}</td>
        </tr>`).join('');
    }

    async function loadBranches() {
      const rows = await fetch('/api/branches').then(r => r.json());
      const sel = document.getElementById('branch') as HTMLSelectElement;
      rows.forEach((b: any) => {
        const opt = document.createElement('option');
        opt.value = b.id; opt.textContent = b.name;
        sel.appendChild(opt);
      });
    }

    document.getElementById('period')!.addEventListener('change', loadKpis);
    document.getElementById('branch')!.addEventListener('change', loadKpis);

    loadBranches();
    loadKpis();
    loadWOs();
    loadTickets();
  </script>
</Layout>
