---
// Public tracker page — no auth required
const { token } = Astro.params;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Estado de Solicitud</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen py-10 px-4">
  <div class="max-w-lg mx-auto">
    <div class="text-center mb-6">
      <h1 class="text-xl font-bold">Estado de tu Solicitud</h1>
    </div>
    <div id="content" class="bg-white rounded-xl shadow-sm border p-6">
      <p class="text-center text-gray-400">Cargando…</p>
    </div>
  </div>

  <script define:vars={{ trackingToken: token }}>
    const STATUS_LABELS = { OPEN:'Abierto', IN_PROGRESS:'En progreso', ESCALATED:'Escalado', RESOLVED:'Resuelto', CLOSED:'Cerrado' };
    const STATUS_COLORS = { OPEN:'bg-blue-100 text-blue-800', IN_PROGRESS:'bg-yellow-100 text-yellow-800', ESCALATED:'bg-red-100 text-red-800', RESOLVED:'bg-green-100 text-green-800', CLOSED:'bg-gray-100 text-gray-600' };
    const fmtDate = d => d ? new Date(d).toLocaleDateString('es-CO',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—';

    async function load() {
      const data = await fetch(`/api/helpdesk/track/${trackingToken}`).then(r => r.json());
      const el   = document.getElementById('content');
      if (data.error) { el.innerHTML = `<p class="text-red-500 text-center">${data.error}</p>`; return; }

      const badge = `<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${STATUS_COLORS[data.status]??''}">${STATUS_LABELS[data.status]??data.status}</span>`;
      el.innerHTML = `
        <div class="space-y-3">
          <div class="flex items-start justify-between">
            <span class="font-mono font-bold text-lg">${data.code}</span>
            ${badge}
          </div>
          <dl class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
            <div><dt class="text-gray-500">Solicitante</dt><dd>${data.requesterName}</dd></div>
            <div><dt class="text-gray-500">Área</dt><dd>${data.area}</dd></div>
            <div><dt class="text-gray-500">Enviado</dt><dd>${fmtDate(data.createdAt)}</dd></div>
            <div><dt class="text-gray-500">SLA</dt><dd>${fmtDate(data.slaDeadline)}</dd></div>
          </dl>
          <div class="text-sm">
            <p class="text-gray-500 font-medium mb-1">Descripción</p>
            <p>${data.description}</p>
          </div>
          ${data.resolutionNotes ? `<div class="bg-green-50 rounded p-3 text-sm"><p class="text-green-800 font-medium mb-1">Resolución</p><p>${data.resolutionNotes}</p></div>` : ''}
          ${data.comments?.length ? `
            <div>
              <p class="text-gray-500 font-medium text-sm mb-2">Comentarios del equipo</p>
              <div class="space-y-2">
                ${data.comments.map(c => `
                  <div class="border rounded p-3 text-sm">
                    <p class="font-medium">${c.authorName} <span class="text-xs text-gray-400">${fmtDate(c.createdAt)}</span></p>
                    <p>${c.content}</p>
                  </div>`).join('')}
              </div>
            </div>` : ''}
        </div>
        <div class="mt-4 pt-4 border-t text-center">
          <a href="/helpdesk/nuevo" class="text-blue-600 text-sm hover:underline">Nueva solicitud</a>
        </div>
      `;
    }

    load();
  </script>
</body>
</html>
