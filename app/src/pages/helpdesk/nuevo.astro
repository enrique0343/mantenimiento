---
// Public page — no auth required
const BASE_URL = (Astro.locals.runtime as any)?.env?.BASE_URL ?? '';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Solicitud de Mantenimiento</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-start justify-center py-10 px-4">
  <div class="w-full max-w-lg">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold">Mesa de Ayuda — Mantenimiento</h1>
      <p class="text-gray-500 text-sm mt-1">Complete el formulario para enviar su solicitud</p>
    </div>

    <div id="success" class="hidden bg-green-50 border border-green-300 text-green-800 rounded-lg p-5 text-center">
      <div class="text-4xl mb-3">✅</div>
      <h2 class="font-bold text-lg mb-2">Solicitud recibida</h2>
      <p class="text-sm mb-4">Su ticket fue registrado. Puede hacer seguimiento en el enlace que le enviamos al correo.</p>
      <p class="font-mono text-sm" id="ticket-code"></p>
      <a id="track-link" href="#" class="inline-block mt-3 text-primary-600 underline text-sm">Ver estado de mi solicitud →</a>
    </div>

    <form id="form" class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
      <div id="err" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded p-3"></div>

      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre completo *</label>
          <input class="w-full border rounded-md px-3 py-2 text-sm" name="requesterName" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Correo electrónico *</label>
          <input class="w-full border rounded-md px-3 py-2 text-sm" type="email" name="requesterEmail" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono / Extensión</label>
          <input class="w-full border rounded-md px-3 py-2 text-sm" name="requesterPhone" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Sucursal *</label>
          <select class="w-full border rounded-md px-3 py-2 text-sm" name="branchId" id="branch-sel" required>
            <option value="">— Seleccionar —</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Área / Servicio *</label>
          <input class="w-full border rounded-md px-3 py-2 text-sm" name="area" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de solicitud *</label>
          <select class="w-full border rounded-md px-3 py-2 text-sm" name="requestType" required>
            <option value="">— Seleccionar —</option>
            <option value="EQUIPMENT_FAILURE">Falla de equipo</option>
            <option value="MAINTENANCE_REQUEST">Solicitud de mantenimiento</option>
            <option value="OTHER">Otro</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Prioridad sugerida *</label>
          <select class="w-full border rounded-md px-3 py-2 text-sm" name="priority" required>
            <option value="MEDIUM">Media</option>
            <option value="LOW">Baja</option>
            <option value="HIGH">Alta</option>
            <option value="CRITICAL">Crítica</option>
          </select>
        </div>
        <div class="col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Descripción del problema *</label>
          <textarea class="w-full border rounded-md px-3 py-2 text-sm" name="description" rows="4" required></textarea>
        </div>
      </div>

      <button type="submit" class="w-full bg-blue-600 text-white rounded-md py-2 text-sm font-medium hover:bg-blue-700">
        Enviar solicitud
      </button>
    </form>
  </div>

  <script define:vars={{ baseUrl: BASE_URL }}>
    async function loadBranches() {
      const rows = await fetch('/api/branches').then(r => r.json()).catch(() => []);
      const sel  = document.getElementById('branch-sel');
      rows.forEach(b => {
        const opt = document.createElement('option');
        opt.value = b.id; opt.textContent = b.name; sel.appendChild(opt);
      });
    }
    const form = document.getElementById('form');
    const err  = document.getElementById('err');
    form.addEventListener('submit', async e => {
      e.preventDefault(); err.classList.add('hidden');
      const fd   = new FormData(form);
      const body = Object.fromEntries([...fd.entries()].filter(([,v]) => v !== ''));
      const res  = await fetch('/api/helpdesk/tickets', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      const json = await res.json();
      if (res.ok) {
        form.classList.add('hidden');
        const suc = document.getElementById('success');
        suc.classList.remove('hidden');
        document.getElementById('ticket-code').textContent = `Ticket: ${json.code}`;
        document.getElementById('track-link').href = `/helpdesk/ticket/${json.trackingToken}`;
      } else {
        err.textContent = json.error; err.classList.remove('hidden');
      }
    });
    loadBranches();
  </script>
</body>
</html>
