---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Helpdesk">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-bold">Mesa de Ayuda</h2>
    <a href="/helpdesk/nuevo" target="_blank" class="btn-secondary text-xs">Formulario público ↗</a>
  </div>

  <div class="flex flex-wrap gap-3 mb-4">
    <select id="f-status" class="input w-44">
      <option value="">Estado: todos</option>
      <option value="OPEN">Abierto</option>
      <option value="IN_PROGRESS">En progreso</option>
      <option value="ESCALATED">Escalado</option>
      <option value="RESOLVED">Resuelto</option>
      <option value="CLOSED">Cerrado</option>
    </select>
    <select id="f-branch" class="input w-44">
      <option value="">Sucursal: todas</option>
    </select>
  </div>

  <div class="table-container">
    <table>
      <thead><tr>
        <th>Ticket</th><th>Solicitante</th><th>Área</th><th>Tipo</th><th>Prioridad</th><th>Estado</th><th>SLA</th><th></th>
      </tr></thead>
      <tbody id="hd-table"><tr><td colspan="8" class="text-center py-8 text-gray-400">Cargando…</td></tr></tbody>
    </table>
  </div>

  <script>
    const P_CLR = { CRITICAL:'bg-red-100 text-red-800', HIGH:'bg-orange-100 text-orange-800', MEDIUM:'bg-yellow-100 text-yellow-800', LOW:'bg-green-100 text-green-800' };
    const S_CLR = { OPEN:'bg-blue-100 text-blue-800', IN_PROGRESS:'bg-yellow-100 text-yellow-800', ESCALATED:'bg-red-100 text-red-800', RESOLVED:'bg-green-100 text-green-800', CLOSED:'bg-gray-100 text-gray-500' };
    const S_LBL = { OPEN:'Abierto', IN_PROGRESS:'En progreso', ESCALATED:'Escalado', RESOLVED:'Resuelto', CLOSED:'Cerrado' };
    const T_LBL = { EQUIPMENT_FAILURE:'Falla equipo', MAINTENANCE_REQUEST:'Solicitud mant.', OTHER:'Otro' };
    function slaCell(deadline) {
      if (!deadline) return '—';
      const diff = (new Date(deadline) - Date.now()) / 36e5;
      if (diff < 0) return `<span class="text-red-600 font-medium text-xs">Vencido</span>`;
      if (diff < 4) return `<span class="text-orange-500 text-xs">${diff.toFixed(1)}h</span>`;
      return `<span class="text-green-600 text-xs">${diff.toFixed(1)}h</span>`;
    }

    async function load() {
      const status = (document.getElementById('f-status') as HTMLSelectElement).value;
      const branch = (document.getElementById('f-branch') as HTMLSelectElement).value;
      const qs = new URLSearchParams();
      if (status) qs.set('status', status);
      if (branch) qs.set('branch', branch);
      const rows = await fetch(`/api/helpdesk/tickets?${qs}`).then(r => r.json());
      const tbody = document.getElementById('hd-table')!;
      if (!rows.length) { tbody.innerHTML = '<tr><td colspan="8" class="text-center py-8 text-gray-400">Sin tickets</td></tr>'; return; }
      tbody.innerHTML = rows.map((t: any) => `
        <tr>
          <td class="font-mono text-xs"><a href="/helpdesk/${t.id}" class="text-primary-600 hover:underline">${t.code}</a></td>
          <td class="text-sm">${t.requesterName}</td>
          <td class="text-xs text-gray-500">${t.area}</td>
          <td class="text-xs">${T_LBL[t.requestType]??t.requestType}</td>
          <td><span class="badge ${P_CLR[t.priority]??''}">${t.priority}</span></td>
          <td><span class="badge ${S_CLR[t.status]??''}">${S_LBL[t.status]??t.status}</span></td>
          <td>${slaCell(t.slaDeadline)}</td>
          <td><a href="/helpdesk/${t.id}" class="text-primary-500 text-xs hover:underline">Ver →</a></td>
        </tr>`).join('');
    }

    async function loadBranches() {
      const rows = await fetch('/api/branches').then(r => r.json());
      const sel  = document.getElementById('f-branch') as HTMLSelectElement;
      rows.forEach((b: any) => {
        const opt = document.createElement('option');
        opt.value = b.id; opt.textContent = b.name; sel.appendChild(opt);
      });
    }

    ['f-status','f-branch'].forEach(id => document.getElementById(id)!.addEventListener('change', load));
    loadBranches(); load();
  </script>
</Layout>
