---
import Layout from '../../layouts/Layout.astro';
const { id } = Astro.params;
---
<Layout title="Ticket">
  <div class="max-w-3xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/helpdesk" class="text-gray-500 hover:text-gray-700">← Helpdesk</a>
      <h2 class="text-xl font-bold" id="ticket-title">Cargando…</h2>
      <span id="status-badge" class="badge"></span>
    </div>

    <div id="detail-card" class="card mb-4"></div>

    <!-- Actions -->
    <div id="actions" class="flex flex-wrap gap-3 mb-6"></div>

    <!-- Comments -->
    <div class="card mb-4">
      <h3 class="font-semibold mb-3">Historial de comentarios</h3>
      <div id="comments-list" class="space-y-3 mb-4"></div>
      <div class="border-t pt-3">
        <textarea id="new-comment" class="input" rows="2" placeholder="Agregar comentario…"></textarea>
        <div class="flex gap-3 mt-2 items-center">
          <button id="add-comment-btn" class="btn-primary text-sm">Agregar comentario</button>
          <label class="flex items-center gap-2 text-sm text-gray-600">
            <input type="checkbox" id="is-internal" /> Nota interna (no visible al solicitante)
          </label>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ ticketId: id }}>
    const S_LBL = { OPEN:'Abierto', IN_PROGRESS:'En progreso', ESCALATED:'Escalado', RESOLVED:'Resuelto', CLOSED:'Cerrado' };
    const S_CLR = { OPEN:'bg-blue-100 text-blue-800', IN_PROGRESS:'bg-yellow-100 text-yellow-800', ESCALATED:'bg-red-100 text-red-800', RESOLVED:'bg-green-100 text-green-800', CLOSED:'bg-gray-100 text-gray-500' };
    const P_CLR = { CRITICAL:'bg-red-100 text-red-800', HIGH:'bg-orange-100 text-orange-800', MEDIUM:'bg-yellow-100 text-yellow-800', LOW:'bg-green-100 text-green-800' };
    const T_LBL = { EQUIPMENT_FAILURE:'Falla de equipo', MAINTENANCE_REQUEST:'Solicitud de mantenimiento', OTHER:'Otro' };
    const fmtDate = d => d ? new Date(d).toLocaleString('es-CO') : '—';

    async function load() {
      const ticket = await fetch(`/api/helpdesk/tickets/${ticketId}`).then(r => r.json());
      if (ticket.error) { document.getElementById('ticket-title').textContent = 'No encontrado'; return; }

      document.getElementById('ticket-title').textContent = ticket.code;
      const sb = document.getElementById('status-badge');
      sb.textContent = S_LBL[ticket.status]??ticket.status;
      sb.className = `badge ${S_CLR[ticket.status]??''}`;

      document.getElementById('detail-card').innerHTML = `
        <dl class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
          <div><dt class="font-medium text-gray-500">Solicitante</dt><dd>${ticket.requesterName}</dd></div>
          <div><dt class="font-medium text-gray-500">Correo</dt><dd>${ticket.requesterEmail}</dd></div>
          <div><dt class="font-medium text-gray-500">Área</dt><dd>${ticket.area}</dd></div>
          <div><dt class="font-medium text-gray-500">Tipo</dt><dd>${T_LBL[ticket.requestType]??ticket.requestType}</dd></div>
          <div><dt class="font-medium text-gray-500">Prioridad</dt><dd><span class="badge ${P_CLR[ticket.priority]??''}">${ticket.priority}</span></dd></div>
          <div><dt class="font-medium text-gray-500">SLA</dt><dd>${fmtDate(ticket.slaDeadline)}</dd></div>
          <div><dt class="font-medium text-gray-500">Creado</dt><dd>${fmtDate(ticket.createdAt)}</dd></div>
          <div><dt class="font-medium text-gray-500">Resuelto</dt><dd>${fmtDate(ticket.resolvedAt)}</dd></div>
          <div class="col-span-2"><dt class="font-medium text-gray-500">Descripción</dt><dd class="mt-1">${ticket.description}</dd></div>
          ${ticket.resolutionNotes ? `<div class="col-span-2"><dt class="font-medium text-gray-500">Resolución</dt><dd class="mt-1 bg-green-50 p-2 rounded">${ticket.resolutionNotes}</dd></div>` : ''}
        </dl>
      `;

      // Actions based on status
      const actions = document.getElementById('actions');
      const btns = [];
      if (ticket.status === 'OPEN' || ticket.status === 'IN_PROGRESS') {
        btns.push(`
          <button onclick="setStatus('RESOLVED')" class="btn-primary">✓ Marcar como Resuelto</button>
          <button onclick="convertToWO()" class="btn-secondary">🔧 Convertir a OT Correctiva</button>
        `);
      }
      if (ticket.status === 'RESOLVED') btns.push(`<button onclick="setStatus('CLOSED')" class="btn-secondary">🔒 Cerrar ticket</button>`);
      actions.innerHTML = btns.join('');

      loadComments();
    }

    async function loadComments() {
      const rows = await fetch(`/api/helpdesk/tickets/${ticketId}?sub=comments`).then(r => r.json());
      const el   = document.getElementById('comments-list');
      if (!rows.length) { el.innerHTML = '<p class="text-sm text-gray-400">Sin comentarios aún.</p>'; return; }
      el.innerHTML = rows.map(c => `
        <div class="border rounded-md p-3 text-sm ${c.isInternal ? 'bg-yellow-50 border-yellow-200' : ''}">
          <div class="flex justify-between mb-1">
            <span class="font-medium">${c.authorName}${c.isInternal ? ' <span class="text-xs text-yellow-700">[interna]</span>' : ''}</span>
            <span class="text-xs text-gray-400">${new Date(c.createdAt).toLocaleString('es-CO')}</span>
          </div>
          <p>${c.content}</p>
        </div>`).join('');
    }

    async function setStatus(status) {
      const notes = status === 'RESOLVED' ? prompt('Nota de resolución (opcional):') ?? '' : '';
      await fetch(`/api/helpdesk/tickets/${ticketId}?sub=status`, {
        method: 'PATCH', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ status, resolutionNotes: notes }),
      });
      load();
    }

    async function convertToWO() {
      const res  = await fetch(`/api/helpdesk/tickets/${ticketId}?sub=convert`, {
        method: 'PATCH', headers: { 'content-type': 'application/json' }, body: '{}',
      });
      const json = await res.json();
      if (res.ok) window.location.href = `/ordenes/${json.workOrderId}`;
      else alert(json.error);
    }

    document.getElementById('add-comment-btn').addEventListener('click', async () => {
      const content    = (document.getElementById('new-comment') as HTMLTextAreaElement).value.trim();
      const isInternal = (document.getElementById('is-internal') as HTMLInputElement).checked;
      if (!content) return;
      await fetch(`/api/helpdesk/tickets/${ticketId}?sub=comment`, {
        method: 'PATCH', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ content, isInternal }),
      });
      (document.getElementById('new-comment') as HTMLTextAreaElement).value = '';
      loadComments();
    });

    load();
  </script>
</Layout>
